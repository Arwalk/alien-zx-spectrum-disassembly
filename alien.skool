; FillAttributeBlock
;
; Fills a rectangular block of attribute cells with A (loaded via A'), then
; draws the 10-tile corridor segment row. Advances the draw pointer by 1824
; bytes (one full character-row stride in the attribute file region), pops AF
; to recover the colour and segment counter from the stack, then draws 10
; corridor tiles using #R31626. Also updates the ambient sound and room-
; display state via #R34882 and #R39572.
;
@label=FillAttributeBlock
c31577 LD DE,1824    ; stride to next character row in attribute area
; This entry point is used by the routine at #R31562.
*31580 ADD HL,DE     ;
 31581 LD (31257),HL ;
 31584 POP AF        ;
 31585 INC A         ;
 31586 EX AF,AF'     ;
 31587 DEC A         ;
 31588 JR NZ,31559   ;
 31590 LD HL,30205   ;
 31593 LD (31261),HL ;
 31596 LD B,10       ;
*31598 PUSH BC       ;
 31599 CALL 31626    ;
 31602 POP BC        ;
 31603 DJNZ 31598    ;
 31605 CALL 34882    ;
 31608 CALL 39572    ;
 31611 RET           ;
; This entry point is used by the routines at #R31417, #R31634, #R34684,
; #R35222 and #R35578.
*31612 LD DE,22      ;
*31615 LD B,10       ;
*31617 LD (HL),A     ;
 31618 INC HL        ;
 31619 DJNZ 31617    ;
 31621 ADD HL,DE     ;
 31622 DEC C         ;
 31623 JR NZ,31615   ;
 31625 RET           ;

; DrawNextCorridorTile
;
; Reads the next tile index from the corridor position pointer at #R31261, draws
; it by falling through into #R31634 (DrawSprite), and advances the pointer.
;
; Used by the routines at #R31417, #R31577, #R31634, #R35290 and #R35578.
@label=DrawNextCorridorTile
@ignoreua
c31626 LD HL,(31261) ; HL = corridor tile-source pointer (#R31261)
 31629 LD A,(HL)     ; A = next tile index
 31630 INC HL        ; advance pointer
 31631 LD (31261),HL ; save updated pointer; fall through to DrawSprite

; DrawSprite
;
; Draws a 10-column × 8-row (80px wide) sprite at the current draw position
; (#R31241). Each column is one 8-pixel-tall tile drawn by #R31369. The sprite
; data is a table of 10 tile indices (each 10 bytes wide) looked up from the
; 10-byte-per-sprite character table at #R28221 ($#R28221). After drawing 10
; columns, advances #R31241 to the next character row accounting for the ZX
; Spectrum display-file row wrapping.
;
; Input:  A = sprite index (255 → use default/blank sprite index 92)
;         (#R31241) = screen destination address
;
; Used by the routines at #R31417, #R33610, #R35290, #R35451, #R35578, #R36457,
; #R36859, #R37018, #R37490, #R38379, #R40826, #R44880 and #R45401.
@label=DrawSprite
c31634 CP 255        ; sprite index 255 = invalid/absent
 31636 JR NZ,31640   ; valid index: draw it
 31638 LD A,92       ; substitute blank sprite (index 92)
*31640 LD L,A        ; L = sprite index
 31641 LD H,0        ;
 31643 ADD HL,HL     ; HL = index × 2
 31644 PUSH HL       ; save HL = index × 2
 31645 ADD HL,HL     ; HL = index × 4
 31646 ADD HL,HL     ; HL = index × 8
 31647 POP DE        ; DE = index × 2
 31648 ADD HL,DE     ; HL = index × 10 (sprite record size)
 31649 LD DE,28221   ; DE = #R28221 (character sprite table base)
 31652 ADD HL,DE     ; HL = address of sprite's 10 tile-index bytes
 31653 EX DE,HL      ; DE = sprite data source
 31654 LD B,10       ; 10 tile columns per sprite
*31656 PUSH BC       ; save column counter
 31657 PUSH DE       ; save sprite data pointer
 31658 CALL 31369    ; DrawSpriteRow: draw one tile column (8px tall)
 31661 POP DE        ; restore sprite data pointer
 31662 INC DE        ; advance to next tile index byte
@ignoreua
 31663 LD HL,31257   ; HL → draw pointer (#R31241)
 31666 INC (HL)      ; move draw pointer right by 1 character column
 31667 POP BC        ;
 31668 DJNZ 31656    ; repeat for all 10 columns
 31670 LD HL,(31257) ; HL = draw pointer after last column
 31673 DEC L         ; back to start of this character row
 31674 LD DE,23      ; advance 23 columns to next row (normal case)
 31677 LD A,L        ;
 31678 CP 224        ; $E0: check for display-file third-bank boundary
 31680 JR C,31685    ; below $E0: normal row advance (+23)
 31682 LD DE,1815    ; at/above $E0: large offset to wrap to next band
*31685 ADD HL,DE     ; move draw pointer to start of next character row
 31686 LD (31257),HL ; save updated draw pointer
 31689 RET           ;
