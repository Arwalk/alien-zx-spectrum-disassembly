; Same as RoomHandlerNop; the front-hand item row (8) dispatches here.
@label=RoomHandlerNop2
c35449 RET           ;
 35450 RET           ;

; SwapHeldItems
;
; Action on the back-item row (9): swap the actor's front and back
; hands — exchange HeldItemFront/HeldItemBack, flip the two markers
; in ItemLocations (#R29940) by +/-32, adjust the sprite position by
; the difference of the two courage bonuses, and redraw the front item's
; name.
@label=SwapHeldItems
c35451 CALL 31820    ; refresh HeldItemFront/Back for this actor
 35454 LD (IX+0),0   ; park the actor's countdown
 35458 LD DE,(31248) ; E = front item, D = back item
 35462 LD HL,29984   ; ItemCourageBonus:
