;   .......# ........ #.......  (row  2)
;   .......# .######. #.......  (row  3, oval)
;   .......# .#....#. #.......  (row  4)
;   .......# .#....#. #.......  (row  5)
;   .......# .#....#. #.......  (row  6)
;   .......# .######. #.......  (row  7)
