 45445 SUB 2         ;
 45447 ADD A,(IX+6)  ;
 45450 LD (IX+6),A   ;
 45453 POP DE        ; and the other way round:
 45454 PUSH DE       ; DE -> this actor's morale byte (+6)
 45455 INC E         ;
 45456 INC E         ;
 45457 INC E         ;
 45458 INC E         ;
 45459 INC E         ;
 45460 INC E         ;
 45461 LD A,(DE)     ; += the mate's courage - 2
 45462 ADD A,(IX+5)  ;
 45465 SUB 2         ;
 45467 LD (DE),A     ;
 45468 JR 45425      ;

