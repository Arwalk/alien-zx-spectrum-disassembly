 35617 LD A,(IX+6)   ;
 35620 ADD A,(HL)    ;
 35621 LD (IX+6),A   ;
 35624 LD C,160      ; and use the front hand (slot+160)
@label=GetItemPick_Take
*35626 LD A,(31241)  ; ItemLocations[item] = hand marker:
 35629 ADD A,C       ; the item is now carried
