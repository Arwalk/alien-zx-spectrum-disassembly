; CrewWalkA1
;
; Crew member walking sprite, phase 1 (AnimateCrewA #R34967, phases 0-1).
; XOR-blit sprite: 24px wide x 12px tall (3 bytes per row).
; Upright standing/walking pose — arms close to body, feet together.
; Left and right bytes are zero (figure fits in the 8-pixel centre column).
;
; Centre 8px:
;   ........  (row  0, blank)
;   ....#...  (row  1, $08, head top)
;   ...###..  (row  2, $1C, head)
;   ....#...  (row  3, $08, chin)
;   ..#####.  (row  4, $3E, shoulders)
;   .#.###.#  (row  5, $5D, torso)
;   ..#####.  (row  6, $3E, body)
;   ...###..  (row  7, $1C, hips)
;   ...#.#..  (row  8, $14, upper legs)
;   ...#.#..  (row  9, $14, mid legs)
;   ...#.#..  (row 10, $14, lower legs)
;   ..##.##.  (row 11, $36, feet)
@label=CrewWalkA1
b26781 DEFB 0,0,0               ; row  0: blank
 26784 DEFB 0,8,0               ; row  1: head top
 26787 DEFB 0,28,0              ; row  2: head
 26790 DEFB 0,8,0               ; row  3: chin
 26793 DEFB 0,62,0              ; row  4: shoulders
 26796 DEFB 0,93,0              ; row  5: torso
 26799 DEFB 0,62,0              ; row  6: body
 26802 DEFB 0,28,0              ; row  7: hips
 26805 DEFB 0,20,0              ; row  8: upper legs
 26808 DEFB 0,20,0              ; row  9: mid legs
 26811 DEFB 0,20,0              ; row 10: lower legs
 26814 DEFB 0,54,0              ; row 11: feet

; CrewWalkA2
;
; Crew member walking sprite, phase 2 (AnimateCrewA #R34967, phases 2-3).
; Mid-stride pose — arms pumping outward, legs spread in step.
; Row 5 has a stray pixel in the right byte (arm extension).
;
; Centre 8px (+ right byte for row 5):
;   ....#...                    (row  0, $08, head)
;   ...#.#..                    (row  1, $14, head wide)
;   ..#...#.                    (row  2, $22, arms raising)
;   ..##.##.                    (row  3, $36, upper arms)
;   .#.....#                    (row  4, $41, arms spread)
;   #.#...#. + #.......         (row  5, $A2+$80, torso+arm)
;   .#.....#                    (row  6, $41)
;   ..#...#.                    (row  7, $22, arms return)
;   ..#.#.#.                    (row  8, $2A, legs mid-stride)
;   ..#.#.#.                    (row  9, $2A)
;   .##.#.##                    (row 10, $6B, feet contact)
;   .#..#..#                    (row 11, $49, feet split)
@label=CrewWalkA2
b26817 DEFB 0,8,0               ; row  0: head
 26820 DEFB 0,20,0              ; row  1: head wide
 26823 DEFB 0,34,0              ; row  2: arms raising
 26826 DEFB 0,54,0              ; row  3: upper arms
 26829 DEFB 0,65,0              ; row  4: arms spread
 26832 DEFB 0,162,128           ; row  5: torso + arm extension
 26835 DEFB 0,65,0              ; row  6
 26838 DEFB 0,34,0              ; row  7: arms return
 26841 DEFB 0,42,0              ; row  8: legs mid-stride
 26844 DEFB 0,42,0              ; row  9
 26847 DEFB 0,107,0             ; row 10: feet contact
 26850 DEFB 0,73,0              ; row 11: feet split

; AnimCrewAFrames
;
; 4 × 16-bit pointers to crew animation frame-A sprite bitmaps.
; Indexed by frame phase (0-3); phases 0-1 share one bitmap, 2-3 share
; another, producing a two-frame walk cycle at rate 10 (10 frames/step).
; Used by AnimateCrewA (#R34967) to XOR-blit crew sprites onto the screen.
;
@label=CrewWalkAnimA
w26853 DEFW 26781,26781,26817,26817

; AnimCrewBFrames
;
; 4 × 16-bit pointers to room indicator cursor bitmaps (faster channel,
; rate 5). Used by AnimateCrewB (#R35016) to XOR-blit the animated room
; cursor that highlights the current room on the corridor map.
;
@label=CrewWalkAnimB
w26861 DEFW 26637,26673,26709,26745

