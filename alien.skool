; Game state scratchpad RAM
;
; 110 bytes of mixed 1- and 2-byte variables stamped inline within the
; code region. The initial byte values come from the tape image, but every
; byte is treated as RAM by the running game: written by the main-loop
; subsystems and read back on subsequent frames. Despite living inside the
; code segment, none of these bytes are executed.
;
; Key variables:
;   #R33682 AlienFlags        bit-packed input (R,L,D,U,Fire)
;   #R33683 CorridorCursor    current corridor index (0..18)
;   #R33688 SpriteDestAddr    sprite blitter screen pointer
;   #R33690 FrameCounterB     free-running 50Hz counter
;   #R33699 SoundRequest      one-shot sound trigger
;   #R33700 CrewIndex         current crew member (0..6)
;   #R33701 Auto_83A5         pointer to current crew record
;   #R33703 AlienTargetID     crew ID being targeted (255=none)
;   #R33704 AlienActiveFlag   alien is loose flag
;   #R33706 AlienEventTimer   countdown to next alien event
;   #R33731 SoundReqFlag      pending sound parameters
;   #R33734 SprScreenAddrA    crew sprite A destination
;   #R33736 SprScreenAddrB    crew sprite B destination
;   #R33737 MusicActiveFlag   music phrase is playing
;   #R33739 AnimFrameCnt      crew animation tick
;
; The remaining Auto_* labels are confirmed RAM cells but their exact
; semantics are not yet documented; the labels exist so cross-references
; from the code rename consistently.
@label=AlienFlags
b33682 DEFB 0                ; Keyboard/joystick scan bitmask (bit 0=R, 1=L, 2=D, 3=U, 4=Fire)
@label=CorridorCursor
 33683 DEFB 17               ; Currently selected corridor / cursor position (0-18)
@label=Auto_8394
 33684 DEFB 0,0              ;
@label=SprDestA
 33686 DEFB 0                ;
@label=Auto_8397
 33687 DEFB 64               ;
@label=SpriteDestAddr
 33688 DEFW 16384            ; Screen destination pointer used by sprite blitter
@label=FrameCounterB
 33690 DEFB 25               ; Free-running frame counter (low byte, ~50 Hz)
@label=Auto_839B
 33691 DEFB 25               ;
@label=Auto_839C
 33692 DEFB 255,255,255      ; Initialised to $FFFFFF
@label=Auto_839F
 33695 DEFB 255              ; Initialised to $FF (scratch byte)
@label=NearestCrewA
 33696 DEFB 255              ; nearest crew ID, slot A (255 = none)
@label=NearestCrewB
 33697 DEFB 255              ; nearest crew ID, slot B (255 = none)
@label=Auto_83A2
 33698 DEFB 0                ;
@label=SoundRequest
 33699 DEFB 0                ; One-shot sound request (255 = idle)
@label=CrewIndex
 33700 DEFB 1                ; Current crew member index (0-6)
@label=Auto_83A5
 33701 DEFB 134,115          ; 16-bit pointer to current crew record
@label=AlienTargetID
 33703 DEFB 9                ; In the Long Game this is the **Android** slot index (1..7): the dormant traitor crew member that UpdateAlien (#R40826) activates on first encounter with the alien (the first frame AlienActiveFlag is set and the slot still has its template +0=+7=0). Once activated, the Android enters action state 7 and wounds nearby crew via CrewAction7_Handler (#R40757). Values >= 8 (e.g. ShortGameInit's hard-wired 9) disable the mechanic — TriggerAlienEvent (#R41264) treats them as "no valid target".
@label=AlienActiveFlag
 33704 DEFB 0                ; Non-zero when the alien is loose in corridors
@label=Auto_83A9
 33705 DEFB 0                ;
@label=AlienEventTimer
 33706 DEFB 6                ; Frames until next alien event (255 = disabled)
@label=Auto_83AB
 33707 DEFB 255              ; Secondary alien-event counter
@label=Auto_83AC
 33708 DEFB 0                ;
@label=Auto_83AD
 33709 DEFB 0                ;
@label=Auto_83AE
 33710 DEFB 224,90           ; 16-bit scratch (room/sprite ptr)
@label=Auto_83B0
 33712 DEFB 255              ;
@label=Auto_83B1
 33713 DEFB 255              ;
@label=Auto_83B2
