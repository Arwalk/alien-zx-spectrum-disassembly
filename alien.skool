 44667 JR Z,44683    ;
 44669 LD A,(IX+7)   ; alive?
 44672 AND A         ;
 44673 JR NZ,44683   ;
 44675 LD L,(IX+4)   ; yes: total += 2 x strength
 44678 SLA L         ;
 44680 EX AF,AF'     ;
 44681 ADD A,L       ;
 44682 EX AF,AF'     ;
@label=Rating_SkipCrew
