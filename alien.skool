@ignoreua
; Per-screen RAM state
;
; First 26 bytes of the runtime RAM map. The remaining per-game-state
; scratchpad variables live further down in the code segment near
; #R33682 — see that block for the rest of the RAM map.
; .
; Variables:
;   #R31241 DrawSlotIndex    actor slot (0-7) currently drawn/processed
;   #R31242 CurrentRoom      room of that actor; "the viewed room"
;   #R31243 RoomTypeByte     view type: deck 0-2 of ShipMapData, 3 =
;                            Narcissus, 4 = alien-encounter screen
;   #R31244 RoomAttrStep     word: attr-cursor stride for door drawing
;   #R31246 RoomCellStep     word: cell-grid stride for door drawing
;   #R31248 HeldItemFront    item id in the actor's front hand (255 = none)
;   #R31249 HeldItemBack     item id in the actor's back hand (255 = none)
;   #R31250 RoomMateA        first other actor in the room (255 = none)
;   #R31251 RoomMateB        second other actor in the room (255 = none)
;   #R31252 RoomModeByte     current room mode (drives RoomDispatchTable)
;   #R31253 ShipSystemFlags  bit 0 destruct armed; bits 1/2 airlocks
;                            blown; bits 3-5 engine state
;   #R31255 RoomAttrCursor   word: attribute-file cursor (room drawing)
;   #R31257 DrawScreenPtr    word: THE display-file draw pointer (~120 refs)
;   #R31259 RoomCellCursor   word: 20-wide room-cell-grid cursor
;   #R31261 CorridorTilePtr  pointer into corridor tile source
;   #R31263 CrewAnimFlags    XOR-blit toggle for crew sprite set A
;   #R31264 AnimFramePhase   XOR-blit toggle for set B / cursor
;   #R31265 ScriptPointer    ROM-traversal AI script pointer
; .
; The bytes from #R31267 onwards hold executable code (the view
; background renderer, invoked via CALL #R31267 from #R31459 and
; #R32719), preserved as DEFB data only because the section was
; originally classified as RAM. Decoded, DrawRoomBackground reads:
; fill the 20x19 attribute window with 4 (green ink); A = RoomTypeByte;
; if A = 3 JP #R33644 (NarcissusBackground); if A = 4 JP #R39687
; (ResetAlienXAnim, the encounter screen); else HL = ShipMapData +
; 380*A (that deck's 20x19 tile map) and fall into
; DrawRoomBackground_0 (#R31312), which renders the 20x19 tile map at
; HL onto the display via DrawSpriteRow — also called directly by
; NarcissusBackground with the RLE-expanded grid buffer.
@label=DrawSlotIndex
b31241 DEFB 5
@label=CurrentRoom
 31242 DEFB 6              ; room of the actor being processed (record
                           ; byte +1, cached by SelectSlotByDrawIdx #R31721);
                           ; doubles as "the viewed room" in encounter checks
@label=RoomTypeByte
 31243 DEFB 1
@label=RoomAttrStep
 31244 DEFB 0,0            ; word: attribute-cursor stride for door drawing
@label=RoomCellStep
 31246 DEFB 0,0            ; word: room-cell-grid stride for door drawing
@label=HeldItemFront
 31248 DEFB 255            ; corridor-strip cell (0-21) of the actor's id+160
                           ; marker; 12 = the alien's lair cell (see #R31823)
@label=HeldItemBack
 31249 DEFB 255            ; corridor-strip cell of the actor's id+128 marker
@label=RoomMateA
 31250 DEFB 255            ; slots of up to two OTHER actors in the current
@label=RoomMateB
 31251 DEFB 255            ; room (255 = none) - printed as "Also here" /
                           ; "Also Bodies of"; found by #R36187
@label=RoomModeByte
 31252 DEFB 0
@label=ShipSystemFlags
 31253 DEFB 0              ; bit 0 = self-destruct armed; bits 1/2 =
                           ; Airlock #1/#2 blown open (set by BlowLock,
                           ; cleared by SealLock); bits 3-5 = Engine
                           ; #1/#2/#3 state (ship-systems tick at #R39041)
 31254 DEFB 0
@label=RoomAttrCursor
 31255 DEFB 0,88           ; word: attribute-file cursor for room/door
                           ; drawing (initially the attr-file base)
@label=DrawScreenPtr
 31257 DEFB 0,64           ; word: THE main display-file draw pointer used by
                           ; every blit routine (initially the display file)
@label=RoomCellCursor
 31259 DEFB 0,96           ; word: cursor into the 20-cell-wide room grid,
                           ; walked in step with RoomAttrCursor
@label=CorridorTilePtr
 31261 DEFB 0,0
@label=CrewAnimFlags
 31263 DEFB 128
@label=AnimFramePhase
 31264 DEFB 128
@label=ScriptPointer
 31265 DEFB 0,0
@label=DrawRoomBackground
 31267 DEFB 17,12,0,33,0,88,14,19
 31275 DEFB 6,20,54,4,35,16,251,25
 31283 DEFB 13,32,245,17,124,1,33,0
 31291 DEFB 96,58,11,122,254,3,202,108
 31299 DEFB 131,254,4,202,7,155,167,40
 31307 DEFB 4,25,61,32,252
@label=DrawRoomBackground_0
*31312 DEFB 34,27,122,33,0,64,34,25
 31320 DEFB 122,14,19,6,20,197,237,91
 31328 DEFB 27,122,205,137,122,33,25,122
 31336 DEFB 52,42,27,122,35,34,27,122
 31344 DEFB 193,16,234,17,12,0,42,25
 31352 DEFB 122,125,254,224,56,3,17,12
 31360 DEFB 7,25,34,25,122,13,32,211
 31368 DEFB 201

; DrawSpriteRow
@ignoreua
;
; Draws one 8-pixel-tall column of a sprite tile onto the screen. Reads a
; tile index byte from (DE), multiplies by 8 to get an offset into the
; 8-byte-per-row character bitmap table at $6935 (#R26869 + index×8), then
; writes all 8 bytes vertically downward from the current draw pointer at
; #R31257 (INC H steps through ZX Spectrum display rows within the same
; character cell column).
; .
; Input:  (DE) = tile/character index; (#R31257) = screen destination address
; Output: screen updated; DE advanced; H incremented 8 times
; .
; Used by the routines at #R31634, #R31690, #R32143, #R32385, #R32536,
; #R37221, #R39572, #R42581 and #R44509.
@label=DrawSpriteRow
c31369 LD A,(DE)     ; read tile index from source pointer
; This entry point is used by the routines at #R32143, #R32536, #R32670,
; #R33479, #R37322 and #R40149.
@label=DrawTileA
*31370 LD L,A        ; L = tile index
 31371 LD H,0        ;
 31373 ADD HL,HL     ; HL = index × 2
 31374 ADD HL,HL     ; HL = index × 4
 31375 ADD HL,HL     ; HL = index × 8
@ignoreua
 31376 LD BC,26869   ; BC = $6935 (character bitmap base)
 31379 ADD HL,BC     ; HL = address of first row of tile bitmap
 31380 EX DE,HL      ; DE = bitmap source; HL = old DE (tile index ptr)
@ignoreua
 31381 LD HL,(31257) ; HL = screen destination (DrawScreenPtr)
 31384 LD B,8        ; 8 pixel rows per character
@label=DrawTileA_RowLoop
*31386 LD A,(DE)     ; read bitmap byte for this pixel row
 31387 LD (HL),A     ; write to display file
 31388 INC H         ; next display row (INC H steps within 8-row band)
 31389 INC DE        ; next bitmap byte
 31390 DJNZ 31386    ; repeat for all 8 rows
 31392 RET           ;

; NextScanLine
;
; Used by the routine at #R35065.
@label=NextScanLine
c31393 LD A,H        ;
 31394 AND 7         ;
 31396 CP 7          ;
 31398 JR Z,31402    ;
 31400 INC H         ;
 31401 RET           ;
@label=NextScanLine_RowEnd
*31402 LD A,L        ;
 31403 CP 224        ;
 31405 JR NC,31412   ;
 31407 LD DE,63776   ;
 31410 ADD HL,DE     ;
 31411 RET           ;
@label=NextScanLine_NextThird
*31412 LD DE,32      ;
 31415 ADD HL,DE     ;
 31416 RET           ;

; InitGameView
;
; Initialises the corridor view for the current room. Clears the room mode
; byte, freezes both crew animation channels (sets bit 7 of #R31263/#R31264),
; resets the corridor cursor to segment 8, copies the 19-byte corridor
; position template from #R30197 to #R29630, then draws the room's attribute
; colours and initial crew sprites.
; .
; Used by the routines at #R35163, #R35338, #R35440, #R36457, #R37584,
; #R39400, #R40941, #R45676 and #R45732.
@label=InitGameView
c31417 XOR A         ; A = 0
@ignoreua
 31418 LD (31252),A  ; clear room mode byte at #R31252
@ignoreua
 31421 LD HL,31263   ; HL = #R31263 (crew animation flags)
 31424 SET 7,(HL)    ; freeze animation channel A (bit 7 = freeze)
 31426 INC HL        ;
 31427 SET 7,(HL)    ; freeze animation channel B
 31429 LD A,128      ; $80
@nowarn=39741
@ssub=LD (AlienXPhase),A
 31431 LD (39741),A  ; set alien pixel X sentinel (#R39741)
@nowarn=39753
@ssub=LD (JonesPhase),A
 31434 LD (39753),A  ; set alien pixel Y sentinel (#R39753)
 31437 LD A,8        ; segment 8 = centre of 19-segment corridor
@nowarn=33683
@ssub=LD (CorridorCursor),A
@ignoreua
 31439 LD (33683),A  ; store as current corridor cursor (#R33683)
 31442 LD A,32       ; space char
 31444 CALL 33479    ; draw blank room border / clear game window
@ignoreua
 31447 LD A,(31243)  ; read room-type byte (#R31243)
 31450 CP 4          ; room type 4 = special (engine room)
 31452 JR NZ,31459   ;
 31454 LD A,1        ; remap type 4 → type 1
 31456 LD (31243),A  ;
@label=InitView_DrawBg
*31459 CALL 31267    ; draw room background (walls, doors, floor tiles)
 31462 LD DE,29630   ; DE = #R29630 (corridor position table, 19 bytes)
 31465 LD HL,30197   ; HL = #R30197 (corridor position templates)
 31468 LD BC,19      ; copy 19 entries
 31471 LDIR          ; initialise position table from template
@ignoreua
 31473 LD HL,22550   ; HL = $5816 (attribute row for top of game window)
 31476 LD A,7        ; white ink on black paper
 31478 LD C,1        ; 1 column wide
 31480 CALL 31612    ; paint attribute column
 31483 LD A,40       ;
 31485 LD C,8        ;
 31487 CALL 31612    ;
 31490 LD A,32       ;
 31492 LD C,2        ;
 31494 CALL 31612    ;
 31497 LD A,23       ;
 31499 LD C,5        ;
 31501 CALL 31612    ;
 31504 XOR A         ;
 31505 LD C,3        ;
 31507 CALL 31612    ;
 31510 LD C,1        ;
 31512 LD A,7        ;
 31514 CALL 31612    ;
 31517 LD HL,16406   ;
 31520 LD (31257),HL ;
 31523 LD A,82       ;
 31525 CALL 31634    ;
 31528 LD HL,30197   ;
 31531 LD (31261),HL ;
 31534 CALL 31626    ;
 31537 LD B,7        ;
@label=InitView_BlankLoop
*31539 PUSH BC       ;
 31540 LD A,92       ;
 31542 CALL 31634    ;
 31545 POP BC        ;
 31546 DJNZ 31539    ;
 31548 LD HL,16470   ;
 31551 LD (31257),HL ;
 31554 LD A,1        ;
 31556 EX AF,AF'     ;
 31557 LD A,7        ;
; This entry point is used by the routine at #R31577.
; Orders-screen crew-name loop head: A' holds the next crew id,
; A the remaining row count (7 names on menu rows 2-8).
@label=OrdersCrewNameLoop
*31559 EX AF,AF'     ; A = crew id to print
 31560 DEFB 42,25     ; first 2 bytes of "LD HL,(draw pointer)": the
                      ; operand-high byte is the LD A,D at #R31562, so
                      ; falling through loads HL and continues after it

; Orders-screen crew-name row
;
; Body of the loop above (never entered at #R31562 itself — the LD A,D
; opcode is just the operand high byte of the overlapping instruction):
; prints crew name A via PrintName (#R31690), then steps the menu draw
; pointer (#R31257) one character row down: +32 within a display-file
; third, or +1824 (via the fall-through block below) when crossing a
; third boundary (L >= $E0).
@label=OrdersCrewNameRow
c31562 LD A,D        ; (dead when fallen into: overlap operand)
 31563 PUSH AF       ; save crew id
 31564 PUSH HL       ; save draw pointer
 31565 CALL 31690    ; PrintName: draw crew name A on this row
 31568 POP HL        ;
 31569 LD DE,32      ; normal stride: next char row in same third
 31572 LD A,L        ;
 31573 CP 224        ; crossing into the next display third?
 31575 JR C,31580    ; no: advance by 32

; Orders-menu build, lower part
;
; Tail of the orders-screen build started in InitGameView (#R31417).
; First the third-boundary case of the crew-name row stride (+1824),
; then the shared loop tail: store the draw pointer, advance A' to the
; next crew id and loop until all 7 names are printed. After the loop,
; draws menu rows 9-18 straight from OrdersMenuLowerHalf (#R30205)
; (" Indicate "/" Location ", " Display  "/"  Level   ", the three
; deck rows, blanks), re-highlights the cursor row and mirrors its
; cell value (#R34882), and redraws the oxygen clock on row 19
; (#R39572).
@label=OrdersMenuNextRow
c31577 LD DE,1824    ; big stride: next char row across a third boundary
; This entry point is used by the routine at #R31562.
@label=OrdersMenuAdvance
*31580 ADD HL,DE     ;
 31581 LD (31257),HL ; store draw pointer for the next row
 31584 POP AF        ; A = crew id just printed
 31585 INC A         ;
 31586 EX AF,AF'     ; A' = next crew id, A = row counter
 31587 DEC A         ;
 31588 JR NZ,31559   ; loop for all 7 crew rows
 31590 LD HL,30205   ; then draw rows 9-18 from OrdersMenuLowerHalf
 31593 LD (31261),HL ;
 31596 LD B,10       ;
@label=OrdersMenuLowerLoop
*31598 PUSH BC       ;
 31599 CALL 31626    ; draw next menu row from the template
 31602 POP BC        ;
 31603 DJNZ 31598    ;
 31605 CALL 34882    ; highlight the cursor row / mirror its value
 31608 CALL 39572    ; redraw the oxygen clock (row 19)
 31611 RET           ;

; FillAttrColumn
;
; Used by the routines at #R31417, #R32816, #R34859, #R34882, #R35228 and
; #R35638.
; .
; Paint a 10-cell-wide attribute block — C rows of
; attribute A starting at HL (stride 22 = 32-10 to the next row).
; Used to colour the menu rows.
@label=FillAttrColumn
c31612 LD DE,22      ; row stride remainder (32 - 10)
@label=FillAttrCol_RowLoop
*31615 LD B,10       ; 10 attribute cells per row
@label=FillAttrCol_CellLoop
*31617 LD (HL),A     ;
 31618 INC HL        ;
 31619 DJNZ 31617    ;
 31621 ADD HL,DE     ; next row
 31622 DEC C         ;
 31623 JR NZ,31615   ;
 31625 RET           ;

; DrawNextCorridorTile
;
; Reads the next tile index from the corridor position pointer at #R31261, draws
; it by falling through into #R31634 (DrawSprite), and advances the pointer.
; .
; Used by the routines at #R31417, #R31577, #R32816, #R35290 and #R35638.
@label=DrawNextCorridorTile
@ignoreua
c31626 LD HL,(31261) ; HL = corridor tile-source pointer (#R31261)
 31629 LD A,(HL)     ; A = next tile index
 31630 INC HL        ; advance pointer
 31631 LD (31261),HL ; save updated pointer; fall through to DrawSprite

; DrawSprite
;
; Renders a 10-character text label at the current draw position (#R31257).
; The "sprite" data is the 10-byte text entry at #R28221 + A×10 (see
; RoomNameTable / UIStringTable); each byte is used as a tile index into
; #R26869, which is laid out so that index N == ASCII N produces the glyph
; for that character. After drawing 10 columns, advances #R31257 to the next
; character row accounting for the ZX Spectrum display-file row wrapping.
; .
; Input:  A = text/label index (255 → use blank label, entry 92)
;         (#R31257) = screen destination address
; .
; Used by the routines at #R31417, #R32143, #R32816, #R33610, #R35290,
; #R35451, #R35814, #R36793, #R36859, #R37221, #R37493, #R37520, #R37944,
; #R38454, #R38483, #R38588, #R38617, #R38645, #R38674, #R39077, #R40941,
; #R44938 and #R45760.
@label=DrawSprite
c31634 CP 255        ; sprite index 255 = invalid/absent
 31636 JR NZ,31640   ; valid index: draw it
 31638 LD A,92       ; substitute blank sprite (index 92)
@label=DrawSprite_Lookup
*31640 LD L,A        ; L = sprite index
 31641 LD H,0        ;
 31643 ADD HL,HL     ; HL = index × 2
 31644 PUSH HL       ; save HL = index × 2
 31645 ADD HL,HL     ; HL = index × 4
 31646 ADD HL,HL     ; HL = index × 8
 31647 POP DE        ; DE = index × 2
 31648 ADD HL,DE     ; HL = index × 10 (label record size)
 31649 LD DE,28221   ; DE = #R28221 (RoomNameTable base)
 31652 ADD HL,DE     ; HL = address of the 10-byte text entry
 31653 EX DE,HL      ; DE = source pointer (10 ASCII tile-indices)
 31654 LD B,10       ; 10 character columns per label
@label=DrawSprite_ColLoop
*31656 PUSH BC       ; save column counter
 31657 PUSH DE       ; save sprite data pointer
 31658 CALL 31369    ; DrawSpriteRow: draw one tile column (8px tall)
 31661 POP DE        ; restore sprite data pointer
 31662 INC DE        ; advance to next tile index byte
@ignoreua
 31663 LD HL,31257   ; HL → draw pointer (#R31257)
 31666 INC (HL)      ; move draw pointer right by 1 character column
 31667 POP BC        ;
 31668 DJNZ 31656    ; repeat for all 10 columns
 31670 LD HL,(31257) ; HL = draw pointer after last column
 31673 DEC L         ; back to start of this character row
 31674 LD DE,23      ; advance 23 columns to next row (normal case)
 31677 LD A,L        ;
 31678 CP 224        ; $E0: check for display-file third-bank boundary
 31680 JR C,31685    ; below $E0: normal row advance (+23)
 31682 LD DE,1815    ; at/above $E0: large offset to wrap to next band
@label=DrawSprite_Advance
*31685 ADD HL,DE     ; move draw pointer to start of next character row
 31686 LD (31257),HL ; save updated draw pointer
 31689 RET           ;

; PrintName
;
; Prints actor name A (0 = ALIEN, 1-7 = crew) by skipping A
; 255-terminated names in CrewNameTable and drawing the next one one
; glyph at a time. The second entry point three bytes in is also
; entered directly with DE pre-set to walk other string lists.
; .
; Used by the routines at #R31562, #R32385, #R32536, #R32816, #R37221,
; #R42821, #R44354, #R44428 and #R45692.
@label=PrintName
c31690 LD DE,29516   ; CrewNameTable
; This entry point is used by the routines at #R32385 and #R42821.
@label=PrintNameDE
*31693 AND A         ; name 0: draw from the list head
 31694 JR Z,31705    ;
 31696 LD B,A        ; skip A 255-terminated names
@label=PrintName_SkipLoop
*31697 LD A,(DE)     ;
 31698 INC DE        ;
 31699 CP 255        ;
 31701 JR NZ,31697   ;
 31703 DJNZ 31697    ;
@label=PrintName_GlyphLoop
*31705 PUSH DE       ; draw one glyph via DrawSpriteRow
 31706 CALL 31369    ;
 31709 POP DE        ;
 31710 INC DE        ;
 31711 LD HL,31257   ; draw pointer right one column
 31714 INC (HL)      ;
 31715 LD A,(DE)     ; until the 255 terminator
 31716 CP 255        ;
 31718 JR NZ,31705   ;
 31720 RET           ;

; SelectSlotByDrawIdx
@ignoreua
;
; Re-points IX at the 8-byte record indexed by (#R31241) and loads the
; slot's identity into (#R31242) for downstream lookups. Critically, if
; the slot wears the HostMarker (byte+1 == $FF), the routine returns
; immediately without writing #R31242 / #R31243 — every per-frame caller
; that walks into this entry point therefore skips that slot during
; routine corridor processing. In the Long Game this means the
; chestburster host is excluded from normal crew handling; in the
; Short Game the same exclusion applies to all four pre-stamped slots.
; .
; This entry point is used by the routines at #R32719 and #R35163.
@label=SelectSlotByDrawIdx
c31721 LD A,(31241)  ; A = current draw index (slot 0..7)
 31724 ADD A,A       ;
 31725 ADD A,A       ;
 31726 ADD A,A       ; A *= 8 (record stride)
 31727 LD E,A        ;
 31728 LD D,0        ;
@ignoreua
 31730 LD IX,29566   ; IX = $737E (slot table base)
 31734 ADD IX,DE     ; IX = &slot[index]
 31736 LD A,(IX+1)   ; A = slot.byte+1
@label=SelectSlot_HostCheck
 31739 CP 255        ; HostMarker?
 31741 RET Z         ; yes → bail out (slot is not a normal crew member)
 31742 LD (31242),A  ; cache slot identity for the rest of the room handler
 31745 AND 63        ; mask off direction bit → raw crew ID (0..63)
 31747 LD E,A        ;
 31748 LD D,0        ;
 31750 LD HL,29905   ; RoomTypeTable[crew's room]
 31753 ADD HL,DE     ;
 31754 LD A,(HL)     ;
 31755 LD (31243),A  ; RoomTypeByte for this crew
 31758 RET           ;

; BuildExitList
;
; Builds the current room's door-exit list (CorridorPosTable + 2):
; walks the room's
; 5 direction slots in RoomAdjCorridors and stores each destination
; that differs from the current room (up to 5 entries). The room view
; draws one door per entry.
@label=BuildExitList
c31759 LD A,(31242)  ; A = current room
 31762 LD L,A        ;
 31763 LD H,0        ;
 31765 PUSH HL       ;
 31766 ADD HL,HL     ;
 31767 ADD HL,HL     ;
 31768 POP DE        ;
 31769 ADD HL,DE     ;
 31770 LD DE,29171   ;
 31773 ADD HL,DE     ;
 31774 LD DE,29632   ;
 31777 LD B,5        ;
@label=BuildExit_SlotLoop
*31779 LD C,(HL)     ;
 31780 CP C          ;
 31781 JR Z,31792    ;
 31783 LD A,(31242)  ;
 31786 CP C          ;
 31787 JR Z,31792    ;
 31789 LD A,C        ;
 31790 LD (DE),A     ;
 31791 INC DE        ;
@label=BuildExit_NextSlot
*31792 INC HL        ;
 31793 DJNZ 31779    ;
 31795 RET           ;

; BuildRoomItemList
;
; List the item ids lying in the current room —
; scan ItemLocations (#R29940) from the top down for entries equal to
; the room number, appending each match to RoomItemList (#R29962).
@label=BuildRoomItemList
c31796 LD A,(31242)  ; C = current room
 31799 LD C,A        ;
 31800 LD HL,29961   ; scan ItemLocations from item 21 down
 31803 LD DE,29962   ; DE -> RoomItemList write pointer
 31806 LD B,22       ;
@label=BuildRoomItems_Loop
*31808 LD A,(HL)     ; item's location
 31809 CP C          ; lying in this room?
 31810 JR NZ,31816   ;
 31812 LD A,B        ; yes: append its id (= B-1) to the list
 31813 DEC A         ;
 31814 LD (DE),A     ;
 31815 INC DE        ;
@label=BuildRoomItems_Next
*31816 DEC HL        ;
 31817 DJNZ 31808    ;
 31819 RET           ;

; RefreshHeldItems
;
; Used by the routines at #R32719, #R35451, #R35814 and #R44924.
; .
; Find what the current actor (#R31241) holds.
@label=RefreshHeldItems
c31820 LD A,(31241)  ;

; FindHeldItems
;
; Finds what actor A is carrying: scans ItemLocations (#R29940) for
; the slot+160 marker (front hand) into HeldItemFront (#R31248) and
; the slot+128 marker (back hand) into HeldItemBack (#R31249). The
; item id is the table position where the marker sits.
; .
; Used by the routines at #R37584, #R37992 and #R40941.
@label=FindHeldItems
c31823 ADD A,128     ; C = slot + 128, E = slot + 160
 31825 LD C,A        ;
 31826 ADD A,32      ;
 31828 LD E,A        ;
 31829 LD HL,29961   ; scan ItemLocations from item 21 down
 31832 LD B,22       ;
@label=FindHeld_Loop
*31834 LD A,(HL)     ;
 31835 CP C          ; back-hand marker?
 31836 JR NZ,31845   ;
 31838 LD A,B        ; yes: HeldItemBack = item id (B-1)
 31839 DEC A         ;
 31840 LD (31249),A  ;
 31843 JR 31853      ;
@label=FindHeld_FrontCheck
*31845 CP E          ; front-hand marker?
 31846 JR NZ,31853   ;
 31848 LD A,B        ; yes: HeldItemFront = item id
 31849 DEC A         ;
 31850 LD (31248),A  ;
@label=FindHeld_Next
*31853 DEC HL        ;
 31854 DJNZ 31834    ;
 31856 RET           ;
; This entry point is used by the routines at #R31915, #R35451, #R35638,
; #R35814 and #R37944.

; ItemIdToString
;
; Maps an item id (in A) to its name's string index:
; ids 0-2 -> 35 Elctrc Prd, 3-5 -> 36 Incineratr, 6-7 -> 37 Tracker,
; 8-11 -> 38 Fire Extng, 12 -> 39 Harpn Gun, 13-15 -> 40 Laser Pist,
; 16 -> 41 Net, 17 -> 42 Cat Box, 18-19 -> 43 Spanner; ids 20/21
; (Jones captured) -> strings 68 "Cat in Net" / 69 "Cat in Box".
@label=ItemIdToString
c31857 LD E,35       ; E = first item string ("Elctrc Prd")
 31859 CP 3          ; ids 0-2: prods
 31861 JR C,31899    ;
 31863 INC E         ; 3-5: incinerators
 31864 CP 6          ;
 31866 JR C,31899    ;
 31868 INC E         ; 6-7: trackers
 31869 CP 8          ;
 31871 JR C,31899    ;
 31873 INC E         ; 8-11: extinguishers
 31874 CP 12         ;
 31876 JR C,31899    ;
 31878 INC E         ; 12: the harpoon gun
 31879 CP 12         ;
 31881 JR Z,31899    ;
 31883 INC E         ; 13-15: laser pistols
 31884 CP 16         ;
 31886 JR C,31899    ;
 31888 INC E         ; 16: the net
 31889 CP 16         ;
 31891 JR Z,31899    ;
 31893 INC E         ; 17: the cat box
 31894 CP 17         ;
 31896 JR Z,31899    ;
 31898 INC E         ; 18-19: spanners
@label=ItemIdStr_Specials
*31899 CP 20         ; ids 20/21 (the caught cat)
 31901 JR NZ,31907   ; override the chain:
 31903 LD E,68       ; 68 "Cat in Net"
 31905 JR 31913      ;
@label=ItemIdStr_CatBox
*31907 CP 21         ;
 31909 JR NZ,31913   ;
 31911 LD E,69       ; 69 "Cat in Box"
@label=ItemIdStr_Done
*31913 LD A,E        ;
 31914 RET           ;

; BuildItemMenu
;
; Fills the action menu's " use:" rows (strip cells 8-11) for the
; current actor: row 8 = name of the front-hand item, row 9 = name of
; the back-hand item, row 10 = "Get Item" (47) when the room has items
; lying about and the back hand is free, row 11 = "Leave Item" (48)
; when the front hand is loaded.
@label=BuildItemMenu
c31915 LD C,255      ; C = "empty" sentinel
 31917 LD HL,29638   ; menu strip cell 8
 31920 LD A,(31248)  ; front-hand item
 31923 CP C          ;
 31924 CALL NZ,31857 ; -> item name string
 31927 LD (HL),A     ; row 8
 31928 INC HL        ;
 31929 LD A,(31249)  ; back-hand item
 31932 CP C          ;
 31933 CALL NZ,31857 ;
 31936 LD (HL),A     ; row 9
 31937 INC HL        ;
 31938 LD DE,29962   ; any items lying in this room?
 31941 LD A,(DE)     ;
 31942 CP C          ;
 31943 JR Z,31954    ;
 31945 LD A,(31249)  ; and the back hand free?
 31948 CP C          ;
 31949 JR NZ,31954   ;
 31951 LD A,47       ; yes: row 10 = "Get Item"
 31953 LD (HL),A     ;
@label=BuildItemMenu_Hands
*31954 INC HL        ;
 31955 LD A,(31248)  ; front hand loaded?
 31958 CP C          ;
 31959 RET Z         ;
 31960 LD A,48       ; yes: row 11 = "Leave Item"
 31962 LD (HL),A     ;
 31963 RET           ;

; DrawRoomSpecials
;
; Fill the strip cells for the viewed room's special occupants and
; fixtures: the hostile Android and the alien (ATTACK on the Special
; slot), Jones ("Get Jones " on row 14), then the room's fixture
; label on cells 15/16 (destruct lever, airlock doors, hypersleep
; pod, engine fire, launch console).
@label=DrawRoomSpecials
@nowarn=33703
@ssub=LD A,(AlienTargetID)
c31964 LD A,(33703)  ; is there an Android this game,
 31967 CP 8          ;
 31969 JR NC,31988   ;
@nowarn=33704
@ssub=LD A,(AlienActiveFlag)
 31971 LD A,(33704)  ; already hostile,
 31974 AND A         ;
 31975 JR Z,31988    ;
 31977 LD HL,(33701) ; and in the viewed room?
 31980 INC HL        ;
 31981 LD A,(31242)  ;
 31984 CP (HL)       ;
 31985 CALL Z,32134  ; yes: offer ATTACK
@label=DrawSpec_RoomChecks
*31988 LD A,(31242)  ; Jones in the viewed room?
@nowarn=33706
@ssub=LD HL,JonesRoom
 31991 LD HL,33706   ;
 31994 CP (HL)       ;
 31995 CALL Z,32109  ; yes: cat + "Get Jones " row
 31998 LD HL,29567   ; the alien in the viewed room?
 32001 CP (HL)       ;
 32002 CALL Z,32121  ; yes: offer ATTACK
 32005 LD HL,31253   ; HL -> ShipSystemFlags,
 32008 LD DE,29645   ; DE -> strip cells 15/16: which
 32011 CP 6          ; fixture lives in this room?
 32013 JR Z,32051    ; CommdCentr: the destruct lever
 32015 CP 13         ; Corridor#6: the airlock doors
 32017 JR Z,32089    ;
 32019 CP 15         ; Cryo Vault: the hypersleep pod
 32021 JR Z,32064    ;
 32023 CP 17         ; engine rooms: a fire,
 32025 JR Z,32071    ; if one is burning
 32027 CP 18         ;
 32029 JR Z,32075    ;
 32031 CP 19         ;
 32033 JR Z,32079    ;
 32035 CP 34         ; Narcissus: the launch console
 32037 JR Z,32040    ;
 32039 RET           ; other rooms: no fixture
@label=DrawSpec_LaunchConsole
*32040 BIT 6,(HL)    ; (flag bit 6 would hide the console;
 32042 RET NZ        ; nothing sets it in this build)
 32043 LD A,78       ; cells 15/16 = launch-console
 32045 LD (DE),A     ; label (strings 78/81)
 32046 LD A,81       ;
 32048 INC DE        ;
 32049 LD (DE),A     ;
 32050 RET           ;
@label=DrawSpec_DestructLever
*32051 LD A,70       ; lever off (70/71), or
 32053 BIT 0,(HL)    ; armed (72/73) when the
 32055 JR Z,32059    ; destruct bit is set
 32057 LD A,72       ;
@label=DrawSpec_LeverStore
*32059 LD (DE),A     ; write the two-row label
 32060 INC DE        ; into cells 15/16
 32061 INC A         ;
 32062 LD (DE),A     ;
 32063 RET           ;
@label=DrawSpec_HyperPod
*32064 LD A,74       ; hypersleep pod label (74/75)
 32066 LD (DE),A     ; into cells 15/16
 32067 INC DE        ;
 32068 INC A         ;
 32069 LD (DE),A     ;
 32070 RET           ;
@label=DrawSpec_Engine1Fire
*32071 BIT 3,(HL)    ; Engine #1 burning?
 32073 JR 32081      ;
@label=DrawSpec_Engine2Fire
*32075 BIT 4,(HL)    ; Engine #2 burning?
 32077 JR 32081      ;
@label=DrawSpec_Engine3Fire
*32079 BIT 5,(HL)    ; Engine #3 burning?
@label=DrawSpec_FireCells
*32081 RET Z         ; no fire: no label
 32082 LD A,76       ; fire label (76/77)
 32084 LD (DE),A     ; into cells 15/16
 32085 INC A         ;
 32086 INC DE        ;
 32087 LD (DE),A     ;
 32088 RET           ;
@label=DrawSpec_Airlock
*32089 LD A,53       ; cell 15 = airlock #1 door:
 32091 BIT 1,(HL)    ; closed (53) or blown (55)
 32093 JR Z,32097    ;
 32095 LD A,55       ;
@label=DrawSpec_StoreDoor1
*32097 LD (DE),A     ;
 32098 INC DE        ;
 32099 LD A,54       ; cell 16 = airlock #2 door:
 32101 BIT 2,(HL)    ; closed (54) or blown (56)
 32103 JR Z,32107    ;
 32105 LD A,56       ;
@label=DrawSpec_StoreDoor2
*32107 LD (DE),A     ;
 32108 RET           ;
@ignoreua
; Jones is in the viewed room: menu Special row 14 ($73CC) offers
; string 51 "Get Jones " (its handler needs the Net or the Cat Box),
; and the cat is drawn.
@label=DrawSpec_JonesHere
*32109 PUSH AF       ;
 32110 LD DE,29644   ;
 32113 LD A,51       ;
 32115 LD (DE),A     ;
 32116 CALL 39655    ;
 32119 POP AF        ;
 32120 RET           ;
; The alien is in the viewed room: draw it and offer "  ATTACK  ".
@label=DrawSpec_AlienHere
*32121 PUSH AF       ;
 32122 JP 44996      ;
; This entry point is used by the routine at #R44996.
@label=DrawSpec_AlienAttackRow
*32125 LD A,52       ; menu row = "  ATTACK  "
 32127 LD (DE),A     ;
 32128 XOR A         ;
@nowarn=39741
@ssub=LD (AlienXPhase),A
 32129 LD (39741),A  ;
; This entry point is used by the routine at #R44996.
@label=DrawSpec_AlienDone
*32132 POP AF        ;
