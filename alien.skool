 36839 LD A,4        ; the alien-encounter screen
 36841 LD (31243),A  ;
; This entry point is used by the routine at #R45080.
@label=RefreshInfo_AttackRow
*36844 LD A,52       ; Special cell (13) = "  ATTACK  "
