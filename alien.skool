 32930 CALL 39572    ; and redraw the status line
 32933 RET           ;
; Cell-glyph walk-handler table (was mis-disassembled as code):
; 3-byte records (glyph, handler word) looked up by DrawDoorArm
; (#R33223), which patches the handler into its CALL as it walks an
; exit path over the room-map grid. Glyphs 126/127/132/133 are
; straight wall segments -> ArmStraight (#R33275, a no-op: keep
; heading); 128-131 are the four corner pieces -> steer handlers that
; bend the walk by approach direction; 125 '}' (duct grille) and
; 142/143 (junction nodes) -> ArmEndNode (#R33388): paint and end the
; walk.
@label=CellDrawTable
 32934 DEFB 125,108,130   ; '}' duct grille -> ArmEndNode
 32937 DEFB 126,251,129   ; horizontal wall -> ArmStraight
 32940 DEFB 127,251,129   ; vertical wall -> ArmStraight
 32943 DEFB 128,252,129   ; top-left corner -> ArmCornerTopLeft
 32946 DEFB 129,24,130   ; bottom-left corner -> ArmCornerBottomLeft
 32949 DEFB 130,52,130   ; bottom-right corner -> ArmCornerBottomRight
 32952 DEFB 131,80,130   ; top-right corner -> ArmCornerTopRight
 32955 DEFB 132,251,129   ; horizontal wall -> ArmStraight
 32958 DEFB 133,251,129   ; vertical wall -> ArmStraight
 32961 DEFB 142,108,130   ; junction node -> ArmEndNode
 32964 DEFB 143,108,130   ; junction node -> ArmEndNode

; RedrawRoomView
;
; Rebuilds the room-interior view for the current room: picks the
; layout template by room type, decompresses it into the grid buffer,
; draws walls/furniture, then walks the exit list drawing one door arm
; per neighbour (and grille arms for duct openings). Room type 4 (the
; alien's lair view) resets the encounter animation instead.
@label=RedrawRoomView
c32967 LD A,(31243)  ; A = room type
 32970 CP 4          ; alien-lair view?
 32972 JR NZ,32981   ;
 32974 CALL 39687    ; yes: reset alien body animation
 32977 CALL 33421    ;
 32980 RET           ;

; PickRoomLayout
@label=PickRoomLayout
c32981 LD HL,25716   ; room type 0: layout template 0
 32984 AND A         ;
 32985 JR Z,32997    ;
 32987 LD HL,25835   ;
 32990 CP 1          ;
 32992 JR Z,32997    ;
 32994 LD HL,25996   ;
@label=PickLayout_Expand
*32997 CALL 33153    ;
 33000 CALL 33421    ;
 33003 CALL 33395    ;
 33006 CALL 33178    ;
 33009 LD HL,(31255) ; mark the room's anchor cell (attr 71:
 33012 LD (HL),71    ; bright white) — the arms start here
 33014 PUSH HL       ;
 33015 LD HL,(31259) ;
 33018 PUSH HL       ;
 33019 LD A,(29632)  ; 1st exit (menu strip cell 2)?
 33022 CP 255        ;
 33024 JR Z,33054    ;
 33026 LD DE,65516   ; yes: walk the NORTH arm — heading -20
 33029 LD (31246),DE ; (grid) / -32 (attr), starting one cell
 33033 ADD HL,DE     ; above the anchor
 33034 LD (31259),HL ;
 33037 LD HL,(31255) ;
@nowarn=65504
 33040 LD DE,65504   ; DE = -32 (screen stride: one cell up within a third)
 33043 LD (31244),DE ;
 33047 ADD HL,DE     ;
 33048 LD (31255),HL ;
 33051 CALL 33223    ;
@label=PickLayout_Exit2
*33054 LD A,(29633)  ; 2nd exit (menu strip cell 3)?
 33057 CP 255        ;
 33059 JR Z,33088    ;
 33061 POP HL        ; yes: walk the EAST arm — heading +1/+1,
 33062 POP DE        ; starting one cell right of the anchor
 33063 PUSH DE       ;
 33064 PUSH HL       ;
 33065 LD BC,1       ;
 33068 INC HL        ;
 33069 LD (31259),HL ;
 33072 INC DE        ;
 33073 LD (31255),DE ;
 33077 LD (31244),BC ;
 33081 LD (31246),BC ;
 33085 CALL 33223    ;
@label=PickLayout_Exit3
*33088 LD A,(29634)  ; 3rd exit (menu strip cell 4)?
 33091 CP 255        ;
 33093 JR Z,33123    ;
 33095 POP HL        ; yes: walk the SOUTH arm — heading +20/+32,
 33096 POP DE        ; starting one cell below the anchor
 33097 PUSH DE       ;
 33098 PUSH HL       ;
 33099 LD BC,20      ;
 33102 LD (31246),BC ;
 33106 ADD HL,BC     ;
 33107 LD (31259),HL ;
 33110 LD HL,32      ;
 33113 LD (31244),HL ;
 33116 ADD HL,DE     ;
 33117 LD (31255),HL ;
 33120 CALL 33223    ;
@label=PickLayout_Exit4
*33123 POP HL        ;
 33124 POP DE        ;
 33125 LD A,(29635)  ; 4th exit (menu strip cell 5)?
 33128 CP 255        ;
 33130 RET Z         ;
 33131 DEC DE        ; yes: walk the WEST arm — heading -1/-1,
 33132 DEC HL        ; starting one cell left of the anchor
 33133 LD (31259),HL ;
 33136 LD (31255),DE ;
 33140 LD HL,65535   ;
 33143 LD (31244),HL ;
 33146 LD (31246),HL ;
 33149 CALL 33223    ;
 33152 RET           ;

; RoomLayoutExpand
;
; Decompresses the RLE room layout at HL into the 20x19 grid buffer:
; byte < 30 = that many zero cells, 30-254 = literal tile code,
; 255 = end.
; .
; Used by NarcissusBackground (#R33644) and PickRoomLayout (#R32981).
@label=RoomLayoutExpand
c33153 LD DE,26121   ; DE = grid buffer; HL = RLE source
@label=RleExpand_Loop
*33156 LD A,(HL)     ;
 33157 CP 30         ;
 33159 JR C,33169    ;
 33161 CP 255        ;
 33163 RET Z         ;
 33164 LD (DE),A     ;
 33165 INC HL        ;
 33166 INC DE        ;
 33167 JR 33156      ;
@label=RleExpand_Zeros
*33169 LD B,A        ;
 33170 XOR A         ;
@label=RleExpand_ZeroLoop
*33171 LD (DE),A     ;
 33172 INC DE        ;
 33173 DJNZ 33171    ;
 33175 INC HL        ;
 33176 JR 33156      ;

; SetRoomOrigin
;
; Loads the current room's (row, column) pair from RoomOriginTable and
; sets RoomCellCursor (grid buffer + 20*row + col) and RoomAttrCursor
; (attribute file + 32*row + col) for the door drawing pass.
@label=SetRoomOrigin
c33178 LD A,(31242)  ; A = current room
 33181 AND 63        ;
 33183 ADD A,A       ;
 33184 LD D,0        ;
 33186 LD E,A        ;
 33187 LD HL,26501   ;
 33190 ADD HL,DE     ;
 33191 LD B,(HL)     ;
 33192 INC HL        ;
 33193 LD C,(HL)     ;
 33194 PUSH BC       ;
 33195 LD DE,20      ;
 33198 LD HL,26121   ;
@label=RoomOrigin_GridLoop
*33201 ADD HL,DE     ;
 33202 DJNZ 33201    ;
 33204 ADD HL,BC     ;
 33205 LD (31259),HL ;
 33208 POP BC        ;
 33209 LD HL,22528   ;
 33212 LD DE,32      ;
@label=RoomOrigin_AttrLoop
*33215 ADD HL,DE     ;
 33216 DJNZ 33215    ;
 33218 ADD HL,BC     ;
 33219 LD (31255),HL ;
 33222 RET           ;

; DrawDoorArm
;
; Highlights one exit path of the room-map view: walks the (invisibly
; drawn) wall glyphs from the room's anchor point, painting each
; visited attribute cell cyan (attr 5), until it reaches a grille or
; junction node. Per cell it reads the grid under RoomCellCursor,
; looks the glyph up in CellDrawTable (#R32934) and patches the
; handler into the CALL below (self-modifying). Straight segments keep
; the heading, corner glyphs 128-131 turn it, and node glyphs
; (125/142/143) end the walk via ArmEndNode (which pops the return
; address). The stride pair RoomAttrStep/RoomCellStep encodes the
; heading: attr +32/-32/+1/-1 = south/north/east/west (grid steps
; +20/-20/+1/-1 in lockstep, the grid being 20 cells wide).
@label=DrawDoorArm
c33223 LD HL,(31259) ; read grid cell under the cursor
 33226 LD A,(HL)     ;
@nowarn=32934
@ssub=LD HL,CellDrawTable
 33227 LD HL,32934   ; find its 3-byte record in CellDrawTable
@label=DoorArm_FindCell
*33230 CP (HL)       ;
 33231 JR Z,33238    ;
 33233 INC HL        ;
 33234 INC HL        ;
 33235 INC HL        ;
 33236 JR 33230      ;
@label=DoorArm_GotCell
*33238 INC HL        ; fetch the handler word
 33239 LD A,(HL)     ;
 33240 INC HL        ;
 33241 LD H,(HL)     ;
 33242 LD L,A        ;
 33243 LD (33247),HL ; patch it into the CALL below
 33246 CALL 33275    ; steer/stop for this glyph
 33249 LD HL,(31255) ; paint the attribute cell cyan
 33252 LD (HL),5     ;
 33254 LD DE,(31244) ; step the attribute cursor by the heading
 33258 ADD HL,DE     ;
 33259 LD (31255),HL ;
 33262 LD HL,(31259) ; step the grid cursor in lockstep
 33265 LD DE,(31246) ;
 33269 ADD HL,DE     ;
 33270 LD (31259),HL ;
 33273 JR 33223      ;

; ArmStraight
;
; Walk handler for straight wall glyphs (126/127/132/133): a no-op,
; the walk keeps its current heading.
@label=ArmStraight
c33275 RET           ;
; ArmCornerTopLeft — walk handler for corner glyph 128, which joins a
; south-going edge to an east-going one: a walker heading north exits
; east; any other heading exits south.
@label=ArmCornerTopLeft
 33276 LD HL,(31244) ; L = low byte of current heading
 33279 LD A,L        ;
 33280 LD DE,32      ; default: turn south
 33283 LD HL,20      ;
 33286 CP 224        ; heading north (-32, low byte 224)?
 33288 JR NZ,33296   ;
 33290 LD DE,1       ; yes: turn east
 33293 LD HL,1       ;
@label=ArmCornerTL_SetSteps
*33296 LD (31244),DE ;
 33300 LD (31246),HL ;
 33303 RET           ;
; ArmCornerBottomLeft — corner glyph 129 joins a north-going edge to
; an east-going one: heading south exits east; otherwise exits north.
@label=ArmCornerBottomLeft
 33304 LD HL,(31244) ; L = low byte of current heading
 33307 LD A,L        ;
 33308 LD DE,1       ; default: turn east
 33311 LD HL,1       ;
 33314 CP 32         ; heading south?
 33316 JR Z,33324    ;
@nowarn=65504
 33318 LD DE,65504   ; no: turn north (DE = -32, HL = -20)
 33321 LD HL,65516   ;
@label=ArmCornerBL_SetSteps
*33324 LD (31244),DE ;
 33328 LD (31246),HL ;
 33331 RET           ;
; ArmCornerBottomRight — corner glyph 130 joins a west-going edge to
; a north-going one: heading east exits north; otherwise exits west.
@label=ArmCornerBottomRight
 33332 LD HL,(31244) ; L = low byte of current heading
 33335 LD A,L        ;
@nowarn=65504
 33336 LD DE,65504   ; default: turn north (DE = -32, HL = -20)
 33339 LD HL,65516   ;
 33342 CP 1          ; heading east?
 33344 JR Z,33352    ;
 33346 LD DE,65535   ; no: turn west
 33349 LD HL,65535   ;
@label=ArmCornerBR_SetSteps
*33352 LD (31244),DE ;
 33356 LD (31246),HL ;
 33359 RET           ;
; ArmCornerTopRight — corner glyph 131 joins a west-going edge to a
; south-going one: heading east exits south; otherwise exits west.
@label=ArmCornerTopRight
 33360 LD HL,(31244) ; L = low byte of current heading
 33363 LD A,L        ;
 33364 LD DE,32      ; default: turn south
 33367 LD HL,20      ;
 33370 CP 1          ; heading east?
 33372 JR Z,33380    ;
 33374 LD DE,65535   ; no: turn west
 33377 LD HL,65535   ;
@label=ArmCornerTR_SetSteps
*33380 LD (31244),DE ;
 33384 LD (31246),HL ;
 33387 RET           ;
; ArmEndNode — walk handler for the duct grille (125) and junction
; nodes (142/143): pops DrawDoorArm's looping return address, paints
; the node cell cyan and ends the walk.
@label=ArmEndNode
 33388 POP AF        ;
 33389 LD HL,(31255) ;
 33392 LD (HL),5     ;
 33394 RET           ;

; ClearRoomAttrs
@label=ClearRoomAttrs
c33395 LD DE,12      ; black out the 20x19 room-view
 33398 LD HL,22528   ; attribute window
 33401 LD C,19       ;
@label=ClearRoomAttrs_RowLoop
*33403 LD B,20       ;
@label=ClearRoomAttrs_CellLoop
*33405 LD (HL),0     ;
 33407 INC HL        ;
 33408 DJNZ 33405    ;
 33410 ADD HL,DE     ;
 33411 DEC C         ;
 33412 JR NZ,33403   ;
 33414 LD HL,26121   ; then render the grid buffer
 33417 CALL 31312    ; (DrawRoomBackground_0)
 33420 RET           ;

; BuildDuctExitList
;
; The duct view's "move to:" rows: fill strip cells 2-5 from the
; room's four RoomAdjDucts slots (skipping no-exit entries), then
; overwrite each present exit with an anonymous direction arrow —
; strings 57-60 "North/East/South/West" — so the player sees where
; the crawlway leads but not what it leads to.
@label=BuildDuctExitList
c33421 LD A,(31242)  ; HL = RoomAdjDucts + room * 5
 33424 AND 63        ;
 33426 LD L,A        ;
 33427 LD H,0        ;
 33429 PUSH HL       ;
 33430 ADD HL,HL     ;
 33431 ADD HL,HL     ;
 33432 POP DE        ;
 33433 ADD HL,DE     ;
 33434 LD DE,29346   ;
 33437 ADD HL,DE     ;
 33438 LD DE,29632   ; DE -> strip cell 2
 33441 LD B,4        ; four duct directions:
@label=DuctExits_SlotLoop
*33443 LD C,(HL)     ; C = the destination that way;
 33444 CP C          ; own room = no exit: leave the
 33445 JR Z,33457    ; cell empty (checked twice — A
 33447 LD A,(31242)  ; holds a stale destination after
 33450 AND 63        ; a stored exit, so the reload
 33452 CP C          ; makes the second test reliable)
 33453 JR Z,33457    ;
 33455 LD A,C        ; else cell = the destination room
 33456 LD (DE),A     ;
@label=DuctExits_NextSlot
*33457 INC DE        ;
 33458 INC HL        ;
 33459 DJNZ 33443    ;
 33461 LD B,4        ; second pass: disguise each
 33463 LD HL,29632   ; present exit as a direction
 33466 LD C,57       ; arrow (57 North ... 60 West)
@label=DuctExits_ArrowLoop
*33468 LD A,(HL)     ;
 33469 CP 255        ;
 33471 JR Z,33474    ;
 33473 LD (HL),C     ;
@label=DuctExits_NextArrow
*33474 INC C         ;
 33475 INC HL        ;
 33476 DJNZ 33468    ;
 33478 RET           ;

; ClearTextWindow
;
; Used by the routines at #R31417, #R32719 and #R44815.
@label=ClearTextWindow
c33479 LD HL,20576   ;
 33482 LD (31257),HL ;
 33485 LD B,128      ;
@label=ClearText_Loop
*33487 PUSH BC       ;
 33488 XOR A         ;
 33489 CALL 31370    ;
 33492 LD HL,31257   ;
 33495 INC (HL)      ;
 33496 POP BC        ;
 33497 DJNZ 33487    ;
 33499 RET           ;

; DrawCrewPortrait
;
; Draw the selected crew member's 24x24-pixel portrait (CrewPortraits
; #R30216, 72 bytes each) at the bottom-left of the room view (screen
; rows 15-17, cols 1-3), blue ink on white. BlitPortrait is also
; entered directly by GameModeScreen with HL/DE preloaded.
@label=DrawCrewPortrait
c33500 LD HL,23009   ; paint the 3x3 attribute square
 33503 LD DE,29      ; (row 15, col 1) blue-on-white (57)
 33506 LD C,3        ;
@label=Portrait_AttrRowLoop
*33508 LD B,3        ;
@label=Portrait_AttrCellLoop
*33510 LD (HL),57    ;
 33512 INC HL        ;
 33513 DJNZ 33510    ;
 33515 DEC C         ;
 33516 ADD HL,DE     ;
 33517 JR NZ,33508   ;
 33519 LD DE,72      ; DE -> CrewPortraits +
 33522 LD HL,30216   ; (slot-1) * 72 bytes
 33525 LD A,(31241)  ;
 33528 DEC A         ;
 33529 JR Z,33535    ;
 33531 LD B,A        ;
@label=Portrait_AddrLoop
*33532 ADD HL,DE     ;
 33533 DJNZ 33532    ;
@label=Portrait_AddrDone
*33535 EX DE,HL      ;
 33536 LD HL,18657   ; blit at screen row 15, col 1
; This entry point is used by the routine at #R42821.
@label=BlitPortrait
*33539 LD (31257),HL ;
 33542 LD B,3        ; 3 cell rows
@label=BlitPortrait_RowLoop
*33544 LD C,3        ; of 3 cell columns
@label=BlitPortrait_ColLoop
*33546 PUSH BC       ;
 33547 LD HL,(31257) ;
 33550 LD B,8        ; 8 pixel bytes straight down
@label=BlitPortrait_PixLoop
*33552 LD A,(DE)     ;
 33553 LD (HL),A     ;
 33554 INC H         ;
 33555 INC DE        ;
 33556 DJNZ 33552    ;
 33558 LD HL,31257   ; next cell column
 33561 INC (HL)      ;
 33562 POP BC        ;
 33563 DEC C         ;
 33564 JR NZ,33546   ;
 33566 PUSH DE       ; next cell row: usually -3 +32,
 33567 LD HL,(31257) ; but crossing into the next
 33570 LD DE,29      ; screen third needs the big
 33573 LD A,L        ; +1821 stride
 33574 CP 224        ;
 33576 JR C,33581    ;
 33578 LD DE,1821    ;
@label=BlitPortrait_Advance
*33581 ADD HL,DE     ;
 33582 LD (31257),HL ;
 33585 POP DE        ;
 33586 DJNZ 33544    ;
 33588 RET           ;

; AdvanceScriptPtr
@ignoreua
;
; Steps the ROM-traversal script pointer forward by one byte and returns the
; low nibble (0-15) of the new byte in A. The pointer lives at #R31265 and
; walks through ZX Spectrum ROM bytes starting at $1041 (SEED $9041 with H
; masked to $10). Each nibble encodes one game command for the AI scheduler.
; .
; Output: A = next script command (0-15)
; .
; Used by the routines at #R35814, #R36457, #R36717, #R36859, #R37018,
; #R37992, #R38674, #R39256, #R39400 and #R42276.
@label=AdvanceScriptPtr
@ignoreua
c33589 LD HL,(31265) ; HL = current script pointer (#R31265)
 33592 INC HL        ; advance to next ROM byte
 33593 LD (31265),HL ; save updated pointer
 33596 LD A,(HL)     ; read ROM byte at new address
 33597 AND 15        ; keep only low nibble → command 0-15
 33599 RET           ;

; ResetScriptPtr
@ignoreua
;
; Resets the ROM-traversal script pointer to its starting address. Reads the
; SEED value from #R23672 (ZX Spectrum system variable SEED, updated by RAND),
; calls the address-masking helper at #R45290 to compute $1041 (ROM address
; $9041 with H masked to $10), and stores the result at #R31265.
; .
; Used by the routines at #R36457 and #R45222.
@label=ResetScriptPtr
c33600 LD HL,(23672) ; HL = SEED (#R23672): ZX ROM random seed value
 33603 CALL 45290    ; mask H to $10: HL → ROM address in range $1000-$1FFF
@ignoreua
 33606 LD (31265),HL ; store as script pointer at #R31265
 33609 RET           ;

; Prefix a dead room-mate's name with "Body of "
;
; Called by DrawRoomMates (#R32536) with A = actor slot before each
; mate's name is printed. If the actor's status byte (ActorRecords +7)
; is non-zero (dead/removed), draw strip 94 ("Body of   ") at the
; current draw position and advance DrawScreenPtr 8 cells so the name
; lands right after the prefix. A is preserved.
@label=DrawCrewStatusHalf
c33610 PUSH AF       ; save the actor slot
 33611 LD HL,29573   ; HL = ActorRecords slot 0 byte +7 (status)
 33614 LD DE,8       ;
 33617 LD B,A        ; step to slot A's status byte (slot >= 1 here)
@label=CrewStatus_Seek
*33618 ADD HL,DE     ;
 33619 DJNZ 33618    ;
 33621 LD A,(HL)     ; status: 0 = alive
 33622 AND A         ;
 33623 JR Z,33642    ; alive: no prefix
 33625 LD HL,(31257) ;
 33628 PUSH HL       ;
 33629 LD A,94       ; strip 94 = "Body of   "
 33631 CALL 31634    ; DrawSprite prints it at DrawScreenPtr
 33634 POP HL        ;
 33635 LD DE,8       ; advance the draw pointer 8 cells: the name
 33638 ADD HL,DE     ; overprints the strip's trailing spaces
 33639 LD (31257),HL ;
@label=CrewStatus_Done
*33642 POP AF        ; restore the actor slot
 33643 RET           ;

; NarcissusBackground — the shuttle's view background
@ignoreua
;
; Reached only from DrawRoomBackground's hidden dispatch: the JP Z at
; $7A41 (inside the code preserved as DEFBs at #R31267) lands here
; when RoomTypeByte is 3, i.e. the Narcissus. Expands NarcissusLayout
; (#R30720) into the grid buffer, copies NarcissusAttrs (#R30861) over
; the attribute file, then renders the grid via DrawRoomBackground_0
; (#R31312). No skoolkit-visible caller — the JP hides in DEFB data —
; and absent from the execution traces only because they never
; boarded the shuttle.
@label=NarcissusBackground
c33644 LD HL,30720   ; NarcissusLayout: RLE source
 33647 CALL 33153    ; RoomLayoutExpand -> grid buffer
 33650 LD DE,30861   ; NarcissusAttrs
 33653 LD HL,22528   ; attribute file base
 33656 LD C,19       ; 19 rows...
@label=Narcissus_AttrRows
*33658 LD B,20       ; ...of 20 attribute bytes
@label=Narcissus_AttrCells
*33660 LD A,(DE)     ;
 33661 LD (HL),A     ;
 33662 INC DE        ;
 33663 INC HL        ;
 33664 DJNZ 33660    ;
 33666 PUSH DE       ;
 33667 LD DE,12      ; skip the remaining 12 columns of the row
 33670 ADD HL,DE     ;
 33671 POP DE        ;
 33672 DEC C         ;
 33673 JR NZ,33658   ;
 33675 LD HL,26121   ; grid buffer
 33678 CALL 31312    ; render it as tiles
 33681 RET           ;

; Game state scratchpad RAM
;
; 110 bytes of mixed 1- and 2-byte variables stamped inline within the
; code region. The initial byte values come from the tape image, but every
; byte is treated as RAM by the running game: written by the main-loop
; subsystems and read back on subsequent frames. Despite living inside the
; code segment, none of these bytes are executed.
; .
; Key variables:
;   #R33682 AlienFlags        bit-packed input (R,L,D,U,Fire)
;   #R33683 CorridorCursor    current corridor index (0..18)
;   #R33688 SpriteDestAddr    sprite blitter screen pointer
;   #R33690 FrameCounterB     free-running 50Hz counter
;   #R33699 SoundRequest      one-shot sound trigger
;   #R33700 CrewIndex         current crew member (0..6)
;   #R33701 AlienTargetPtr         pointer to current crew record
;   #R33703 AlienTargetID     crew ID being targeted (255=none)
;   #R33704 AlienActiveFlag   alien is loose flag
;   #R33706 JonesRoom         Jones the cat's current room (255 = off-map)
;   #R33731 SoundReqFlag      pending sound parameters
;   #R33734 SprScreenAddrA    crew sprite A destination
;   #R33736 SprScreenAddrB    crew sprite B destination
;   #R33737 MusicActiveFlag   music phrase is playing
;   #R33739 AnimFrameCnt      crew animation tick
; .
; All cells in this block now carry meaningful labels; the
; message-queue cluster (MsgDrawnCol through MsgLastEnqueued) is
; documented at TickMessageQueue (#R37363).
@label=AlienFlags
b33682 DEFB 0                ; Keyboard/joystick scan bitmask (bit 0=R, 1=L, 2=D, 3=U, 4=Fire)
@label=CorridorCursor
 33683 DEFB 17               ; Currently selected corridor / cursor position (0-18)
@label=SavedRowAttr
@ignoreua
 33684 DEFB 0                ; attribute saved from under the menu-cursor highlight
                             ; (HighlightMenuRow $8842 / UnhighlightMenuRow $882B)
@label=CursorCellValue
@ignoreua
 33685 DEFB 0                ; CorridorPosTable cell value under the cursor ($8395):
                             ; what the action key dispatches on
@label=SprDestA
 33686 DEFB 0                ;
@label=SprDestAHi
 33687 DEFB 64               ; high byte of SprDestA (marker A screen address)
@label=SpriteDestAddr
 33688 DEFW 16384            ; Screen destination pointer used by sprite blitter
@label=FrameCounterB
 33690 DEFB 25               ; Free-running frame counter (low byte, ~50 Hz)
@label=FrameCounterA
 33691 DEFB 25               ; frame counter for marker channel A (reset to 10)
@label=NearRoomList
@ignoreua
 33692 DEFB 255,255,255      ; motion-tracker results (scan at $9707): entries
                             ; for Tracker #1/#2 and the carried cat = the
                             ; holder's room when nothing moves next door
                             ; (+1 morale for actors there, tested at $8E30),
                             ; or 255 = motion detected (beep / uneasy cat)
@label=NearestCrewC
@ignoreua
 33695 DEFB 255              ; third nearest-crew slot; $839F-$83A1 are also iterated as a 3-list
@label=NearestCrewA
 33696 DEFB 255              ; nearest crew ID, slot A (255 = none)
@label=NearestCrewB
 33697 DEFB 255              ; nearest crew ID, slot B (255 = none)
@label=DistanceAccum
 33698 DEFB 0                ; running distance/count accumulator for the nearest-crew scan
@label=SoundRequest
 33699 DEFB 0                ; One-shot sound request (255 = idle)
@label=CrewIndex
 33700 DEFB 1                ; Current crew member index (0-6)
@label=AlienTargetPtr
 33701 DEFB 134,115          ; pointer to the alien-target / Android ActorRecords slot
@label=AlienTargetID
 33703 DEFB 9                ; In the Long Game this is the **Android** slot index (1..7): the dormant traitor crew member that UpdateAlien (#R40826) activates on first encounter with the alien (the first frame AlienActiveFlag is set and the slot still has its template +0=+7=0). Once activated, the Android enters action state 7 and wounds nearby crew via CrewAction7_Handler (#R40757). Values >= 8 (e.g. ShortGameInit's hard-wired 9) disable the mechanic — TriggerAlienEvent (#R41264) treats them as "no valid target".
@label=AlienActiveFlag
 33704 DEFB 0                ; 255 once the alien has taken 6+ wounds while the
                             ; Android is still dormant (TriggerAlienEvent
                             ; #R41264); gates all Android hostility
