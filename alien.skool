 35505 LD L,B        ; swap HeldItemFront <-> HeldItemBack
 35506 LD H,C        ;
 35507 LD (31248),HL ;
 35510 LD HL,29940   ; ItemLocations:
 35513 PUSH HL       ;
 35514 LD E,C        ; old front item's marker -32
 35515 LD D,0        ; (160+slot -> 128+slot: now in the back hand)
 35517 ADD HL,DE     ;
 35518 LD A,(HL)     ;
 35519 SUB 32        ;
 35521 LD (HL),A     ;
 35522 POP HL        ;
 35523 LD E,B        ; old back item's marker +32
 35524 ADD HL,DE     ; (128+slot -> 160+slot: now in front)
 35525 LD A,(HL)     ;
 35526 ADD A,32      ;
 35528 LD (HL),A     ;
 35529 LD HL,18486   ; redraw the " use:" rows:
 35532 LD (31257),HL ;
 35535 LD A,(31248)  ;
 35538 CALL 31857    ;
 35541 CALL 31634    ; draw the new front item's name
 35544 LD A,(31249)  ;
 35547 CALL 31857    ; and the new back item's name
 35550 CALL 31634    ;
 35553 CALL 32385    ; refresh the condition line
 35556 CALL 36793    ; and the room info
 35559 RET           ;

; MoveThroughGrille
;
; Action on the "Grille" move-to row (1, offered once the room's
; grille is removed): send the actor through the duct opening — the
; destination is the same room with the in-ducts flag (bit 6) flipped.
; .
; Used by the routines at #R33794 and #R36579.
@label=MoveThroughGrille
c35560 LD A,64       ; base time 64
 35562 CALL 35814    ; set the actor's action timer
 35565 LD (IX+3),2   ; action state = 2 (duct transit)
 35569 LD A,(31242)  ;
 35572 XOR 64        ; same room, other side of the grille
 35574 LD (IX+2),A   ;
 35577 RET           ;

; GetItemPick
;
; Room mode 4: the "Get Item" picker strip is up (see GetItemMenu,
; #R35638) and the action key fires on a row. QUIT rebuilds the room
; scene; otherwise the picked row's entry in RoomItemList (#R29962)
; is the item id to take: it goes into the front hand (marker
; 160+slot in ItemLocations (#R29940), courage/morale raised by
; ItemCourageBonus) if that hand is free, else into the back hand
; (128+slot).
@label=GetItemPick
c35578 LD A,(33685)  ; row value under the cursor
 35581 CP 61         ; QUIT?
 35583 JP Z,32719    ;
@nowarn=33683
@ssub=LD A,(CorridorCursor)
 35586 LD A,(33683)  ; cursor row
 35589 LD E,A        ;
 35590 LD D,0        ;
 35592 LD HL,29962   ; E = RoomItemList[row] = picked item id
 35595 ADD HL,DE     ;
 35596 LD E,(HL)     ;
 35597 LD C,128      ; assume back hand (marker = slot+128)
 35599 LD A,(31248)  ; front hand free?
 35602 CP 255        ;
 35604 JR NZ,35626   ;
 35606 LD HL,29984   ; yes: raise courage and morale
 35609 ADD HL,DE     ; by ItemCourageBonus[item]
 35610 LD A,(IX+5)   ;
