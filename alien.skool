 37370 LD (33709),A  ;
 37373 RET NZ        ;
@nowarn=33710
@ssub=LD A,(MsgAttrPtr)
 37374 LD A,(33710)  ; hold over: start the erase sweep —
 37377 AND 31        ; MsgDrawnCol = current column,
@nowarn=33708
@ssub=LD (MsgDrawnCol),A
 37379 LD (33708),A  ; bit 7 clear
 37382 RET           ;
@nowarn=33708
