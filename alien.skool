; AdvanceScriptPtr
@ignoreua
;
; Steps the ROM-traversal script pointer forward by one byte and returns the
; low nibble (0-15) of the new byte in A. The pointer lives at #R31265 and
; walks through ZX Spectrum ROM bytes starting at $1041 (SEED $9041 with H
; masked to $10). Each nibble encodes one game command for the AI scheduler.
;
; Output: A = next script command (0-15)
;
; Used by the routines at #R35578, #R36457, #R36859, #R37018, #R37490, #R38379
; and #R41264.
@label=AdvanceScriptPtr
@ignoreua
c33589 LD HL,(31265) ; HL = current script pointer (#R31265)
 33592 INC HL        ; advance to next ROM byte
 33593 LD (31265),HL ; save updated pointer
 33596 LD A,(HL)     ; read ROM byte at new address
 33597 AND 15        ; keep only low nibble → command 0-15
 33599 RET           ;

; ResetScriptPtr
@ignoreua
;
; Resets the ROM-traversal script pointer to its starting address. Reads the
; SEED value from #R23672 (ZX Spectrum system variable SEED, updated by RAND),
; calls the address-masking helper at #R45290 to compute $1041 (ROM address
; $9041 with H masked to $10), and stores the result at #R31265.
;
; Used by the routines at #R36457 and #R44880.
@label=ResetScriptPtr
c33600 LD HL,(23672) ; HL = SEED (#R23672): ZX ROM random seed value
 33603 CALL 45290    ; mask H to $10: HL → ROM address in range $1000-$1FFF
@ignoreua
 33606 LD (31265),HL ; store as script pointer at #R31265
 33609 RET           ;

