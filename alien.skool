; DrawRoomTitle
;
; Used by the routines at #R32719 and #R38182.
; .
; The panel's top line — the room name (or "In Duct")
; and, for rooms, "Damage" plus the two ASCII damage digits.
@label=DrawRoomTitle
c32143 LD A,(31242)  ; room-name string = room number,
 32146 BIT 6,A       ; or 93 "In Duct" inside the ducts
 32148 JR Z,32152    ;
 32150 LD A,93       ;
@label=DrawTitle_Print
*32152 LD HL,20576   ; draw pointer -> title row
 32155 LD (31257),HL ;
 32158 CALL 31634    ;
 32161 LD HL,31242   ; in the ducts: no damage meter
 32164 BIT 6,(HL)    ;
 32166 RET NZ        ;
 32167 LD HL,20587   ; "Damage    " (89)
 32170 LD (31257),HL ;
 32173 LD A,89       ;
 32175 CALL 31634    ;
 32178 LD A,(31242)  ; DE -> RoomDamageDigits[room]
 32181 ADD A,A       ;
 32182 LD L,A        ;
 32183 LD H,0        ;
 32185 LD DE,30006   ;
 32188 ADD HL,DE     ;
 32189 EX DE,HL      ;
 32190 LD HL,20594   ; draw the two ASCII digits
 32193 LD (31257),HL ;
 32196 PUSH DE       ;
 32197 CALL 31369    ;
 32200 POP DE        ;
 32201 LD HL,31257   ;
 32204 INC (HL)      ;
 32205 INC DE        ;
 32206 CALL 31369    ;
 32209 LD HL,31257   ;
 32212 INC (HL)      ;
 32213 LD A,135      ; damage-meter icon glyph
 32215 CALL 31370    ;
 32218 RET           ;
; Room-info panel text fragments (was mis-disassembled as code):
; ASCII strings drawn one glyph at a time by the panel routines below.
; Byte 136 is the grille-icon UDG.
@label=ItemsPresentText
