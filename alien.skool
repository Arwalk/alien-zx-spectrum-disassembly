 29506 DEFB 33,33,16,32,32  ; 32 ShuttleBay -> 16 Engineerng, 33 Shttlstore
 29511 DEFB 33,3,3,32,32    ; 33 Shttlstore -> 3 Cargopod#1, 32 ShuttleBay

; CrewNameTable
;
; 7 crew/role names separated by 255 ($FF) terminators: ALIEN, Dallas, Kane,
; Ripley, Ash, Lambert, Parker, Brett. Substituted into MessageTextTable
; placeholders 253/254 by the message renderer at #R37221.
@label=CrewNameTable
b29516 DEFB 65,76,73,69,78,255,68,97
 29524 DEFB 108,108,97,115,255,75,97,110
 29532 DEFB 101,255,82,105,112,108,101,121
 29540 DEFB 255,65,115,104,255,76,97,109
 29548 DEFB 98,101,114,116,255,80,97,114
 29556 DEFB 107,101,114,255,66,114,101,116
 29564 DEFB 116,255

; Actor record array — slot 0: the alien
;
; Eight 8-byte actor records (64 bytes in all). Slot k's name
; is entry k of #R29516 (CrewNameTable): slot 0 = ALIEN, slots 1-7 =
; Dallas, Kane, Ripley, Ash, Lambert, Parker, Brett. Most per-frame loops
; start from this base (LD IX,29566) and step 8 bytes per slot; the
; message renderer at #R37221 passes the slot number straight to the
; name printer.
; .
; Per-record field layout (IX-relative):
;   +0 = sprite index for the actor's current pose (20 = idle; 92 =
;        blank; 255 = none) — also stepped as an action/frame counter
;   +1 = current room: bits 0-5 = room ID 0-34 (indexes #R28221 names
;        and the #R29171 adjacency map), bit 6 set = travelling in the
;        air-duct network (#R29346). $FF = HostMarker: slot excluded
;        from normal crew processing
;   +2 = destination room, written by the picker at #R36717 (bit 6
;        carries the duct flag along)
;   +3 = action state (1=idle, 2=move, 3=wait, 5=investigate, 7=attack)
;   +4 = strength / hit points (initial values 2-6; combat decrements)
;   +5 = sprite X tile
;   +6 = sprite Y tile
;   +7 = status: 0 = alive/normal; 1 = killed (stamped by #R37584's
;        kill path); 2 = android defeated; $FF = removed from play
;        (hypersleep, or HostMarker partner of +1=$FF)
; .
; Slot 0 is the alien: its +1 byte (29566+1) holds the alien's current
; room at runtime (initialised inside CommonGameInit #R42397, rewritten
; by the airlock eject in BlowLock #R38645; read by the combat dispatch
; CrewAction4_Handler #R37520 and by Jones's avoidance check in
; #R36859). Its +7 byte (#R29573) anchors the status-column scans
; (+7 column, step 8).
; .
; The whole array is overwritten at game start by the templates at
; #R41444 (Long Game) / #R41508 (Short Game); the row values below are
; the tape-image leftovers.
@label=ActorRecords
b29566 DEFB 0,0,0,0,0,0,0      ; slot 0 (+0..+6) — unused

; Actor record array — status column anchor
;
; Slot 0's +7 (status) byte. The alive/status scans walk the +7 column
; from here or from slot 1's +7 (#R29581) in steps of 8.
@label=ActorStatusColumn
b29573 DEFB 0

; Actor record array — crew slots 1-7
;
; See #R29566 for the field layout. Slot 1's row is split after +6 so
; that the status byte (#R29581, base of the crew-extinction scan in
; CheckCrewAlive #R44313) keeps its own address and label.
@label=CrewRecords
b29574 DEFB 64,12,0,0,2,2,2    ; slot 1 Dallas  +0..+6 — in Corridor#5
@label=CrewStatusColumn
 29581 DEFB 0                  ; slot 1 Dallas  +7 (alive-scan base)
 29582 DEFB 64,22,0,0,4,4,4,0  ; slot 2 Kane    — in Inf Stores
 29590 DEFB 64,75,0,0,4,2,2,0  ; slot 3 Ripley  — in Corridor#4 duct (bit 6)
 29598 DEFB 64,9,0,0,4,4,4,0   ; slot 4 Ash     — in Corridor#2
 29606 DEFB 64,27,0,0,3,4,4,0  ; slot 5 Lambert — in Mess
 29614 DEFB 64,11,0,0,3,4,4,0  ; slot 6 Parker  — in Corridor#4
 29622 DEFB 34,19,0,0,4,2,2,0  ; slot 7 Brett   — in Engine #3

; CorridorPosTable — the 19-cell strip / action-menu rows
;
@ignoreua
; 19 bytes indexed by CorridorCursor (#R33683, range 0..18); the cell
; value under the cursor is mirrored to CursorCellValue ($8395) and
; is what the action key dispatches on. Cell r is drawn on screen row
; r+1, columns 22-31 (row 0 holds the view title); a cell value >= 70
; is the first row of a two-row label, so the cursor highlight covers
; two rows (see HighlightMenuRow #R34882). The cells' meaning depends
; on the view: on the orders screen (mode 0) they hold the
; OrdersMenuTemplate (#R30197) bytes; in the room view (mode 1) each
; cell holds a string index for the menu row drawn at that position
; (ResetActionMenu (#R32684) loads the skeleton from
; ActionMenuTemplate (#R30178); the load image holds a hypersleep-
; room variant: 73 " Destruct ", 74 "  Enter   ", 75 "Hypersleep");
; in the Indicate Location list (modes 2/3, IndicateLocation
; (#R35222)) cells 1-17 hold room ids 0-16 or 17-33, framed by cell 0
; = 62 "Other List" (page toggle) and cell 18 = 61 "   QUIT   ".
; Read by the cursor-movement helpers around HandleInput at #R34684.
@ignoreua
@label=CorridorPosTable
b29630 DEFB 73,255,255,255,255,255,255,74
; (cells 8-15; cell 8 = first " use:" row, written by BuildItemMenu)
@label=MenuUseRows
 29638 DEFB 255,255,255,255,75,255,255,255
; (cells 16-18; cell 16 = second fixture row, written by FixtureAction)
@label=MenuFixtureRow
 29646 DEFB 255,255,255
; 256 bytes of workspace/padding (zero in the load image)
 29649 DEFB 0,0,0,0,0,0,0,0
 29657 DEFB 0,0,0,0,0,0,0,0
 29665 DEFB 0,0,0,0,0,0,0,0
 29673 DEFB 0,0,0,0,0,0,0,0
 29681 DEFB 0,0,0,0,0,0,0,0
 29689 DEFB 0,0,0,0,0,0,0,0
 29697 DEFB 0,0,0,0,0,0,0,0
