 35633 ADD HL,DE     ;
 35634 LD (HL),A     ;
 35635 JP 32719      ; rebuild the room scene

; GetItemMenu
;
; Action on the "Get Item" row (10): rebuild the strip
; as an item picker listing the room's items — copy RoomItemList
; (#R29962) into CorridorPosTable, converting each id to its name
; string via ItemIdToString (#R31857) — put the cursor on the QUIT
; row and switch to room mode 4 (GetItemPick above handles the
; selection).
@ignoreua
@label=GetItemMenu
c35638 LD (IX+0),0   ; clear the actor's action timer
 35642 LD DE,29630   ; DE -> CorridorPosTable
@nowarn=29962
 35645 LD HL,29962   ; HL -> RoomItemList
 35648 LD B,17       ; copy 17 entries
@label=GetItemMenu_CopyLoop
*35650 LD A,(HL)     ;
 35651 CP 255        ; 255 = empty row, copied as-is
 35653 JR Z,35660    ;
 35655 PUSH DE       ;
 35656 CALL 31857    ; item id -> name string index
 35659 POP DE        ;
@label=GetItemMenu_StoreCell
*35660 LD (DE),A     ;
 35661 INC HL        ;
 35662 INC DE        ;
 35663 DJNZ 35650    ;
 35665 LD A,61       ; row 17 = "   QUIT   ",
 35667 LD (29647),A  ; cursor on it
 35670 LD (33685),A  ;
 35673 LD A,17       ;
@nowarn=33683
@ssub=LD (CorridorCursor),A
 35675 LD (33683),A  ;
 35678 LD HL,22582   ; menu attributes: 17 rows white,
 35681 LD A,15       ; 1 row highlighted
 35683 LD C,17       ;
 35685 CALL 31612    ;
 35688 LD A,56       ;
 35690 LD C,1        ;
 35692 CALL 31612    ;
 35695 LD HL,29630   ; draw the 19 menu rows
 35698 LD (31261),HL ;
 35701 LD HL,16438   ;
 35704 LD (31257),HL ;
 35707 LD B,19       ;
@label=GetItemMenu_DrawLoop
*35709 PUSH BC       ;
 35710 CALL 31626    ;
 35713 POP BC        ;
 35714 DJNZ 35709    ;
 35716 LD A,4        ; room mode = 4 (item picker)
 35718 LD (31252),A  ;
 35721 CALL 34882    ;
 35724 RET           ;

; LeaveItemHandler
;
; Action on the "Leave Item" row (11): drop the
; back-hand item if there is one, otherwise the front-hand item
; (undoing its courage bonus); the dropped item's ItemLocations entry
; becomes the current room.
@label=LeaveItemHandler
c35725 LD (IX+0),0   ;
 35729 LD A,(31249)  ; back hand loaded?
 35732 CP 255        ;
 35734 JR NZ,35782   ; yes: drop the back item
 35736 LD A,(31248)  ; no: drop the front item —
 35739 LD E,A        ;
 35740 LD D,0        ;
 35742 LD HL,29984   ; undo its courage bonus
 35745 ADD HL,DE     ;
 35746 LD A,(IX+5)   ;
 35749 SUB (HL)      ;
 35750 CP 127        ; (clamp underflow to 0)
 35752 JR C,35755    ;
 35754 XOR A         ;
@label=LeaveItem_SetCourage
*35755 LD (IX+5),A   ;
 35758 LD A,(IX+6)   ;
 35761 SUB (HL)      ;
 35762 CP 127        ;
 35764 JR C,35767    ;
 35766 XOR A         ;
@label=LeaveItem_SetMorale
*35767 LD (IX+6),A   ;
@label=LeaveItem_Drop
*35770 LD HL,29940   ; ItemLocations[item] = current room:
 35773 ADD HL,DE     ; the item now lies here
 35774 LD A,(31242)  ;
 35777 LD (HL),A     ;
 35778 CALL 32719    ; rebuild the room scene
 35781 RET           ;
@label=LeaveItem_BackHand
*35782 LD E,A        ; E = back item id (no bonus to undo)
 35783 LD D,0        ;
 35785 JR 35770      ;

; SpecialRowJump
@ignoreua
;
; Special-row handler (row 13, from RoomDispatchTailExtra): the shim
; at $B306 sorts out the 238 marker first, then re-enters below.
@label=SpecialRowJump
c35787 JP 45830      ;

; SpecialRowNormal
;
; Used by the routine at #R45830.
@label=SpecialRowNormal
c35790 CP 52         ; "  ATTACK  " selected?
 35792 JP Z,37493    ; yes: attack handler
; This entry point is used by the routine at #R45830.
; StartGrilleRemoval: queue the timed RmveGrille job — action state 3
; fires CrewAction3_RemoveGrille (#R36150) when the countdown expires.
@label=StartGrilleRemoval
*35795 LD A,(31241)  ; base time = GrilleTimeBySlot[slot]
 35798 LD E,A        ; (100-180 frames, crew-dependent)
@ignoreua
 35799 LD D,0        ;
 35801 LD HL,33770   ;
 35804 ADD HL,DE     ;
 35805 LD A,(HL)     ;
 35806 CALL 35814    ; set the action countdown
 35809 LD (IX+3),3   ; action state = 3 (remove the grille)
 35813 RET           ;

; SetActionTimer
;
; Used by the routines at #R35382, #R35560, #R35790, #R36579 and #R37493.
; .
; (IX+0) = A + ActionTimeBySlot[slot] +
; ActionTimeByStrength[(IX+4) & 7] — the shared countdown formula for
; every queued crew action (move, grille, attack, ...).
@label=SetActionTimer
c35814 PUSH AF       ; A = base time from the caller
@nowarn=33786
@ssub=LD HL,ActionTimeBySlot
 35815 LD HL,33786   ;
 35818 LD A,(31241)  ; + per-slot adjustment
 35821 LD D,0        ;
 35823 LD E,A        ;
 35824 ADD HL,DE     ;
 35825 LD C,(HL)     ;
 35826 LD A,(IX+4)   ; + per-strength adjustment
 35829 AND 7         ; (Wounded +48, strength 3 +16, else +0)
 35831 LD E,A        ;
@nowarn=33778
@ssub=LD HL,ActionTimeByStrength
 35832 LD HL,33778   ;
 35835 ADD HL,DE     ;
 35836 LD A,(HL)     ;
 35837 ADD A,C       ; C = slot + strength adjustments
 35838 LD C,A        ;
 35839 POP AF        ; recover the caller's base time
 35840 ADD A,C       ;
 35841 LD (IX+0),A   ; arm the countdown
 35844 RET           ;
; GetJonesHandler — the "Get Jones" menu row (mode-1 row 14), reached
; through RoomDispatchTailExtra (#R33862). Needs the Net (item 16) or
; the Cat Box (17) in the front hand; rolls a script nibble against
; JonesCatchBySlot (#R33762) — the Net gets -4 on the threshold, so it
; is the easier tool. Failure spooks Jones into moving at once;
; success destroys the tool, puts "Cat in Net"/"Cat in Box" (tool+4)
; in the catcher's hand and takes Jones off the map.
@label=GetJonesHandler
 35845 LD (IX+0),0   ; park the actor's action countdown
 35849 LD A,(31248)  ; front-hand item...
 35852 CP 17         ; ...the Cat Box?
 35854 JR Z,35859    ;
 35856 CP 16         ; ...or the Net?
 35858 RET NZ        ; neither: cannot catch Jones
@label=GetJones_Threshold
*35859 LD A,(31241)  ; E = JonesCatchBySlot[slot],
 35862 LD E,A        ; this crew member's catch threshold
 35863 LD D,0        ;
@nowarn=33762
@ssub=LD HL,JonesCatchBySlot
 35865 LD HL,33762   ;
 35868 ADD HL,DE     ;
 35869 LD E,(HL)     ;
 35870 LD A,(31248)  ; using the Cat Box?
 35873 CP 17         ;
 35875 JR Z,35881    ;
 35877 LD A,E        ; no, the Net: threshold -4
 35878 SUB 4         ; (easier to succeed)
 35880 LD E,A        ;
@label=GetJones_Roll
*35881 CALL 33589    ; roll the next script nibble (0-15)
 35884 CP E          ; beat the threshold?
 35885 JR NC,35896   ; yes: caught him
 35887 LD HL,33707   ; no: JonesMoveTimer = 1 —
 35890 LD (HL),1     ; the cat bolts,
 35892 CALL 36859    ; and UpdateJones moves him right now
 35895 RET           ;
@label=GetJones_Catch
*35896 LD A,(31248)  ; ItemLocations[tool] = 255:
 35899 LD HL,29940   ; the Net / Cat Box ceases to exist...
 35902 LD E,A        ;
 35903 LD D,0        ;
 35905 ADD HL,DE     ;
 35906 LD (HL),255   ;
 35908 LD E,4        ; ...and tool+4 ("Cat in Net" 20 /
 35910 ADD HL,DE     ; "Cat in Box" 21) appears
 35911 LD A,(31241)  ;
 35914 ADD A,160     ; in the catcher's front hand (160+slot)
 35916 LD (HL),A     ;
 35917 CALL 31820    ; refresh the HeldItemFront/Back cache
@ignoreua
 35920 LD A,(31248)  ; front-hand strip cell ($73C6) =
 35923 CALL 31857    ; the new "Cat in ..." item's string id
 35926 LD (29638),A  ;
 35929 LD HL,18486   ; redraw the front-hand row
 35932 LD (31257),HL ; (screen row 9, col 22)
 35935 CALL 31634    ;
 35938 CALL 45510    ; +1 courage/morale for the catcher, and...
 35941 LD (HL),255   ; ...JonesRoom = 255: Jones is off the map
 35943 LD HL,18678   ; blank the "Get Jones" row
 35946 LD (31257),HL ; (screen row 15, col 22)
 35949 LD A,255      ;
 35951 LD (29644),A  ; its strip cell 14 = empty
 35954 CALL 31634    ;
 35957 CALL 34743    ; step the cursor off the now-empty row
 35960 CALL 39670    ; run the cat animation once
 35963 LD A,(31241)  ;
 35966 LD L,A        ; L = capturing crew slot
 35967 LD A,2        ; msg #2 "{actor} has captured Jones"
 35969 CALL 37176    ;
 35972 RET           ;

; ResetCrewTimers — per-frame crew action-countdown walk
;
; Called from GameEntry (#R36457) each frame: walk all 8 actor records,
; decrement every non-parked action countdown (IX+0), and fire the
; queued action on the 1->0 transition — DispatchCrewAction (#R36014)
; then jumps through CrewActionDispatch (#R33876) into the per-state
; handlers (#R36034 move/idle, #R36101 duct transit, #R36150 remove
; grille, ...).
@label=ResetCrewTimers
c35973 PUSH IX       ;
 35975 XOR A         ; CrewIndex = 0: start at the alien's slot
@nowarn=33700
@ssub=LD (CrewIndex),A
 35976 LD (33700),A  ;
 35979 LD IX,29566   ; IX -> ActorRecords slot 0
 35983 LD B,8        ; all 8 actor slots
@label=CrewTimersLoop
*35985 PUSH BC       ;
 35986 LD A,(IX+0)   ; A = action countdown
 35989 AND A         ; parked (0)?
 35990 JR Z,35999    ; yes: leave it alone
 35992 DEC A         ; tick it down
 35993 LD (IX+0),A   ;
 35996 CALL 45232    ; fire the action on the 1->0 transition
@label=CrewTimersNext
*35999 LD DE,8       ; step to the next 8-byte record
 36002 ADD IX,DE     ;
@nowarn=33700
@ssub=LD HL,CrewIndex
 36004 LD HL,33700   ; keeping CrewIndex in step
 36007 INC (HL)      ;
 36008 POP BC        ;
 36009 DJNZ 35985    ;
 36011 POP IX        ;
 36013 RET           ;

; DispatchCrewAction
;
; Dispatches one crew/alien actor through #R33876 (CrewActionDispatch) based on
; (IX+3). Action 0 returns early. Otherwise jumps to the per-action handler
; via JP (HL). Called on an actor's action-countdown 1->0 transition:
; the crew-timer walk (ResetCrewTimers #R35973) goes through the CALL Z
; trampoline at the tail of the #R44880 block.
@label=DispatchCrewAction
c36014 CALL 36579    ; preliminary actor update
 36017 AND A         ; A = current action state from caller
 36018 RET Z         ; action 0: nothing more to do
 36019 LD E,(IX+3)   ; E = action state (1..7)
 36022 LD D,0        ;
@nowarn=33876
@ssub=LD HL,CrewActionDispatch
 36024 LD HL,33876   ; HL = CrewActionDispatch base
 36027 ADD HL,DE     ; HL += action*2 (16-bit-pointer stride)
 36028 ADD HL,DE     ;
 36029 LD A,(HL)     ; HL = *(table + action*2)
 36030 INC HL        ;
 36031 LD H,(HL)     ;
 36032 LD L,A        ;
 36033 JP (HL)       ; tail-call into action handler

; CrewAction1_Arrive — complete a move (action state 1)
;
; Dispatched via CrewActionDispatch entry 1. State 1 means "go to the
; room in (IX+2)" (or idle when the destination equals the current
; room — the AI parks wanderers that way). On firing, the actor
; arrives: current room := destination, with a door sound unless the
; move happened inside the duct network. Arriving in an airlock that
; has been blown open (ShipSystemFlags bit 1 = Airlock #1, bit 2 =
; Airlock #2) dumps the mover into Corridor#6 (room 13) instead.
; .
; Used by the routines at #R33862 and #R37992.
@label=CrewAction1_Arrive
c36034 LD A,(IX+2)   ; A = destination room
 36037 CP (IX+1)     ; already there?
 36040 RET Z         ; yes: stay idle
 36041 LD (IX+1),A   ; arrive: current room = destination
 36044 BIT 6,A       ; was the move inside the ducts?
 36046 JR NZ,36053   ;
 36048 LD A,1        ; no: request the door sound
@nowarn=33699
@ssub=LD (SoundRequest),A
 36050 LD (33699),A  ;
@label=CrewArrive_AirlockCheck
*36053 CALL 36187    ; recompute room-mates and morale
 36056 LD A,(IX+1)   ; entered Airlock #1 (room 0)?
 36059 LD E,2        ; (its "blown" flag is bit 1)
 36061 AND A         ;
 36062 JR Z,36070    ;
 36064 CP 1          ; entered Airlock #2 (room 1)?
 36066 JR NZ,36081   ; neither: no airlock hazard
 36068 LD E,4        ; (its "blown" flag is bit 2)
@label=CrewArrive_AirlockVented
*36070 LD A,E        ; is that airlock blown open?
 36071 LD HL,31253   ;
 36074 AND (HL)      ;
 36075 JR Z,36081    ;
 36077 LD (IX+1),13  ; yes: the mover ends up in Corridor#6
@label=CrewArrive_RefreshView
*36081 LD A,(31252)  ; room view on screen (mode 1)?
 36084 CP 1          ;
 36086 RET NZ        ; no: done
@nowarn=33700
@ssub=LD A,(CrewIndex)
 36087 LD A,(33700)  ; is this the crew member being viewed?
 36090 LD HL,31241   ;
 36093 CP (HL)       ;
 36094 JP Z,32719    ; yes: rebuild the whole room view
 36097 CALL 45338    ; no: refresh the info panel / condition
 36100 RET           ;

; CrewAction2_DuctTransit — climb through a grille (action state 2)
;
; Dispatched via CrewActionDispatch entry 2: the actor crosses between
; a room and the duct run above it (queued by MoveThroughGrille
; #R35560 or the AI's duct hop at #R37132). The cramped ducts cost a
; point of courage to enter; climbing back out earns it back.
@label=CrewAction2_DuctTransit
c36101 LD E,(IX+1)   ; E = current room (bit 6 = in ducts)
 36104 LD A,(IX+5)   ; A = courage
 36107 BIT 6,E       ; climbing out of the ducts?
 36109 JR NZ,36113   ; yes: net +1 courage
 36111 DEC A         ; no, crawling in: net -1
 36112 DEC A         ;
@label=CrewDuct_BumpCourage
*36113 INC A         ;
 36114 CP 127        ; clamp an underflow to 0
 36116 JR C,36119    ;
 36118 XOR A         ;
@label=CrewDuct_SetCourage
*36119 LD (IX+5),A   ;
 36122 LD A,E        ; flip the in-ducts flag:
 36123 XOR 64        ; same room, other side of the grille
 36125 LD (IX+1),A   ;
 36128 CALL 36187    ; recompute room-mates and morale
 36131 LD A,(31252)  ; room view on screen (mode 1)?
 36134 CP 1          ;
 36136 RET NZ        ; no: done
@nowarn=33700
@ssub=LD A,(CrewIndex)
 36137 LD A,(33700)  ; is this the crew member being viewed?
 36140 LD HL,31241   ;
 36143 CP (HL)       ;
 36144 JP Z,32719    ; yes: rebuild the whole room view
 36147 JP 45338      ; no: refresh the info panel / condition

; CrewAction3_RemoveGrille
@ignoreua
;
; Used by the routines at #R33862 and #R36579.
; .
; Dispatched via CrewActionDispatch entry 3.
; Fires when a crew member's timed "RmveGrille" job completes (queued
; by the AI at $90EE or by the action-menu Special handler at $8BD3):
; clears the actor's room's byte in RoomGrilleState (#R30076), queues
; a sound effect, and rebuilds the room view if that room is on
; screen.
@label=CrewAction3_RemoveGrille
c36150 LD A,1        ; queue a sound effect for PlayMusic
@nowarn=33705
@ssub=LD (SoundPending),A
 36152 LD (33705),A  ;
 36155 LD A,(IX+1)   ; E = actor's current room
 36158 AND 63        ; (mask off the in-ducts flag, bit 6)
 36160 LD HL,30076   ;
 36163 LD E,A        ;
 36164 LD D,0        ;
 36166 ADD HL,DE     ;
 36167 LD (HL),0     ; RoomGrilleState[room] = 0: grille removed
 36169 LD A,(31252)  ; room mode 1 (normal room view)?
 36172 CP 1          ;
 36174 RET NZ        ;
 36175 LD A,(31242)  ; is the actor's room the one on screen?
 36178 AND 63        ;
 36180 CP E          ;
 36181 JP Z,32719    ; yes: full room-view rebuild
 36184 JP 36793      ;

; RecalcMorale — find room-mates and recompute the trio's morale
;
; After an actor moves: scan the 7 crew rooms for other actors on the
; same spot (same room, same side of the ducts), record up to two in
; RoomMateA/B, then run MoraleFromCompanion (#R36283) three times,
; rotating the (self, mateA, mateB) triple through NearestCrewC so
; each of the three has his morale recomputed with the other two as
; companions. A third room-mate's slot would spill past RoomMateB
; into RoomModeByte (#R31252) — PreActionCheck's 3-crew room cap is
; what keeps that from happening.
@label=RecalcMorale
c36187 LD HL,65535   ; RoomMateA/B = 255/255 (none)
 36190 LD (31250),HL ;
 36193 LD HL,29575   ; HL -> slot 1's room byte (+1)
 36196 LD C,1        ; C = candidate slot number
@nowarn=33700
@ssub=LD A,(CrewIndex)
 36198 LD A,(33700)  ; processing the alien (slot 0)?
 36201 AND A         ;
 36202 RET Z         ; yes: it has no morale
 36203 EX AF,AF'     ; keep own slot number in A'
 36204 LD DE,31250   ; DE -> RoomMateA
 36207 LD A,(IX+1)   ; A = own spot (room + duct bit)
 36210 LD B,7        ; scan the 7 crew slots
@label=RecalcMorale_ScanLoop
*36212 CP (HL)       ; on the same spot?
 36213 JR NZ,36224   ; no: next slot
 36215 EX AF,AF'     ; is it our own record?
 36216 CP C          ;
 36217 JR Z,36223    ; yes: skip it
 36219 EX DE,HL      ; record the room-mate's slot
 36220 LD (HL),C     ; (RoomMateA, then RoomMateB)
 36221 EX DE,HL      ;
 36222 INC DE        ;
@label=RecalcMorale_SkipSelf
*36223 EX AF,AF'     ; (put the spot back in A)
@label=RecalcMorale_NextSlot
*36224 PUSH DE       ;
 36225 LD DE,8       ; step to the next record's room byte
 36228 ADD HL,DE     ;
 36229 POP DE        ;
 36230 INC C         ;
 36231 DJNZ 36212    ;
 36233 PUSH IX       ;
@nowarn=33700
@ssub=LD A,(CrewIndex)
 36235 LD A,(33700)  ; seed the rotation:
@nowarn=33695
@ssub=LD (NearestCrewC),A
 36238 LD (33695),A  ; C-slot = self,
 36241 LD HL,(31250) ; A/B-slots = the two room-mates
@nowarn=33696
@ssub=LD (NearestCrewA),HL
 36244 LD (33696),HL ;
 36247 CALL 36283    ; morale of self (companions: A and B)
@nowarn=33696
@ssub=LD HL,(NearestCrewA)
 36250 LD HL,(33696) ; rotate the triple: (C,A,B) =
@nowarn=33695
@ssub=LD A,(NearestCrewC)
 36253 LD A,(33695)  ; (mateA, mateB, self)
@nowarn=33697
@ssub=LD (NearestCrewB),A
 36256 LD (33697),A  ;
@nowarn=33695
@ssub=LD (NearestCrewC),HL
 36259 LD (33695),HL ;
 36262 CALL 36283    ; morale of mateA (companions: B, self)
@nowarn=33696
@ssub=LD HL,(NearestCrewA)
 36265 LD HL,(33696) ; rotate again: (C,A,B) =
@nowarn=33695
@ssub=LD A,(NearestCrewC)
 36268 LD A,(33695)  ; (mateB, self, mateA)
@nowarn=33697
@ssub=LD (NearestCrewB),A
 36271 LD (33697),A  ;
@nowarn=33695
@ssub=LD (NearestCrewC),HL
 36274 LD (33695),HL ;
 36277 CALL 36283    ; morale of mateB (companions: self, A)
 36280 POP IX        ;
 36282 RET           ;

; MoraleFromCompanion — morale = courage + companion effects
;
; Recompute the morale (+6) of the crew member whose slot is in
; NearestCrewC from his courage (+5) plus a term per companion slot
; in NearestCrewA/B: a live companion adds his own courage - 2 (a
; brave friend reassures, a coward unnerves); a dead one costs 1 —
; and a freshly dead body (status 1) is "found": everyone's courage
; decays, msg #20 fires and the body's status moves to 2 so it is
; only found once. Standing in one of the rooms in NearRoomList
; (#R33692, the tracker-holder scan at #R38903) is worth +1. The sum
; is clamped to 0 on underflow.
@label=MoraleFromCompanion
c36283 XOR A         ; companion-effect accumulator = 0
@nowarn=33698
@ssub=LD (DistanceAccum),A
 36284 LD (33698),A  ;
@nowarn=33695
@ssub=LD A,(NearestCrewC)
 36287 LD A,(33695)  ; A = whose morale to compute
 36290 CP 255        ; nobody?
 36292 RET Z         ;
 36293 LD B,A        ; IX -> that crew member's record
 36294 LD IX,29566   ;
 36298 LD DE,8       ;
@label=MoraleComp_FindSlot
*36301 ADD IX,DE     ;
 36303 DJNZ 36301    ;
 36305 XOR A         ; dead or removed (+7 nonzero)?
 36306 CP (IX+7)     ;
 36309 RET NZ        ; yes: no morale to compute
 36310 PUSH IX       ;
 36312 LD B,2        ; both companion slots:
@nowarn=33696
@ssub=LD DE,NearestCrewA
 36314 LD DE,33696   ; NearestCrewA, then NearestCrewB
@label=MoraleComp_PairLoop
*36317 PUSH BC       ;
 36318 PUSH DE       ;
 36319 LD A,(DE)     ; A = companion slot (255 = none)
 36320 CP 255        ;
 36322 JR Z,36385    ;
 36324 LD IX,29566   ; IX -> the companion's record
 36328 LD DE,8       ;
@label=MoraleComp_RecSeek
*36331 ADD IX,DE     ;
 36333 DEC A         ;
 36334 JR NZ,36331   ;
 36336 CP (IX+7)     ; companion alive (status 0)?
 36339 JR Z,36372    ; yes: courage support
 36341 INC A         ; a freshly dead body (status 1)?
 36342 CP (IX+7)     ;
 36345 JR NZ,36366   ; no (found earlier / removed): just -1
 36347 CALL 36428    ; find the body: everyone's courage decays,
 36350 POP DE        ;
 36351 PUSH DE       ;
 36352 LD A,(DE)     ; H = the body's slot
 36353 LD H,A        ;
@nowarn=33695
@ssub=LD A,(NearestCrewC)
 36354 LD A,(33695)  ;
 36357 LD L,A        ; L = the discovering crew slot
 36358 LD A,20       ; msg #20 "{actor} finds {target}'s body"
 36360 CALL 37176    ;
 36363 INC (IX+7)    ; status 2: the body is only found once
@nowarn=33698
@label=MoraleComp_Minus
@ssub=LD HL,DistanceAccum
*36366 LD HL,33698   ; a dead companion:
 36369 DEC (HL)      ; morale term -1
 36370 JR 36385      ;
@label=MoraleComp_AddCourage
*36372 LD A,(IX+5)   ; a live companion: morale term +=
 36375 SUB 2         ; his courage - 2
 36377 LD E,A        ;
@nowarn=33698
@ssub=LD A,(DistanceAccum)
 36378 LD A,(33698)  ;
 36381 ADD A,E       ;
@nowarn=33698
@ssub=LD (DistanceAccum),A
 36382 LD (33698),A  ;
@label=MoraleComp_NextPair
*36385 POP DE        ;
 36386 INC DE        ; next companion slot
 36387 POP BC        ;
 36388 DJNZ 36317    ;
 36390 POP IX        ; IX -> the actor again
 36392 LD B,3        ; is his spot one of the 3 rooms
@nowarn=33692
@ssub=LD HL,NearRoomList
 36394 LD HL,33692   ; in NearRoomList?
 36397 LD A,(IX+1)   ;
@label=MoraleComp_RoomScan
*36400 CP (HL)       ;
 36401 JR Z,36408    ;
 36403 INC HL        ;
 36404 DJNZ 36400    ;
 36406 JR 36412      ;
@nowarn=33698
@label=MoraleComp_RoomBonus
@ssub=LD HL,DistanceAccum
*36408 LD HL,33698   ; yes: +1
 36411 INC (HL)      ;
@nowarn=33698
@label=MoraleComp_Apply
@ssub=LD HL,DistanceAccum
*36412 LD HL,33698   ; morale = courage + companion effects,
 36415 LD A,(IX+5)   ;
 36418 ADD A,(HL)    ;
 36419 CP 127        ; clamped to 0 on underflow
 36421 JR C,36424    ;
 36423 XOR A         ;
@label=MoraleComp_SetMorale
*36424 LD (IX+6),A   ;
 36427 RET           ;

; DecayCrewCourage — everyone loses a point of courage and morale
;
; Grim events shake the whole crew: -1 courage and -1 morale for all
; 7 crew members (each clamped at 0). Triggered by finding a body
; (#R36283) and by witnessing a kill (#R45585). The loop body is
; split: DecayMoraleStep (#R45539) handles the morale byte and the
; loop stepping, then refreshes the viewed condition line.
@label=DecayCrewCourage
