; FindTrackerHolders — run the motion-tracker scan
;
; The two Trackers (items 6/7) and the carried cat ("Cat in Net"/"Cat
; in Box", items 20/21) are motion detectors: for each one held in a
; FRONT hand (marker >= 160), TrackerHolderRoom (#R38941) sweeps the
; rooms adjacent to the holder and fills the matching NearRoomList
; entry (#R33692: tracker #1, tracker #2, the cat) with the holder's
; room if nothing moves next door ("all clear" — worth +1 morale to
; everyone standing there, #R36283), or 255 if something does (which
; makes the viewed holder's tracker beep, or Jones grow uneasy —
; ViewedTrackerCheck #R39171).
; .
; Used by the routine at #R38379.
@nowarn=33692
@label=FindTrackerHolders
@ssub=LD HL,NearRoomList
c38903 LD HL,33692   ; HL -> NearRoomList entry 0
 38906 LD A,(29946)  ; Tracker #1 (item 6) in a front
 38909 CP 160        ; hand (marker >= 160)?
 38911 CALL NC,38941 ; yes: scan around its holder
 38914 INC HL        ; entry 1:
 38915 LD A,(29947)  ; Tracker #2 (item 7)
 38918 CP 160        ;
 38920 CALL NC,38941 ;
 38923 INC HL        ; entry 2 (shared):
 38924 LD A,(29960)  ; Cat in Net (item 20)
 38927 CP 160        ;
 38929 CALL NC,38941 ;
 38932 LD A,(29961)  ; Cat in Box (item 21)
 38935 CP 160        ;
 38937 CALL NC,38941 ;
 38940 RET           ;

; TrackerHolderRoom — sweep the rooms around one tracker holder
;
; A = the front-hand marker (160+slot), HL -> the NearRoomList entry
; to fill: walk the holder's 5 adjacency slots (corridor map, or duct
; map when he is in the ducts) and write the holder's room ("all
; clear") — unless Jones, the alien, or any live actor is in an
; adjacent room, in which case the entry becomes 255 ("motion
; detected", via PickRoom_Reject).
; .
; Used by the routine at #R38903.
@label=TrackerHolderRoom
c38941 CP 255        ; marker 255 = the item does not exist
 38943 RET Z         ;
 38944 PUSH HL       ; save the NearRoomList entry ptr
 38945 SUB 160       ; A = the holder's slot;
 38947 ADD A,A       ; HL -> his room byte (+1)
 38948 ADD A,A       ;
 38949 ADD A,A       ;
 38950 LD E,A        ;
 38951 LD D,0        ;
 38953 LD HL,29567   ;
 38956 ADD HL,DE     ;
 38957 LD A,(HL)     ; AdjTestRoom = the holder's room
@nowarn=38356
 38958 LD (38356),A  ;
 38961 LD BC,29171   ; BC = RoomAdjCorridors...
 38964 BIT 6,A       ; ...unless he is in the ducts:
 38966 JR Z,38971    ;
 38968 CALL 45683    ; then RoomAdjDucts (DuctSearchInit)
@label=AdjRowFromRoom
*38971 LD L,A        ; HL = map + room*5:
 38972 LD H,0        ; the room's 5 direction slots
 38974 PUSH HL       ;
 38975 ADD HL,HL     ;
 38976 ADD HL,HL     ;
 38977 POP DE        ;
 38978 ADD HL,DE     ;
 38979 ADD HL,BC     ;
 38980 LD DE,8       ;
 38983 LD B,5        ; each direction slot:
@label=PickRoomScanLoop
*38985 PUSH BC       ;
 38986 PUSH HL       ;
 38987 LD C,(HL)     ; C = the adjacent room
@nowarn=38356
 38988 LD A,(38356)  ; own room = no exit that way:
 38991 CP C          ; skip the slot
 38992 JR Z,39023    ;
@nowarn=33706
@ssub=LD A,(JonesRoom)
 38994 LD A,(33706)  ; anything moving in there?
 38997 JP 45705      ; Jones / the alien / live actors

