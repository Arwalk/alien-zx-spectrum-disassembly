 40284 LD A,1        ; queue the engine-noise effect
@nowarn=33699
@ssub=LD (SoundRequest),A
 40286 LD (33699),A  ;
 40289 CALL 40319    ; play it (FrameTiming)
 40292 LD DE,12      ; toggle the BRIGHT bit across the
 40295 LD HL,22528   ; 20x19 room-view attribute window
 40298 LD C,19       ;
@label=Launch_AttrRows
*40300 LD B,20       ;
@label=Launch_AttrLoop
*40302 LD A,(HL)     ;
 40303 XOR 64        ;
 40305 LD (HL),A     ;
