 42432 CALL 33589    ;
@nowarn=33706
@ssub=LD (AlienEventTimer),A
 42435 LD (33706),A  ;
 42438 CALL 33589    ;
 42441 LD E,A        ;
 42442 LD D,0        ;
@nowarn=41358
@ssub=LD HL,AlienInitTable
 42444 LD HL,41358   ; HL = AlienInitTable ($A18E)
 42447 ADD HL,DE     ;
 42448 LD A,(HL)     ; A = AlienInitTable[script_byte]
 42449 OR 64         ; set direction bit (bit 6)
