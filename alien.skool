; FrameTiming
;
; Controls frame timing and plays a queued sound effect. Reads the sound-
; request flag at #R33731. If zero, calls the standard one-frame wait at
; #R36448 (approx 1/50s on a 48K Spectrum) and returns. If non-zero, plays a
; beeper tone by reading 1-KB ROM bytes starting at $0200 and toggling bit 4
; of port $FE for each byte; the outer loop runs 255 × 4 iterations with a
; short delay (D=64 counts) between each toggle. After playback, clears the
; sound-request flag.
;
; Used by the routines at #R36457, #R38379 and #R42821.
@nowarn=33699
@label=FrameTiming
@ssub=LD A,(SoundRequest)
@ignoreua
c40319 LD A,(33699)  ; A = sound-request flag (#R33731)
 40322 AND A         ; any sound queued?
 40323 JR NZ,40329   ; yes: play beeper effect
 40325 CALL 36448    ; no: standard one-frame timing wait (~1/50s)
 40328 RET           ;
*40329 LD HL,512     ; HL = $0200 (ROM tone data source)
 40332 LD D,64       ; D = inter-toggle delay count
 40334 LD B,255      ; outer loop: 255 iterations
*40336 PUSH BC       ;
 40337 LD B,4        ; 4 sub-iterations per outer step
*40339 PUSH BC       ;
 40340 PUSH DE       ;
 40341 LD A,(HL)     ; read ROM byte
 40342 INC HL        ; advance data pointer
 40343 AND 16        ; isolate bit 4 (EAR/MIC output)
 40345 OUT (254),A   ; toggle beeper
*40347 DEC D         ; delay loop
 40348 JR NZ,40347   ;
 40350 POP DE        ;
 40351 POP BC        ;
 40352 DJNZ 40339    ; repeat 4 sub-iterations
 40354 POP BC        ;
 40355 DJNZ 40336    ; repeat 255 outer iterations
 40357 XOR A         ;
@nowarn=33699
@ssub=LD (SoundRequest),A
 40358 LD (33699),A  ; clear sound-request flag
 40361 RET           ;

; NoteTable
;
; 9 × 4-byte entries used by PlayNoteByIndex. Each entry feeds the ROM
; BEEP routine at $03B5: DE = note duration (number of cycles),
; HL = T-state half-period (frequency).
;
@label=NoteTable
b40362 DEFW 13,1706  ; note 0: dur=13, period=1706 T-states
 40366 DEFW 17,1268  ; note 1: dur=17, period=1268 T-states
 40370 DEFW 13,1602  ; note 2: dur=13, period=1602 T-states
 40374 DEFW 10,2157  ; note 3: dur=10, period=2157 T-states
 40378 DEFW 11,1914  ; note 4: dur=11, period=1914 T-states
 40382 DEFW 19,1124  ; note 5: dur=19, period=1124 T-states
 40386 DEFW 25,834  ; note 6: dur=25, period=834 T-states
 40390 DEFW 20,1061  ; note 7: dur=20, period=1061 T-states
 40394 DEFW 14,1423  ; note 8: dur=14, period=1423 T-states

; PhrasePairs
;
; 8 × 2-byte phrase pairs consumed by PlayMusicPhrase. Each pair is
; (note_A_index, note_B_index) into NoteTable; the two notes are played
; alternately 8 times to form a trill, then the next phrase starts.
;
@label=PhrasePairs
b40398 DEFB 0,5  ; phrase 0: notes 0,5
 40400 DEFB 0,5  ; phrase 1: notes 0,5
 40402 DEFB 1,6  ; phrase 2: notes 1,6
 40404 DEFB 1,6  ; phrase 3: notes 1,6
 40406 DEFB 2,7  ; phrase 4: notes 2,7
 40408 DEFB 2,7  ; phrase 5: notes 2,7
 40410 DEFB 3,8  ; phrase 6: notes 3,8
 40412 DEFB 4,1  ; phrase 7: notes 4,1

; NotePairScratch — 2 bytes of mutable state for the current note pair.
@label=NotePairScratch
b40414 DEFB 0,0
; PhraseStateScratch — 2 bytes of mutable state used by PlayMusicPhrase:
;     +0..+1 = current pointer into PhrasePairs
@ignoreua
@label=PhraseStateScratch
b40416 DEFB 0,0

; PlayNoteByIndex
;
; Plays one beeper note via the ZX Spectrum ROM BEEP routine at $03B5.
; Input: A = note index (0..8) into NoteTable at #R40362. Each table entry
; is 4 bytes: 2-byte duration (passed in DE) and 2-byte period in T-states
; (passed in HL). Used twice per inner iteration of PlayMusicPhrase.
;
@label=PlayNoteByIndex
c40418 ADD A,A       ; A *= 2
 40419 ADD A,A       ; A *= 2 (now A = index × 4 = byte offset)
 40420 LD E,A        ;
 40421 LD D,0        ; DE = byte offset
@nowarn=40362
@ssub=LD HL,NoteTable
 40423 LD HL,40362   ; HL → NoteTable base
 40426 ADD HL,DE     ; HL → 4-byte entry for note A
 40427 LD E,(HL)     ;
 40428 INC HL        ;
 40429 LD D,(HL)     ; DE = duration (cycles)
 40430 INC HL        ;
 40431 LD A,(HL)     ;
 40432 INC HL        ;
 40433 LD H,(HL)     ;
 40434 LD L,A        ; HL = T-state period
 40435 CALL 949      ; ROM BEEP at $03B5 — play tone
 40438 RET           ;

; PlayMusicPhrase
;
; Plays the title-screen jingle: 8 successive 2-note phrases drawn from
; the phrase table at #R40398 (PhrasePairs). Each phrase byte is a (loA,
; hiB) pair selecting two notes from NoteTable at #R40362 (PlayNoteByIndex).
; The inner loop repeats each pair 8 times (so the phrase audibly trills
; on its 2-note interval), and the keyboard rows are polled between
; notes — any key press aborts playback via Auto_9E33.
;
; Used by the routine at #R42581 (DrawIntroScreen).
