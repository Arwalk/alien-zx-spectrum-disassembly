 32860 CALL 31612    ;
 32863 LD A,23       ; cell 10 white-on-red (Get Item),
 32865 LD C,1        ;
 32867 CALL 31612    ;
 32870 LD A,48       ; cell 11 yellow paper (Leave Item),
 32872 LD C,1        ;
 32874 CALL 31612    ;
 32877 LD A,31       ; cells 12-16 white-on-magenta
