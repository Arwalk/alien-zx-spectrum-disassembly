 39842 LD A,(39750)  ; A = JonesPos (pixel Y offset 0-135)
 39845 RRA           ;
 39846 RRA           ;
 39847 RRA           ; A = JonesPos >> 3 (character row 0-16)
 39848 AND 31        ;
 39850 LD E,A        ;
 39851 LD D,0        ; DE = char row index
 39853 LD HL,19488   ; HL = $4C00+1 (display col 1, char-row 0)
