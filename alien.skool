 38564 JR NZ,38575   ; yes: squirt
 38566 LD HL,(31241) ; empty: L = the viewed crew member,
 38569 LD A,6        ; msg #6 "{actor}'s extinguisher is empty"
 38571 CALL 37176    ;
 38574 RET           ;

; FightFireSquirt
