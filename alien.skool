; KeyboardScanner
;
; Reads the keyboard half-rows used by the game and packs the active
; directional / fire keys into #R33682. Bit 4 = fire/action, bit 3 = right
; (key 8), bit 2 = left (key 5), bit 1 = up (key 6), bit 0 = down (key 7).
; Used by the routine at #R34684 (HandleInput).
;
@ignoreua
@label=KeyboardScanner
c34636 CALL 34640    ; scan into AlienFlags
 34639 RET           ;
@nowarn=33682
@ssub=LD HL,AlienFlags
*34640 LD HL,33682   ; HL points to AlienFlags
 34643 LD (HL),0     ;
 34645 LD BC,63486   ;
 34648 IN A,(C)      ;
 34650 LD B,239      ;
*34652 BIT 4,A       ;
 34654 JR NZ,34658   ;
 34656 SET 1,(HL)    ;
*34658 IN A,(C)      ;
 34660 BIT 2,A       ;
 34662 JR NZ,34666   ;
 34664 SET 0,(HL)    ;
*34666 BIT 3,A       ;
 34668 JR NZ,34672   ;
 34670 SET 2,(HL)    ;
*34672 BIT 4,A       ;
 34674 JR NZ,34678   ;
 34676 SET 3,(HL)    ;
*34678 BIT 0,A       ;
 34680 RET NZ        ;
 34681 SET 4,(HL)    ;
 34683 RET           ;
@ignoreua

; HandleInput
;
; Reads the keyboard and moves the selected crew member. Calls the key-scanner
; at #R34636 which packs five keys into #R33642: bit 4 = fire/action, bit 3 =
; move right (key 8), bit 2 = move left (key 5), bits 1-0 = up/down (keys
; 6/7). If the action key (bit 4) is held, enters a beeper loop toggling port
; $FE until released. Otherwise dispatches movement: right → #R34743 (move
; forward along corridor), left → #R34788 (move backward), up/down move the
; crew between parallel corridor rows.
;
; Used by the routine at #R36457.
@label=HandleInput
@ignoreua
c34684 CALL 34636    ; scan keyboard → #R33642 bitmask
@nowarn=33682
@ssub=LD A,(AlienFlags)
@ignoreua
 34687 LD A,(33682)  ; A = key bitmask (#R33642)
 34690 AND A         ; any key pressed?
 34691 RET Z         ; no: return immediately
 34692 BIT 4,A       ; action/fire key held?
 34694 JR Z,34716    ; no: check directional keys
 34696 XOR A         ; A = 0 (border black)
*34697 EX AF,AF'     ; save border colour to A'
 34698 CALL 34636    ; re-scan keyboard (wait for release)
@nowarn=33682
@ssub=LD A,(AlienFlags)
 34701 LD A,(33682)  ; read updated key state
 34704 BIT 4,A       ; action key still held?
 34706 JP Z,34840    ; released: return to caller
 34709 EX AF,AF'     ; restore A' border colour
 34710 XOR 6         ; toggle between 0 (black) and 6 (yellow)
 34712 OUT (254),A   ; flash border
 34714 JR 34697      ; repeat until key released
*34716 BIT 3,A       ; move-right key (key 8)?
 34718 JR NZ,34743   ; yes: move crew forward along corridor
 34720 BIT 2,A       ; move-left key (key 5)?
*34722 JR NZ,34788   ; yes: move crew backward along corridor
 34724 AND 3         ; up (bit 1) or down (bit 0) key?
*34726 RET Z         ; no directional key: return
@ignoreua
 34727 LD A,(31252)  ; A = room mode (#R31252)
 34730 AND A         ; mode 0 = single-row corridor (no up/down)
 34731 RET Z         ; in single-row mode: up/down keys ignored
@ignoreua
*34732 LD A,(33685)  ; A = crew column position ($836D)
 34735 CP 61         ; column 61 = leftmost valid position
 34737 RET Z         ; at left wall: cannot move
 34738 CALL 34743    ; move one step (shares forward-move code)
 34741 JR 34732      ; keep moving while at edge
; This entry point is used by the routines at #R35578, #R36859 and #R37490.
