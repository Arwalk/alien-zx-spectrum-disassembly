; RoomHandlerCommon
;
; Standard corridor room handler for rooms 6-12. Saves the current corridor
; cursor (#R33683) to #R31241, sets up 17 corridor segments (positions 0-16)
; starting at position 61, draws the corridor using #R31721, then checks
; IX+7 (alive flag of the crew member assigned to this room). If the crew
; member is dead (IX+7=0), jumps to #R31417 to redraw the view. If the alien
; is active (#R33736 non-zero) and its target corridor matches the saved cursor,
; calls the alien-in-room handler #R32719.
;
@nowarn=33683
@label=RoomHandlerCommon
@ssub=LD A,(CorridorCursor)
@ignoreua
c35163 LD A,(33683)  ; A = corridor cursor (#R33683)
@ignoreua
 35166 LD (31241),A  ; save as room-entry position (#R31241)
 35169 LD A,17       ; 17 segments in a standard corridor
@nowarn=33683
@ssub=LD (CorridorCursor),A
 35171 LD (33683),A  ; set segment counter
 35174 LD A,61       ; starting position = 61 (leftmost)
@ignoreua
 35176 LD (33685),A  ; store starting corridor position ($836D)
 35179 CALL 31721    ; draw all corridor segments
 35182 XOR A         ; A = 0
 35183 CP (IX+7)     ; is crew member alive? (IX+7 = alive flag)
 35186 JP NZ,31417   ; crew dead: reinit view
@nowarn=33704
@ssub=LD A,(AlienActiveFlag)
@ignoreua
 35189 LD A,(33704)  ; A = alien active flag (#R33736)
 35192 AND A         ; alien present?
 35193 JP Z,32719    ; no alien: draw room contents
@nowarn=33703
@ssub=LD HL,AlienTargetID
@ignoreua
 35196 LD HL,33703   ; HL = alien target corridor ($83C7)
 35199 LD A,(31241)  ; A = saved entry cursor
 35202 CP (HL)       ; alien on this room's corridor?
 35203 JP Z,31417    ; yes: alien blocks entry, redraw
 35206 CALL 32719    ; draw room contents (crew sprites etc.)
 35209 RET           ;

