 38456 CALL 37176    ;
 38459 LD A,72       ; cells 15/16 := armed lever sprites 72/73
 38461 LD (29645),A  ;
 38464 LD HL,20502   ; redraw both rows
 38467 LD (31257),HL ; (screen rows 16/17, col 22)
 38470 CALL 31634    ;
 38473 LD A,73       ;
 38475 LD (29646),A  ;
 38478 CALL 31634    ;
 38481 JR 38510      ;

