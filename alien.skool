; PauseMenu
;
; Pause screen overlay shown when the player presses key 1 during gameplay.
; Draws two lines of text (pause message and restart prompt) over the game
; screen using the tile-blit helper at #R44509. Sets the border to yellow (6)
; and waits for the player to press key 1 again. If key 1 is pressed, jumps
; directly to #R36457 (GameEntry) to restart the game. Any other key resumes
; play by returning normally. If the corridor view was active (mode=1), calls
; #R32719 to restore the room display before returning.
;
; Used by the routine at #R36457.
@label=PauseMenu
c44815 CALL 33479    ; draw game-window border
@ignoreua
 44818 LD HL,20614   ; HL = $5086 (mid-screen attribute row)
 44821 LD (31257),HL ; set draw pointer
 44824 LD B,20       ; 20-character message line
; This entry point is used by the routine at #R44561.
@nowarn=44770
@ssub=LD DE,Auto_AEE2
*44826 LD DE,44770   ; DE = text data for pause message line 1
 44829 CALL 44509    ; blit text
 44832 LD HL,20675   ; next screen row
 44835 LD (31257),HL ;
 44838 LD B,25       ; 25-character second line
@nowarn=44790
@ssub=LD DE,Auto_AEF6
 44840 LD DE,44790   ; text data for "PRESS 1 TO RESTART" line
 44843 CALL 44509    ; blit text
 44846 CALL 44109    ; short wait (debounce key release)
; This entry point is used by the routine at #R44561.
*44849 LD A,6        ; 6 = yellow border
 44851 OUT (254),A   ; flash border yellow (indicates pause)
 44853 CALL 44093    ; wait loop (keyboard debounce / delay)
@ignoreua
 44856 LD BC,63486   ; BC = $F7FE: keyboard row for keys 1-5
 44859 IN A,(C)      ; read keyboard
; This entry point is used by the routine at #R44561.
*44861 RRA           ; bit 0 → carry (key 1 = active-low)
 44862 JP NC,36457   ; key 1 held: restart game from entry
 44865 XOR A         ; A = 0
 44866 OUT (254),A   ; restore border to black
 44868 CALL 33479    ; redraw game-window frame
@ignoreua
 44871 LD A,(31252)  ; A = room mode (#R31252)
; This entry point is used by the routine at #R44561.
*44874 CP 1          ; mode 1 = corridor view active
; This entry point is used by the routine at #R44561.
*44876 CALL Z,32719  ; if in corridor: redraw room contents
 44879 RET           ; resume game loop

; PlayMusic
;
; Plays a background music phrase through the ZX Spectrum beeper. Reads the
; music-active flag at #R33737. If zero, falls through to the standard frame-
; timing wait at #R36448 and returns. Otherwise plays a descending sequence of
; tones: reads 32 consecutive ROM bytes from $0200 and for each byte toggles
; bit 4 of port $FE (beeper output), with a delay of C counts between
; toggles. After each 32-byte block, decrements C by 8 to raise the pitch,
; producing a descending arpeggio effect. Runs until C underflows (B=255
; exhausted), then returns.
;
; Used by the routines at #R36457 and #R42821.
@nowarn=33705
@label=PlayMusic
@ssub=LD A,(Auto_83A9)
@ignoreua
c44880 LD A,(33705)  ; A = music-active flag (#R33737)
 44883 AND A         ; music enabled?
 44884 JP Z,36448    ; no: standard frame-timing wait and return
 44887 LD HL,512     ; HL = $0200 (ROM data used as tone source)
 44890 LD BC,2176    ; B=8 (8 pitch steps), C=$88 (initial delay = 136)
*44893 PUSH BC       ; save pitch counter
 44894 LD B,32       ; 32 bytes (ROM data) per pitch step
*44896 LD A,(HL)     ; read ROM byte
 44897 AND 16        ; isolate bit 4 (beeper toggle bit)
 44899 OUT (254),A   ; output to port $FE (beeper + border)
 44901 INC HL        ; advance ROM pointer
 44902 LD A,C        ; A = current delay count
*44903 DEC A         ; count down delay
 44904 JR NZ,44903   ; busy-wait
 44906 DJNZ 44896    ; next ROM byte in this pitch step
 44908 LD B,255      ; inter-note gap: 255 NOP-equivalent iterations
*44910 DJNZ 44910    ; wait
 44912 POP BC        ; restore pitch counter
 44913 LD A,C        ; A = current delay value
 44914 SUB 8         ; reduce delay → raise pitch
 44916 LD C,A        ; store updated delay
 44917 DJNZ 44893    ;
 44919 XOR A         ;
