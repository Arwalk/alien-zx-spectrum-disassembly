@ignoreua
; TriggerAlienEvent
;
; Per-frame guard: when the alien's current corridor index is >= 6 AND
; the alien-target crew id is < 8 AND the targeted crew member is dead
; (alive flag at offset 7 of the crew record is zero), fire a "hatch"
; event by setting the alien-source byte to 255 and jumping to the
; alien-event dispatcher at #R45732. Otherwise simply returns.
;
; Used by the routine at #R36457.
@label=TriggerAlienEvent
c41264 LD HL,29570   ; HL → alien's current corridor index
 41267 LD A,(HL)     ; A = corridor
 41268 CP 6          ; corridor 0-5 = pre-alien spawn area
 41270 RET C         ; below 6: alien not yet active here
@nowarn=33703
@ssub=LD A,(AlienTargetID)
 41271 LD A,(33703)  ; A = AlienTargetID (crew ID being targeted)
 41274 CP 8          ; crew IDs are 0..6; 8+ = none/invalid
 41276 RET NC        ; no valid target: nothing to do
 41277 LD HL,(33701) ; HL = pointer to current crew record (Auto_83A5)
 41280 LD DE,7       ; offset 7 = alive flag
 41283 ADD HL,DE     ;
 41284 XOR A         ;
 41285 CP (HL)       ;
 41286 RET NZ        ;
 41287 LD A,255      ;
 41289 JP 45732      ;
 41292 RET           ;
@nowarn=33682
@ssub=LD HL,AlienFlags
 41293 LD HL,33682   ;
 41296 LD (HL),0     ;
 41298 LD BC,31      ;
 41301 IN A,(C)      ;
 41303 BIT 2,A       ;
 41305 JR Z,41309    ;
 41307 SET 3,(HL)    ;
