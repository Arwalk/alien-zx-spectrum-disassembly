 44685 INC C         ;
 44686 DJNZ 44663    ;
 44688 EX AF,AF'     ; RatingScore += the total
 44689 LD C,A        ;
@nowarn=40503
@ssub=LD A,(RatingScore)
 44690 LD A,(40503)  ;
 44693 ADD A,C       ;
@nowarn=40503
@ssub=LD (RatingScore),A
 44694 LD (40503),A  ;
 44697 RET           ;

