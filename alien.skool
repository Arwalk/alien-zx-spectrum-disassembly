 39575 LD A,L        ;
 39576 CP 48         ;
 39578 JR NZ,39601   ;
 39580 LD A,H        ;
 39581 CP 53         ;
 39583 JR NZ,39601   ;
@nowarn=38376
@ssub=LD HL,(OxygenLo)
 39585 LD HL,(38376) ; ...and low digits = "00"?
 39588 LD A,48       ;
 39590 CP L          ;
 39591 JR NZ,39601   ;
 39593 CP H          ;
 39594 JR NZ,39601   ;
 39596 LD A,26       ; msg #26 "Oxygen status CRITICAL"
 39598 CALL 37176    ;
@label=ClockPanelUpdate
*39601 LD A,(38373)  ; did the borrow ripple past the
 39604 CP 32         ; digits (oxygen fully exhausted)?
 39606 JP NZ,44277   ; yes: Endgame_OxygenOut
 39609 LD A,(31252)  ; no status line over the
 39612 CP 2          ; Indicate Location list
 39614 RET Z         ; (modes 2/3)
 39615 CP 3          ;
 39617 RET Z         ;
 39618 LD HL,20598   ; draw at screen row 19, col 22:
 39621 LD (31257),HL ;
@nowarn=38368
@ssub=LD DE,OxygenText
 39624 LD DE,38368   ; "TOOH: nnnn" — unless the
 39627 LD HL,31253   ; self-destruct is armed:
 39630 BIT 0,(HL)    ;
 39632 JR Z,39637    ;
@nowarn=38358
@ssub=LD DE,DestructTimeText
 39634 LD DE,38358   ; then "TIME: m:ss"
@label=ClockDraw10
*39637 LD B,10       ; blit the 10 characters
@label=ClockDrawLoop
*39639 PUSH BC       ;
