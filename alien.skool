; UpdateAlien
@ignoreua
;
; Moves the alien and attacks reachable crew. Returns immediately if the alien
; is inactive (flag at #R33736 = 0) or if the alien's current target crew
; record (pointer at $83A5) shows the crew member is already dead (byte 0 of
; record non-zero means busy/alive). Otherwise checks whether the crew members
; stored at #R33696 and #R33697 (nearest crew IDs) are still alive by looking up
; their alive flags in the crew table at $73BD. If neither is alive, calls
; #R36717 (alien wander) and sets the alien to idle state. If at least one is
; reachable, calls #R37176 to move the alien toward the target and sets
; IX+3=7 (attack state), IX+0 to attack timer.
;
; Used by the routine at #R36457.
@nowarn=33704
@label=UpdateAlien
@ssub=LD A,(AlienActiveFlag)
@ignoreua
c40826 LD A,(33704)  ; A = alien-active flag (#R33736)
 40829 AND A         ; alien present on ship?
 40830 RET Z         ; no: nothing to do
@ignoreua
 40831 LD HL,(33701) ; HL = pointer to alien's target crew record ($83A5)
 40834 LD A,(HL)     ; read byte 0 of crew record (action state)
 40835 AND A         ; 0 = crew idle/available
 40836 RET NZ        ; crew is busy (not vulnerable): skip attack
 40837 LD DE,7       ; offset to alive flag within crew record
 40840 ADD HL,DE     ; HL → alive-flag byte of target crew
 40841 CP (HL)       ; alive flag = 0 means dead
 40842 RET NZ        ; crew still alive: don't attack yet
 40843 PUSH IX       ; save caller's IX
 40845 LD IX,(33701) ; IX = alien's current target crew record
 40849 LD (IX+0),80  ; set alien action state = 80 (attack)
@nowarn=33703
@ssub=LD A,(AlienTargetID)
 40853 LD A,(33703)  ; A = alien target corridor ID (#R33703)
@nowarn=33700
@ssub=LD (CrewIndex),A
 40856 LD (33700),A  ; store as alien current corridor (#R33700)
 40859 CALL 37876    ; update alien sprite position on screen
@nowarn=33696
@ssub=LD A,(Auto_83A0)
 40862 LD A,(33696)  ; A = nearest crew ID 1 (#R33696)
 40865 CP 255        ; $FF = no crew in range
 40867 JR Z,40906    ; no primary target: wander
 40869 LD C,A        ; C = crew ID
 40870 ADD A,A       ; A × 8 (crew record size)
 40871 ADD A,A       ;
 40872 ADD A,A       ;
 40873 LD E,A        ;
 40874 LD D,0        ;
@ignoreua
 40876 LD HL,29573   ; HL = crew table base ($73BD)
 40879 ADD HL,DE     ; index to crew record's alive flag
 40880 XOR A         ;
 40881 CP (HL)       ; alive = 0 → dead
 40882 JR Z,40920    ; crew 1 alive: attack it
@nowarn=33697
@ssub=LD A,(Auto_83A1)
 40884 LD A,(33697)  ; A = nearest crew ID 2 (#R33697)
 40887 CP 255        ;
 40889 JR Z,40906    ; no secondary target either: wander
 40891 LD C,A        ;
 40892 ADD A,A       ;
 40893 ADD A,A       ;
 40894 ADD A,A       ;
 40895 LD E,A        ;
 40896 LD D,0        ;
 40898 LD HL,29573   ; crew table base
 40901 ADD HL,DE     ;
 40902 XOR A         ;
 40903 CP (HL)       ; crew 2 alive?
 40904 JR Z,40920    ; yes: attack crew 2
*40906 CALL 36717    ; no reachable crew: alien wanders
 40909 LD (IX+3),1   ; set alien state = 1 (idle/wander)
 40913 LD (IX+0),60  ; set alien timer = 60 frames
 40917 POP IX        ;
 40919 RET           ;
*40920 LD H,C        ; H = target crew ID
@nowarn=33703
@ssub=LD A,(AlienTargetID)
 40921 LD A,(33703)  ; A = alien corridor
 40924 LD L,A        ; L = alien corridor position
 40925 LD A,30       ; move distance = 30
 40927 CALL 37176    ; move alien toward crew member
 40930 LD (IX+3),7   ;
 40934 LD (IX+0),40  ;
 40938 POP IX        ;
 40940 RET           ;
