 42535 JR NZ,42569   ;
 42537 JR NZ,42571   ;
 42539 JR NZ,42573   ;
@label=Auto_A62D
 42541 LD C,D        ;
 42542 LD L,A        ;
 42543 LD L,B        ;
 42544 LD L,(HL)     ;
@label=Auto_A631
 42545 LD C,B        ;
 42546 LD H,L        ;
