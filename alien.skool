; PauseMenu
;
; Pause screen overlay shown when the player presses key 1 during gameplay.
; Draws two lines of text (pause message and restart prompt) over the game
; screen using the tile-blit helper at #R44509. Sets the border to yellow (6)
; and waits for the player to press key 1 again. If key 1 is pressed, jumps
; directly to #R36457 (GameEntry) to restart the game. Any other key resumes
; play by returning normally. If the corridor view was active (mode=1), calls
; #R32719 to restore the room display before returning.
;
; Used by the routine at #R36457.
@label=PauseMenu
c44815 CALL 33479    ; draw game-window border
@ignoreua
 44818 LD HL,20614   ; HL = $5086 (mid-screen attribute row)
 44821 LD (31257),HL ; set draw pointer
 44824 LD B,20       ; 20-character message line
; This entry point is used by the routine at #R44561.
@nowarn=44770
@ssub=LD DE,Auto_AEE2
*44826 LD DE,44770   ; DE = text data for pause message line 1
 44829 CALL 44509    ; blit text
 44832 LD HL,20675   ; next screen row
 44835 LD (31257),HL ;
 44838 LD B,25       ; 25-character second line
@nowarn=44790
@ssub=LD DE,Auto_AEF6
 44840 LD DE,44790   ; text data for "PRESS 1 TO RESTART" line
 44843 CALL 44509    ; blit text
 44846 CALL 44109    ; short wait (debounce key release)
; This entry point is used by the routine at #R44561.
*44849 LD A,6        ; 6 = yellow border
 44851 OUT (254),A   ; flash border yellow (indicates pause)
 44853 CALL 44093    ; wait loop (keyboard debounce / delay)
@ignoreua
