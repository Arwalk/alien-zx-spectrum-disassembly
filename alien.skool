; AlienInitTable
@ignoreua
;
; 16-byte lookup table indexed by a ROM-script nibble (0-15) inside
; CommonGameInit (#R42380). The looked-up value is ORed with $40
; (direction flag, bit 6) and written to $737F (the alien slot's
; identity/heading byte), randomising the alien's starting attributes.
@label=AlienInitTable
b41358 DEFB 3,4,5,9,10,11,13,14,18,19,20,20,22,24,25,30

; LongGameHostSlotTable
@ignoreua
;
; 16-byte lookup table indexed by a ROM-script nibble (0-15) inside
; LongGameInit (#R42276). Selects which 8-byte record slot at #R29566
; will be the **chestburster host** for this run — i.e. the crew
; member whose name will be substituted into the opening status-bar
; message #33 "Alien has hatched from {actor}" enqueued at #R42362.
; The chosen slot has byte +1 and byte +7 overwritten with $FF (the
; HostMarker pattern); that tag is what every "skip this slot during
; normal corridor processing" check keys off (e.g. `CP 255` on byte +1
; at #R31739 inside SelectSlotByDrawIdx). Values are restricted to
; {1, 2, 5} so the host is always one of the alien-area slot 1 or the
; crew slots 2 / 5.
@label=LongGameHostSlotTable
b41374 DEFB 1,2,5,1,2,5,1,2,5,1,2,5,1,2,5,2

; LongGameTargetTable
@ignoreua
;
; 16-byte lookup table indexed by a ROM-script nibble (0-15) inside
; LongGameInit (#R42276). Used to randomise #R33703 (AlienTargetID): the
; selector loops until it picks a value different from the host slot
; chosen via #R41374 (LongGameHostSlotTable), then stores the value
; in AlienTargetID and uses it to compute the targeted crew's record
; pointer at #R33701. Values are restricted to {1, 2, 4, 6} = the four
; crew slots {Dallas, Kane, Ash, Parker}, always different from the
; chestburster host slot.
;
; This selection is the long-game **Android assignment**. The chosen
; crew member behaves like a normal crew member at first; UpdateAlien
; (#R40826) activates them as hostile the first time the alien is
; loose AND their slot is still in template state (i.e. they haven't
; been activated or defeated yet). After activation they enter action
; state 7 and wound their sprite-class kin via CrewAction7_Handler
; (#R40757). Status-bar messages #30 / #32 name that slot.
;
; The four candidate slots correspond to the canonical hatch-victim
; (Kane = 2) plus three crew the alien can plausibly puppet (Dallas /
; Ash / Parker). Note Ash (slot 4) — the canonical film android — is
; one of the four but the pick is random per run.
@label=LongGameTargetTable
b41390 DEFB 1,2,4,6,1,2,4,6,1,2,4,6,1,2,4,6

; CommonInit_AnimTable
;
; 22 bytes copied wholesale by CommonGameInit (#R42397) to $7504
; ($7434) — corridor / animation state for the new game session. The
; final two bytes are $FF sentinels.
@label=CommonInit_AnimTable
b41406 DEFB 24,21,20,6,6,16,3,16,24,17,18,19,32,2,2,2
 41422 DEFB 24,23,31,20,255,255

; CommonInit_WorkspaceTable
;
; 16 bytes copied by CommonGameInit (#R42454) to #R33746 ($83D2): zeros
; the Auto_83D2 area then writes 3,3,3,3,1,8,8,8 into Auto_83DA.
@label=CommonInit_WorkspaceTable
b41428 DEFB 0,0,0,0,0,0,0,0,3,3,3,3,1,8,8,8

; LongGameCrewInit
@ignoreua
;
; 64-byte starting state (eight 8-byte records) copied by LongGameInit
; (#R42276) into $7376-$73B5. Layout, with #R29566 ($7376) as record 0:
;
;   slot 0 ($7376): alien-slot header (all zero)
;   slot 1 ($737E): alien gameplay slot proper
;   slot 2 ($7386): crew[0]    \
;   slot 3 ($738E): crew[1]     |
;   slot 4 ($7396): crew[2]     |  Initial state for the 6 crew that
;   slot 5 ($739E): crew[3]     |  share the 64-byte block. crew[6] at
;   slot 6 ($73A6): crew[4]     |  $73B6 is initialised separately.
;   slot 7 ($73AE): crew[5]    /
;
; Per-record byte layout (offsets inside each 8-byte record):
;   +0 reserved (zero in both templates)
;   +1 crew ID + direction flag (bit 6) — stamped to $FF by LongGameInit
;      on the slot chosen via LongGameHostSlotTable (the HostMarker)
;   +2 corridor position (0 = unplaced)
;   +3 action state (0 = uninitialised)
;   +4 attribute / colour byte: 6 = white, $1B = bright magenta, 0 = N/A
;   +5 sprite X tile
;   +6 sprite Y tile
;   +7 alive flag — also stamped to $FF on the host slot
;
; All seven crew slots start with non-zero +4/+5/+6, so every crew
; member is alive and placed when a Long Game begins. LongGameInit's
; script-driven step at #R42313-#R42334 then marks one slot as the
; chestburster host — the only crew whose +1 and +7 will hold $FF
; after init.
@label=LongGameCrewInit
b41444 DEFB 0,0,0,0,0,0,0,0      ; slot 0: alien header
 41452 DEFB 0,6,0,0,6,4,4,0      ; slot 1: alien gameplay slot
 41460 DEFB 0,6,0,0,5,4,4,0      ; slot 2 (crew[0])
 41468 DEFB 0,6,0,0,4,3,3,0      ; slot 3 (crew[1])
 41476 DEFB 0,27,0,0,5,4,4,0     ; slot 4 (crew[2])  — attr $1B
 41484 DEFB 0,27,0,0,6,4,4,0     ; slot 5 (crew[3])  — attr $1B
 41492 DEFB 0,27,0,0,6,4,4,0     ; slot 6 (crew[4])  — attr $1B
 41500 DEFB 0,0,0,0,5,3,3,0      ; slot 7 (crew[5])

; ShortGameCrewInit
@ignoreua
;
; 64-byte starting state (eight 8-byte records) copied by ShortGameInit
; (#R44738) into $7376-$73B5. Same record layout as #R41444
; (LongGameCrewInit) — see that block for field semantics.
;
; Slot occupancy comparison (ShortGameCrewInit vs LongGameCrewInit):
;
;   slot 0 (alien header)  : both all-zero
;   slot 1 (alien gameplay): both placeholders, but Short has +1=$FF / +7=$FF
;   slot 2 (crew[0])       : Short has +1=$FF / +7=$FF (HostMarker)
;   slot 3 (crew[1])       : Short alive (+1=6, +4=4)
;   slot 4 (crew[2])       : Short has +1=$FF / +7=$FF (HostMarker)
;   slot 5 (crew[3])       : Short alive (+1=6, +4=4)
;   slot 6 (crew[4])       : Short alive (+1=6, +4=6)
;   slot 7 (crew[5])       : Short has +1=$FF / +7=$FF (HostMarker)
;
; The Short Game starts with FOUR slots already carrying the HostMarker
; pattern that the Long Game applies to exactly one random slot. The
; gameplay meaning of the marker here is "skip this slot in normal
; crew processing" (whatever that means for the abbreviated scenario);
; the marker doesn't literally mean four chestburster hosts. Combined
; with the fixed #R33703 AlienTargetID=9 (which the alien-target guard
; at #R41274 reads as "no valid target", so the alien never actively
; hunts), the Short Game has only three "normal" crew members and no
; alien-host subplot — whereas the Long Game uses script randomisation
; to pick a single chestburster host plus the alien's first target.
@label=ShortGameCrewInit
b41508 DEFB 0,0,0,0,0,0,0,0      ; slot 0: alien header
 41516 DEFB 0,255,0,0,0,0,0,255  ; slot 1: alien gameplay slot — tagged
 41524 DEFB 0,255,0,0,0,0,0,255  ; slot 2 (crew[0]) — tagged
 41532 DEFB 0,6,6,0,4,3,3,0      ; slot 3 (crew[1])
 41540 DEFB 0,255,0,0,0,0,0,255  ; slot 4 (crew[2]) — tagged
 41548 DEFB 0,6,6,0,4,3,3,0      ; slot 5 (crew[3])
 41556 DEFB 0,6,0,0,6,4,4,0      ; slot 6 (crew[4])
 41564 DEFB 0,255,0,0,0,0,0,255  ; slot 7 (crew[5]) — tagged
