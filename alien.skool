; ShortGameInit
@ignoreua
;
; Game-mode handler for "1: Short Game" (dispatched from #R43135).
; .
; The Short Game is the abbreviated scenario. Several slots in the
; starting template (#R41508 ShortGameCrewInit) are pre-stamped with the
; HostMarker pattern ($FF on bytes +1 and +7) and the alien's first
; target is hard-wired to crew ID 9 — a value the alien-targeting guard
; at #R41274 treats as "no valid target", so the alien's stalk-the-host
; logic is effectively disabled. No script-driven randomisation runs.
; Every Short Game opens from exactly the same configuration, which is
; what makes it shorter and more deterministic than the Long Game.
; .
; Steps:
;   1. Clear the two run-state bytes at #R33708 / #R33709.
;   2. Point the message queue head (MsgQueueWritePtr #R33741) at the queue
;      base MessageQueue (#R33714).
;   3. Hard-wire #R33703 (AlienTargetID) = 9 — disables alien hunt logic.
;   4. LDIR 64 bytes from #R41508 (ShortGameCrewInit) into $737E to populate
;      the alien slot and the seven crew slots with the short-game starting
;      state (four slots wear the HostMarker so they're skipped by normal
;      crew processing, leaving the alien header plus three active crew).
;   5. JP into the shared common init at #R42380 (CommonGameInit) — skipping
;      the Long Game's script-driven host selection and target picking.
; .
; Used by the dispatcher at #R43134 via the table at #R43135.
@label=ShortGameInit
c44738 XOR A         ; A = 0
@nowarn=33708
@ssub=LD (MsgDrawnCol),A
 44739 LD (33708),A  ; clear run-state byte #R33708
@nowarn=33709
@ssub=LD (MsgVisibleTimer),A
 44742 LD (33709),A  ; clear run-state byte #R33709
@nowarn=33714
@ssub=LD HL,MessageQueue
 44745 LD HL,33714   ; HL = MessageQueue (event queue base)
@nowarn=33741
@ssub=LD (MsgQueueWritePtr),HL
 44748 LD (33741),HL ; event queue head = queue base (empty queue)
@label=ShortGame_SetTarget
 44751 LD A,9        ; A = 9 (fixed Short Game alien target)
@nowarn=33703
@ssub=LD (AlienTargetID),A
 44753 LD (33703),A  ; AlienTargetID = 9 — no randomisation
@nowarn=41508
@ssub=LD HL,ShortGameCrewInit
@ignoreua
 44756 LD HL,41508   ; HL = ShortGameCrewInit ($A224)
@ignoreua
 44759 LD DE,29566   ; DE = $737E (alien slot + crew table base)
 44762 LD BC,64      ; 64 bytes = 8 × 8-byte records
 44765 LDIR          ; copy short-game starting crew/alien state
@label=ShortGameInit_Done
 44767 JP 42380      ; → CommonGameInit (skip Long Game randomisation)

