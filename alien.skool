; ScanInput — read the selected input device
@ignoreua
;
; Per-frame input shim: calls whichever device scanner OptionsScreen
; selected (the CALL operand at $874D is patched from the vector table
; at $A405) to pack the active directional / fire controls into
; #R33682. Bit 4 = fire/action, bit 3 = right (key 8), bit 2 = left
; (key 5), bit 1 = up (key 6), bit 0 = down (key 7).
; Used by the routine at #R34684 (HandleInput).
;
@ignoreua
@label=ScanInput
c34636 CALL 34640    ; scan into AlienFlags via the selected device's
@ignoreua
 34639 RET           ; scanner (the CALL operand at $874D is patched
                     ; from InputScannerTable by OptionsScreen)

; DefaultKeyScanner
@nowarn=33682
@ssub=LD HL,AlienFlags
@label=DefaultKeyScanner
c34640 LD HL,33682   ; HL points to AlienFlags
 34643 LD (HL),0     ; start from "no keys pressed"
@ignoreua
 34645 LD BC,63486   ; port $F7FE: half-row 1-5
 34648 IN A,(C)      ; read half-row 1-5
@ignoreua
 34650 LD B,239      ; next read: port $EFFE, half-row 6-0
 34652 BIT 4,A       ; key 5 pressed? (active low)
 34654 JR NZ,34658   ;
 34656 SET 1,(HL)    ; bit 1 = key 5
@label=KeyScan_LowRow
*34658 IN A,(C)      ; read half-row 6-0
 34660 BIT 2,A       ; key 8?
 34662 JR NZ,34666   ;
 34664 SET 0,(HL)    ; bit 0 = key 8
@label=KeyScan_Check7
*34666 BIT 3,A       ; key 7?
 34668 JR NZ,34672   ;
 34670 SET 2,(HL)    ; bit 2 = key 7
@label=KeyScan_Check6
*34672 BIT 4,A       ; key 6?
 34674 JR NZ,34678   ;
 34676 SET 3,(HL)    ; bit 3 = key 6
@label=KeyScan_Check0
*34678 BIT 0,A       ; key 0 (action)?
 34680 RET NZ        ; not pressed: done
 34681 SET 4,(HL)    ; bit 4 = action
 34683 RET           ;

; HandleInput
;
; Reads the keyboard and moves the corridor cursor. Calls the key-scanner
; at #R34636, which packs five keys into #R33682 (set bit = pressed):
; bit 0 = key 8, bit 1 = key 5, bit 2 = key 7, bit 3 = key 6, bit 4 =
; key 0 (action). While the action key is held the border flashes
; yellow/black; on RELEASE control jumps to #R34840, which dispatches
; through RoomDispatchTable (#R33794) on the current room mode
; (#R31252) — this is how a room's action handler / menu is opened.
; Otherwise: key 6 -> #R34743 (advance the cursor along the corridor),
; key 7 -> #R34788 (retreat), and keys 8/5 move between rows when the
; room view has more than one row (mode != 0).
; .
; Used by the routine at #R36457.
@label=HandleInput
@ignoreua
c34684 CALL 34636    ; scan keyboard → #R33642 bitmask
@nowarn=33682
@ssub=LD A,(AlienFlags)
@ignoreua
 34687 LD A,(33682)  ; A = key bitmask (#R33642)
 34690 AND A         ; any key pressed?
 34691 RET Z         ; no: return immediately
 34692 BIT 4,A       ; action/fire key held?
 34694 JR Z,34716    ; no: check directional keys
 34696 XOR A         ; A = 0 (border black)
@label=Input_FlashLoop
*34697 EX AF,AF'     ; save border colour to A'
 34698 CALL 34636    ; re-scan keyboard (wait for release)
@nowarn=33682
@ssub=LD A,(AlienFlags)
 34701 LD A,(33682)  ; read updated key state
 34704 BIT 4,A       ; action key still held?
 34706 JP Z,34840    ; released: open the room-action dispatch
 34709 EX AF,AF'     ; restore A' border colour
 34710 XOR 6         ; toggle between 0 (black) and 6 (yellow)
 34712 OUT (254),A   ; flash border
 34714 JR 34697      ; repeat until key released
@label=Input_Directional
*34716 BIT 3,A       ; key 6 (advance)?
 34718 JR NZ,34743   ; yes: advance cursor along the corridor
 34720 BIT 2,A       ; key 7 (retreat)?
 34722 JR NZ,34788   ; yes: retreat cursor along the corridor
 34724 AND 3         ; key 5 or key 8 (row movement)?
 34726 RET Z         ; no directional key: return
@ignoreua
 34727 LD A,(31252)  ; A = room mode (#R31252)
 34730 AND A         ; mode 0 = single-row corridor (no up/down)
 34731 RET Z         ; in single-row mode: up/down keys ignored
@ignoreua
@label=Input_RowMove
*34732 LD A,(33685)  ; A = cell value under the cursor ($8395)
 34735 CP 61         ; column 61 = leftmost valid position
 34737 RET Z         ; at left wall: cannot move
 34738 CALL 34743    ; move one step (shares forward-move code)
 34741 JR 34732      ; keep moving while at edge

; AdvanceCursor
;
; Move the cursor one strip row forward (key 6), skipping cells that
; are not selectable; also holds the retreat handler (key 7) and the
; action-key dispatch. Cell values steer the movement: >= 82 is header
; text / empty padding (never a landing spot), 70-81 are two-row
; fixture labels whose second row must be stepped over.
; .
; Used by the routines at #R34684, #R35814, #R36859 and #R37493.
@label=AdvanceCursor
c34743 CALL 34859    ; remove the highlight from the current row
@nowarn=33683
@ssub=LD HL,CorridorCursor
 34746 LD HL,33683   ; HL -> cursor position
 34749 LD A,(33685)  ; A = cell value the cursor is leaving
 34752 CP 70         ; leaving a two-row fixture label?
 34754 JR C,34757    ;
 34756 INC (HL)      ; yes: step over its second row too
@nowarn=33683
@ssub=LD HL,CorridorCursor
@label=AdvCursor_Bounds
*34757 LD HL,33683   ;
 34760 LD A,(HL)     ; A = cursor position
 34761 CP 18         ; already on the last strip row?
 34763 JR C,34767    ;
 34765 LD A,255      ; yes: wrap so the INC restarts at row 0
@label=AdvCursor_Store
*34767 INC A         ; step forward one row
 34768 LD (HL),A     ;
 34769 LD D,0        ;
 34771 LD E,A        ;
 34772 LD HL,29630   ; index CorridorPosTable by the new position
 34775 ADD HL,DE     ;
 34776 LD A,(HL)     ; A = the cell value there
 34777 CP 82         ; header text / empty padding?
 34779 JR NC,34757   ; yes: not selectable, keep stepping
 34781 CALL 34882    ; highlight the new row, mirror its cell value
 34784 CALL 34933    ; re-place the blinking box if it is a room row
 34787 RET           ;
@label=Input_RetreatCursor
*34788 CALL 34859    ; remove the highlight from the current row
@nowarn=33683
@ssub=LD A,(CorridorCursor)
@label=Retreat_Step
*34791 LD A,(33683)  ; A = cursor position
 34794 AND A         ; at the top row (0)?
 34795 JR NZ,34799   ;
 34797 LD A,19       ; yes: wrap so the DEC restarts at row 18
@label=Retreat_Wrap
*34799 DEC A         ; step back one row
@nowarn=33683
@ssub=LD (CorridorCursor),A
 34800 LD (33683),A  ;
 34803 LD D,0        ;
 34805 LD E,A        ;
 34806 LD HL,29630   ; index CorridorPosTable by the new position
 34809 ADD HL,DE     ;
 34810 LD A,(HL)     ; A = the cell value there
 34811 CP 82         ; header text / empty padding?
 34813 JR NC,34791   ; yes: not selectable, keep stepping
 34815 CP 70         ; a two-row fixture label?
 34817 JR C,34833    ; no: done
 34819 DEC HL        ; peek at the cell one row up
 34820 LD A,(HL)     ;
 34821 CP 70         ; is it also part of a two-row label?
 34823 JR C,34833    ; no: we are already on the first row
 34825 CP 82         ;
 34827 JR NC,34833   ;
@nowarn=33683
@ssub=LD HL,CorridorCursor
 34829 LD HL,33683   ; we landed on the label's second row:
 34832 DEC (HL)      ; back up onto its first row
@label=Retreat_Done
*34833 CALL 34882    ; highlight the new row, mirror its cell value
 34836 CALL 34933    ; re-place the blinking box if it is a room row
 34839 RET           ;
@label=Input_ActionRelease
*34840 XOR A         ; action key released:
 34841 OUT (254),A   ; restore black border
 34843 LD HL,33794   ; RoomDispatchTable
 34846 LD A,(31252)  ; A = current room mode
 34849 LD E,A        ;
 34850 LD D,0        ;
 34852 ADD HL,DE     ;
 34853 ADD HL,DE     ; HL = table + mode*2
 34854 LD A,(HL)     ; fetch the handler address
 34855 INC HL        ;
 34856 LD H,(HL)     ;
 34857 LD L,A        ;
 34858 JP (HL)       ; jump to the room's action handler

; UnhighlightMenuRow
;
; Undo the cursor highlight — restore the saved
; attribute (SavedRowAttr) on the row under the cursor; two rows when
; the cell value is >= 70 (first word of a two-row label).
@nowarn=33683
@label=UnhighlightMenuRow
@ssub=LD A,(CorridorCursor)
c34859 LD A,(33683)  ; A = cursor row
 34862 CALL 34920    ; HL = its attribute address
 34865 LD A,(33685)  ; cell value >= 70 (two-row label)?
 34868 LD C,1        ; C = number of rows to repaint
 34870 CP 70         ;
 34872 JR C,34875    ;
 34874 INC C         ; yes: restore two rows
@label=UnhighlightMenuRow_Restore
*34875 LD A,(33684)  ; repaint the saved attribute
 34878 CALL 31612    ; FillAttrColumn over C rows
 34881 RET           ;

; HighlightMenuRow
@ignoreua
;
; Used by the routines at #R31577, #R32816, #R34743, #R35290 and #R35638.
; .
; Mirror the CorridorPosTable cell under the cursor
; into CursorCellValue ($8395), save the attribute under the cursor
; row into SavedRowAttr, then paint the row bright white (attr 120) —
; two rows when the cell value is >= 70 (two-row label).
@nowarn=33683
@label=HighlightMenuRow
@ssub=LD A,(CorridorCursor)
c34882 LD A,(33683)  ; A = cursor row
 34885 PUSH AF       ;
 34886 LD E,A        ;
 34887 LD D,0        ;
 34889 LD HL,29630   ; index CorridorPosTable by the row
 34892 ADD HL,DE     ;
 34893 LD A,(HL)     ; A = cell value under the cursor
 34894 LD (33685),A  ; mirror it for the dispatchers
 34897 EX AF,AF'     ; keep the cell value in A'
 34898 POP AF        ; A = cursor row again
 34899 CALL 34920    ; HL = the row's attribute address
 34902 LD A,(HL)     ;
 34903 LD (33684),A  ; save the attribute for the un-highlight
 34906 EX AF,AF'     ; cell value >= 70 (two-row label)?
 34907 LD C,1        ; C = number of rows to paint
 34909 CP 70         ;
 34911 JR C,34914    ;
 34913 INC C         ; yes: highlight two rows
@label=HighlightMenuRow_Paint
*34914 LD A,120      ; bright white paper, black ink
 34916 CALL 31612    ; FillAttrColumn over C rows
 34919 RET           ;

; GetMenuRowAttrAddr
@ignoreua
;
; HL = attribute address of menu row A — the strip
; rows sit on screen rows 1-19, columns 22-31, so row 0 -> $5836
; (22582) and each further row adds 32.
@label=GetMenuRowAttrAddr
c34920 LD HL,22582   ; attr addr of menu row 0 (screen row 1, col 22)
 34923 AND A         ; row 0?
 34924 RET Z         ; yes: HL is already right
 34925 LD DE,32      ; one attribute row per menu row
 34928 LD B,A        ; B = rows still to skip
@label=GetMenuRowAttrAddrLoop
*34929 ADD HL,DE     ; +32 per row
 34930 DJNZ 34929    ;
 34932 RET           ;

; UpdateRoomMarkerB
;
; Cursor-move hook, called from HandleInput's
; cursor handlers. Erases the blinking candidate-room box (marker
; channel B), then, in the room view only, re-places it if the row now
; under the cursor is a room (an exit row, value < 34) that lies on
; the deck currently shown in the map pane.
@label=UpdateRoomMarkerB
c34933 CALL 35146    ; erase/freeze marker channel B
 34936 LD A,(31252)  ; room view (mode 1)?
 34939 CP 1          ;
 34941 RET NZ        ; no: done
 34942 LD A,(33685)  ; cell under the cursor a room id?
 34945 CP 34         ; (rooms are 0-33)
 34947 RET NC        ; no: done
 34948 LD E,A        ;
 34949 LD D,0        ;
 34951 LD HL,29905   ; RoomTypeTable[room]
 34954 ADD HL,DE     ;
 34955 LD A,(31243)  ; on the deck currently displayed?
 34958 CP (HL)       ;
 34959 RET NZ        ; no: done
 34960 LD A,(33685)  ; yes: blink that room's indicator box
 34963 CALL 35128    ; via PlaceRoomMarkerB
 34966 RET           ;

; AnimateCrewA
;
; Animates marker channel A — the walking crew figure that marks the
; viewed room on the deck map (placed by PlaceRoomMarkerA #R35101).
; Skips if bit 7 of the animation-freeze flag at #R31263 is set.
; Decrements the frame counter at #R33739; when it reaches zero,
; resets the counter to 10 and XOR-blits two consecutive 3×12-byte sprite
; frames from the animation table at #R26853 (indexed by the frame phase in
; #R31263 bits 0-1) onto the display at the address stored in SprDestA
; (#R33686). Calling this routine twice per frame (once to erase, once to
; draw the next frame) produces flicker-free sprite animation via
; double-buffered XOR.
; .
; Used by the routines at #R36457, #R39718 and #R43242.
@label=AnimateCrewA
@ignoreua
c34967 LD A,(31263)  ; A = animation-freeze / frame-phase byte (#R31263)
 34970 BIT 7,A       ; bit 7 = freeze flag
 34972 RET NZ        ; frozen: skip animation this frame
@nowarn=33691
@ssub=LD HL,FrameCounterA
@ignoreua
 34973 LD HL,33691   ; HL = frame counter A (#R33739)
 34976 DEC (HL)      ; tick down counter
 34977 RET NZ        ; not expired: nothing to do
 34978 LD (HL),10    ; reset counter to 10 frames per phase
 34980 LD B,2        ; draw 2 sprite rows
; This entry point is used by the routines at #R35101 and #R43242.
@label=BlitMarkerA
*34982 PUSH BC       ; save row counter
 34983 LD E,A        ; E = frame phase (0-3)
 34984 LD D,0        ;
 34986 LD HL,26853   ; HL = base of crew-A animation table (#R26853)
 34989 ADD HL,DE     ; index by phase × 2
 34990 ADD HL,DE     ;
 34991 LD A,(HL)     ; read 16-bit sprite bitmap pointer
 34992 INC HL        ;
 34993 LD H,(HL)     ;
 34994 LD L,A        ; HL = pointer to 3-byte sprite row data
 34995 EX DE,HL      ; DE = sprite data source
@nowarn=33686
@ssub=LD HL,(SprDestA)
@ignoreua
 34996 LD HL,(33686) ; HL = screen destination address (#R33686)
 34999 CALL 35065    ; XOR-blit 3 bytes × 12 rows onto screen
 35002 POP BC        ; restore row counter
 35003 DEC B         ;
 35004 RET Z         ; done after 2 rows
 35005 LD A,(31263)  ; advance to next frame phase
 35008 INC A         ;
 35009 AND 3         ; wrap phase 0-3
 35011 LD (31263),A  ; store updated phase
 35014 JR 34982      ; blit second sprite row
@ignoreua

; AnimateCrewB
;
; Animates marker channel B — the blinking box cursor on a candidate
; room (placed by PlaceRoomMarkerB #R35128). Identical logic to
; #R34967 (AnimateCrewA) but uses a faster frame rate (counter resets to 5
; rather than 10), the B-set animation table at #R26861, and the
; B-channel screen address at SpriteDestAddr (#R33688). Cycles through four
; cursor shapes (RoomCursor0-3) at twice the speed of the crew walk
; animation.
; .
; Used by the routines at #R36457, #R39718 and #R43242.
@label=AnimateCrewB
c35016 LD A,(31264)  ; A = animation-freeze / frame-phase byte (#R31264)
 35019 BIT 7,A       ; bit 7 = freeze flag
 35021 RET NZ        ; frozen: skip
@nowarn=33690
@ssub=LD HL,FrameCounterB
@ignoreua
 35022 LD HL,33690   ; HL = frame counter B ($83CA)
 35025 DEC (HL)      ; tick down counter
 35026 RET NZ        ; not expired
 35027 LD (HL),5     ; reset to 5 frames per phase (2× speed of set A)
 35029 LD B,2        ; draw 2 sprite rows
; This entry point is used by the routines at #R35128, #R35146 and #R43242.
@label=BlitMarkerB
*35031 PUSH BC       ;
 35032 LD E,A        ; E = frame phase (0-3)
 35033 LD D,0        ;
 35035 LD HL,26861   ; base of crew-B animation table (#R26861)
 35038 ADD HL,DE     ; index by phase × 2
 35039 ADD HL,DE     ;
 35040 LD A,(HL)     ; read 16-bit sprite bitmap pointer
 35041 INC HL        ;
 35042 LD H,(HL)     ;
 35043 LD L,A        ; HL = pointer to sprite row data
 35044 EX DE,HL      ; DE = sprite data source
@nowarn=33688
@ssub=LD HL,(SpriteDestAddr)
@ignoreua
 35045 LD HL,(33688) ; HL = screen destination address (#R33688)
 35048 CALL 35065    ; XOR-blit 3 bytes × 12 rows onto screen
 35051 POP BC        ;
 35052 DEC B         ;
 35053 RET Z         ;
 35054 LD A,(31264)  ; advance frame phase
 35057 INC A         ;
 35058 AND 3         ; wrap 0-3
 35060 LD (31264),A  ;
 35063 JR 35031      ;

; XorBlitMarker
;
; Used by the routines at #R34967 and #R35016.
@label=XorBlitMarker
c35065 LD C,12       ;
@label=XorBlit_RowLoop
*35067 LD B,3        ;
@label=XorBlit_ByteLoop
*35069 LD A,(DE)     ;
 35070 XOR (HL)      ;
 35071 LD (HL),A     ;
 35072 INC HL        ;
 35073 INC DE        ;
 35074 DJNZ 35069    ;
 35076 DEC HL        ;
 35077 DEC HL        ;
 35078 DEC HL        ;
 35079 PUSH DE       ;
 35080 CALL 31393    ;
 35083 POP DE        ;
 35084 DEC C         ;
 35085 JR NZ,35067   ;
 35087 RET           ;

; GetRoomMarkerAddr
;
; A = room id (0-33) -> HL = display-file address
; of the room's indicator box on its deck map, from
; RoomMarkerAddrTable (#R26569).
@label=GetRoomMarkerAddr
c35088 ADD A,A       ;
 35089 LD D,0        ;
 35091 LD E,A        ;
 35092 LD HL,26569   ; RoomMarkerAddrTable + room*2
 35095 ADD HL,DE     ;
 35096 LD A,(HL)     ;
 35097 INC HL        ;
 35098 LD H,(HL)     ;
 35099 LD L,A        ; HL = the room's marker screen address
 35100 RET           ;

; PlaceRoomMarkerA
;
; Used by the routine at #R32719.
; .
; Aim marker channel A (the walking crew figure that
; marks the viewed room on the deck map) at the current room (#R31242)
; and draw its first frame; no marker on the Narcissus (deck type 3).
; Channel A then keeps animating via AnimateCrewA (#R34967).
@label=PlaceRoomMarkerA
c35101 LD A,(31243)  ; on the Narcissus (type 3)?
 35104 CP 3          ;
 35106 RET NC        ; yes: no marker
 35107 LD A,(31242)  ; A = the viewed room
 35110 CALL 35088    ;
@nowarn=33686
@ssub=LD (SprDestA),HL
 35113 LD (33686),HL ; channel A dest = its marker address
 35116 LD HL,31263   ;
 35119 RES 7,(HL)    ; unfreeze channel A
 35121 LD A,(HL)     ; A = current phase
 35122 LD B,1        ;
 35124 CALL 34982    ; XOR-blit one frame (place the box)
 35127 RET           ;

; PlaceRoomMarkerB
;
; Used by the routines at #R34933 and #R35338.
; .
; Aim marker channel B (the "candidate room"
; blinker) at room A and draw its first frame. Used for the exit row
; under the cursor in the room view (UpdateRoomMarkerB #R34933) and
; for a room picked from the Indicate Location list
; (LocationListAction #R35338). Channel B then keeps blinking via
; AnimateCrewB (#R35016).
@label=PlaceRoomMarkerB
c35128 CALL 35088    ; HL = marker address of room A
@nowarn=33688
@ssub=LD (SpriteDestAddr),HL
 35131 LD (33688),HL ; channel B dest = it
 35134 LD HL,31264   ;
 35137 RES 7,(HL)    ; unfreeze channel B
 35139 LD A,(HL)     ; A = current phase
 35140 LD B,1        ;
 35142 CALL 35031    ; XOR-blit one frame (place the box)
 35145 RET           ;

; EraseRoomMarkerB
;
; Used by the routine at #R34933.
; .
; If marker channel B is live, XOR-blit its current
; frame once more (which removes it from the screen) and freeze the
; channel.
@label=EraseRoomMarkerB
c35146 LD HL,31264   ;
 35149 BIT 7,(HL)    ; already frozen?
 35151 RET NZ        ; yes: nothing to erase
 35152 PUSH HL       ;
 35153 LD A,(HL)     ; A = current phase
 35154 LD B,1        ;
 35156 CALL 35031    ; XOR-blit once = erase
 35159 POP HL        ;
 35160 SET 7,(HL)    ; freeze the channel
 35162 RET           ;

; OpenCrewRoomView — orders-screen rows 1-7 (the crew names)
;
; Opens the room view for the crew member on the chosen row. The
; cursor row IS the actor slot number (1-7); it is saved as the
; selected slot (#R31241) for everything that follows (menu dispatch,
; action timers, the alien-presence check at #R45760). The menu
; cursor is parked on the action menu's QUIT row (17, value 61).
; SelectSlotByDrawIdx (#R31721) then points IX at the slot's
; ActorRecords entry and caches its current room (#R31242) and deck
; type (#R31243). Bails back to the orders screen (InitGameView) if
; the slot has been removed (IX+7 nonzero) or if the alien is loose
; and currently targeting this crew member (the encounter sequence
; owns the screen); otherwise builds the room view via
; RedrawRoomScene (#R32719).
;
@nowarn=33683
@label=OpenCrewRoomView
@ssub=LD A,(CorridorCursor)
@ignoreua
c35163 LD A,(33683)  ; A = cursor row = the actor slot picked (1-7)
@ignoreua
 35166 LD (31241),A  ; save as the selected slot (#R31241)
 35169 LD A,17       ;
@nowarn=33683
@ssub=LD (CorridorCursor),A
 35171 LD (33683),A  ; park the cursor on the QUIT row (17)
 35174 LD A,61       ;
@ignoreua
 35176 LD (33685),A  ; mirrored cell value = 61 "   QUIT   " ($8395)
 35179 CALL 31721    ; IX = slot record; cache its room + deck type
 35182 XOR A         ;
 35183 CP (IX+7)     ; slot removed (+7 nonzero)?
 35186 JP NZ,31417   ; yes: back to the orders screen
@nowarn=33704
@ssub=LD A,(AlienActiveFlag)
@ignoreua
 35189 LD A,(33704)  ; alien loose (#R33704)?
 35192 AND A         ;
 35193 JP Z,32719    ; no: build the room view
@nowarn=33703
@ssub=LD HL,AlienTargetID
@ignoreua
 35196 LD HL,33703   ; HL = alien's target slot ($83C7)
 35199 LD A,(31241)  ; targeting the crew member just picked?
 35202 CP (HL)       ;
 35203 JP Z,31417    ; yes: bounce back to the orders screen
 35206 CALL 32719    ; no: build the room view
 35209 RET           ;

; SelectDeckMap — orders-screen rows 12-14 ("Upper Deck"/"MiddleDeck"/
; "Lower Deck"): redraw the map pane to show that deck. The cursor row
; minus 12 is exactly the deck's layout type (0/1/2), which is stored
; as RoomTypeByte and handed to the map-pane drawer at #R31267.
@nowarn=33683
@label=SelectDeckMap
@ssub=LD A,(CorridorCursor)
c35210 LD A,(33683)  ; A = cursor row (12-14)
 35213 SUB 12        ; -> deck layout type 0-2
 35215 LD (31243),A  ; RoomTypeByte = chosen deck
 35218 CALL 31267    ; redraw the map pane for that deck
 35221 RET           ;

; IndicateLocation — orders-screen row 8 (" Indicate "/" Location ")
;
; Opens the room-location list: replaces the menu strip with a pageable
; list of room names. Page 1 (room mode 2, entered here) lists rooms
; 0-16; page 2 (room mode 3, entered at #R35228) lists rooms 17-33 —
; the Narcissus (34) is never listed. The 19 CorridorPosTable cells
; become: cell 0 = 62 "Other List" (switches to the other page),
; cells 1-17 = the seventeen room ids, cell 18 = 61 "   QUIT   "
; (returns to the orders screen). The cursor starts on QUIT. While the
; list is up, the action key dispatches straight to LocationListAction
; (#R35338) via RoomDispatchTable entries 2/3: picking a room draws its
; deck map in the map pane with the room's indicator box blinking on it
; (marker channel B).
; .
; Used by the routines at #R33794 and #R35338.
@label=IndicateLocation
c35222 LD A,2        ; room mode 2: page 1,
 35224 LD E,0        ; first room id 0
 35226 JR 35232      ;

; IndicateLocationPage2
;
; Used by the routine at #R35338.
@label=IndicateLocationPage2
c35228 LD A,3        ; room mode 3: page 2,
 35230 LD E,17       ; first room id 17
@label=BuildLocationList
*35232 LD (31252),A  ; set the room mode (2 or 3)
 35235 LD A,18       ;
@nowarn=33683
@ssub=LD (CorridorCursor),A
 35237 LD (33683),A  ; cursor to row 18 (the QUIT cell)
 35240 LD A,61       ;
 35242 LD (33685),A  ; mirrored cell value = 61 "   QUIT   "
 35245 LD HL,29630   ; fill CorridorPosTable:
 35248 LD (HL),62    ; cell 0 = 62 "Other List" (page toggle)
 35250 INC HL        ;
 35251 LD B,17       ;
@label=BuildLocationListLoop
*35253 LD (HL),E     ; cells 1-17 = room ids E..E+16
 35254 INC HL        ;
 35255 INC E         ;
 35256 DJNZ 35253    ;
 35258 LD (HL),61    ; cell 18 = 61 "   QUIT   "
 35260 LD HL,22582   ; colour the strip (attr rows 1-19, cols 22-31):
 35263 LD A,56       ;
 35265 LD C,1        ; "Other List" row: black ink on white
 35267 CALL 31612    ;
 35270 LD A,15       ;
 35272 LD C,17       ; the 17 room rows: white ink on blue
 35274 CALL 31612    ;
 35277 LD A,56       ;
 35279 LD C,1        ; QUIT row: black ink on white
 35281 CALL 31612    ;
 35284 LD HL,16406   ; draw pointer to row 0, column 22
 35287 LD (31257),HL ; (fall through to draw the list)

; DrawLocationList
;
; Renders the room-location list built above: the " Location " title on
; screen row 0, then the 19 CorridorPosTable cells (room names and the
; two control rows) on rows 1-19, and finally the cursor highlight via
; HighlightMenuRow (#R34882).
@label=DrawLocationList
c35290 LD A,80       ; draw title 80 " Location " on row 0
 35292 CALL 31634    ;
 35295 LD HL,29630   ; then the 19 cells from CorridorPosTable
 35298 LD (31261),HL ;
 35301 LD B,19       ;
@label=DrawLocationListLoop
*35303 PUSH BC       ;
 35304 CALL 31626    ; draw next cell (room name / control row)
 35307 POP BC        ;
 35308 DJNZ 35303    ;
 35310 CALL 34882    ; highlight the cursor row / mirror its value
 35313 RET           ;

; RoomModeDispatch
;
@ignoreua
; Menu-row dispatch for room modes 0 and 1: re-dispatches the action
; key on the cursor ROW (#R33683) through the second half of the same
; word table — base $840C for mode 0 (the orders screen) or $8430 for
; mode 1 (the room view; see the row list at the RoomDispatchTable
; header).
@label=RoomModeDispatch
c35314 CALL 45753    ; A = room mode (0 or 1 here)
@nowarn=33804
 35317 LD HL,33804   ; mode-0 row-handler base
 35320 LD DE,36      ;
 35323 AND A         ;
 35324 JR Z,35327    ;
 35326 ADD HL,DE     ; mode 1: the room-view row table
@nowarn=33683
@label=DispatchOnCursorRow
@ssub=LD A,(CorridorCursor)
*35327 LD A,(33683)  ; cursor row
 35330 LD E,A        ;
 35331 ADD HL,DE     ;
 35332 ADD HL,DE     ; base + row*2
 35333 LD A,(HL)     ;
 35334 INC HL        ;
 35335 LD H,(HL)     ;
 35336 LD L,A        ;
 35337 JP (HL)       ; jump to the row's handler

; LocationListAction — action key in the room-location list (modes 2/3)
;
; Dispatched directly from RoomDispatchTable entries 2 and 3, on the
; cell value under the cursor: 61 "   QUIT   " leaves the list and
; rebuilds the orders screen (InitGameView #R31417); 62 "Other List"
; switches to the other page (mode 2 -> page 2, mode 3 -> page 1);
; any other value is a room id — show where that room is: look up its
; deck in RoomTypeTable (#R29905), make it the displayed deck
; (RoomTypeByte), redraw the map pane and set the room's indicator box
; blinking on it (marker channel B via PlaceRoomMarkerB #R35128). The
; list stays up, so several rooms can be looked up in a row; note the
; displayed deck keeps its last value after QUIT.
@label=LocationListAction
c35338 LD A,(33685)  ; A = cell value under the cursor
 35341 CP 61         ; "   QUIT   "?
 35343 JP Z,31417    ; yes: back to the orders screen
 35346 CP 62         ; "Other List"?
 35348 JR NZ,35361   ;
 35350 LD A,(31252)  ; yes: toggle page —
 35353 CP 2          ; on page 1 (mode 2)?
 35355 JP Z,35228    ; build page 2
 35358 JP 35222      ; else build page 1
@label=LocationListShowRoom
*35361 LD E,A        ; a room id was picked:
 35362 LD D,0        ;
 35364 LD HL,29905   ; RoomTypeTable[room]
 35367 ADD HL,DE     ;
 35368 LD A,(HL)     ;
 35369 LD (31243),A  ; = the deck to display
 35372 CALL 31267    ; redraw the map pane for that deck
 35375 LD A,(33685)  ; and blink the room's indicator box
 35378 CALL 35128    ; on it (marker channel B)
 35381 RET           ;

; MoveToRoom — action on a "move to:" destination row (2-6): set the
; actor's destination room from the row's value; in the ducts the
; destination comes from RoomAdjDucts by direction slot instead.
@label=MoveToRoom
c35382 LD A,64       ;
 35384 CALL 35814    ; set the actor's action timer
 35387 LD (IX+3),1   ; action state = 1
 35391 LD A,(31242)  ;
