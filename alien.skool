@ignoreua
; Per-screen RAM state
;
; First 35 bytes of the runtime RAM map. The remaining per-game-state
; scratchpad variables live further down in the code segment near
; #R33682 — see that block for the rest of the RAM map.
;
; Variables:
;   #R31232 GameStateBase    9-byte status block (crew alive flags?)
;   #R31241 ScreenDrawPtr    screen draw position (low byte first)
;   #R31243 RoomTypeByte     current room type id
;   #R31248 GameState_7A10   reserved (initial $FFFFFFFF)
;   #R31252 RoomModeByte     current room mode (drives RoomDispatchTable)
;   #R31261 CorridorTilePtr  pointer into corridor tile source
;   #R31263 CrewAnimFlags    XOR-blit toggle for crew sprite set A
;   #R31264 AnimFramePhase   XOR-blit toggle for set B / cursor
;   #R31265 ScriptPointer    ROM-traversal AI script pointer
;
; The bytes from #R31267 onwards in the original tape image hold
; executable code (the corridor-drawing routine called from #R31459).
; That code is preserved here as DEFB data only because the section
; was originally classified as RAM; it is invoked via CALL #R31267.
@label=GameStateBase
b31232 DEFB 9,9,9,9,9,9,9,45
 31240 DEFB 45
@label=ScreenDrawPtr
 31241 DEFB 5
@label=CurrentSlotID
 31242 DEFB 6              ; slot.byte+1 cached by SelectSlotByDrawIdx (#R31721)
@label=RoomTypeByte
 31243 DEFB 1,0,0,0,0
@label=GameState_7A10
 31248 DEFB 255,255,255,255
@label=RoomModeByte
 31252 DEFB 0,0,0,0
 31256 DEFB 88,0,64,0,96
@label=CorridorTilePtr
 31261 DEFB 0,0
@label=CrewAnimFlags
 31263 DEFB 128
@label=AnimFramePhase
 31264 DEFB 128
@label=ScriptPointer
 31265 DEFB 0,0
@label=DrawRoomBackground
