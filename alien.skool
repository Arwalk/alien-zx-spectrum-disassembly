; EngineStateScan — tick the three engine-room fires
;
; ShipSystemFlags bits 3-5 mark fires in Engine #1/#2/#3 (rooms
; 17-19, lit by the damage-meter alarm at #R38252). Each burning
; engine goes through FireDamageTick; then the 100-frame ship tick
; that paces fire damage is advanced.
; .
; Used by the routine at #R38379.
@label=EngineStateScan
c39041 LD D,8        ; D = bit mask (bit 3),
 39043 LD A,(31253)  ; A = ShipSystemFlags,
 39046 LD E,17       ; E = Engine #1's room
 39048 BIT 3,A       ; Engine #1 on fire?
 39050 CALL NZ,39077 ;
 39053 SLA D         ; next bit / next room:
 39055 INC E         ;
 39056 BIT 4,A       ; Engine #2 on fire?
 39058 CALL NZ,39077 ;
 39061 SLA D         ;
 39063 INC E         ;
 39064 BIT 5,A       ; Engine #3 on fire?
 39066 CALL NZ,39077 ;
@nowarn=38354
@ssub=LD HL,ShipTickCounter
 39069 LD HL,38354   ; advance the 100-frame ship tick
 39072 DEC (HL)      ;
 39073 RET NZ        ;
 39074 LD (HL),100   ;
 39076 RET           ;

; FireDamageTick — one burning engine room (E), fire bit in D
;
; The number of extinguisher squirts needed grows with the damage
; already done (1, 2 from "60", 3 from "80"). Enough squirts put the
; fire out: clear its ShipSystemFlags bit, blank the on-screen fire
; label, msg #15. Not enough: the fire keeps burning and adds a
; damage point every 100 frames (FireSpreadCheck).
; .
; Used by the routine at #R39041.
@label=FireDamageTick
c39077 PUSH AF       ;
 39078 PUSH DE       ;
 39079 LD C,1        ; C = squirts needed: 1,
 39081 LD B,D        ; (B = the engine's fire bit)
 39082 LD D,0        ;
 39084 LD HL,30006   ; HL -> the room's damage tens digit
 39087 ADD HL,DE     ;
 39088 ADD HL,DE     ;
 39089 LD A,(HL)     ;
 39090 CP 54         ; +1 from "60" damage,
 39092 JR C,39100    ;
 39094 INC C         ;
 39095 CP 56         ; +1 more from "80"
 39097 JR C,39100    ;
 39099 INC C         ;
@label=FireThresholdCheck
*39100 LD HL,38334   ; A = squirts delivered so far
 39103 ADD HL,DE     ; (EngineFixCounts, base-17 indexed)
 39104 LD A,(HL)     ;
 39105 CP C          ; enough to put it out?
 39106 JR C,39159    ; no: the fire keeps burning
 39108 LD A,(31253)  ; yes: clear the engine's fire bit
 39111 XOR B         ;
 39112 LD (31253),A  ;
 39115 LD A,(31252)  ; is the burning room on screen?
 39118 CP 1          ;
 39120 JR NZ,39149   ;
 39122 LD A,(31242)  ;
 39125 CP E          ;
 39126 JR NZ,39149   ;
 39128 LD HL,65535   ; yes: blank the fire label —
 39131 LD (29645),HL ; cells 15/16 = empty
 39134 LD A,L        ;
 39135 LD HL,20502   ; and redraw those rows
 39138 LD (31257),HL ; (screen rows 16/17, col 22)
 39141 CALL 31634    ;
 39144 LD A,255      ;
 39146 CALL 31634    ;
@label=FireExtinguishedMsg
*39149 POP HL        ; L = the room
 39150 PUSH HL       ;
 39151 LD A,15       ; msg #15 "Fire extinguished in {room}"
 39153 CALL 37176    ;
 39156 POP DE        ;
 39157 POP AF        ;
 39158 RET           ;

; FireSpreadCheck
;
; The fire is still burning: on the frame the 100-frame ship tick
; expires, it does another damage point to the room.
; .
; Used by the routine at #R39077.
@nowarn=38354
@label=FireSpreadCheck
@ssub=LD A,(ShipTickCounter)
