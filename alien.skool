; GameEntry
;
; Main game entry point. Initialises the stack, runs the title and options
; screens, then enters the per-frame main loop. The loop calls every major
; subsystem once per frame and repeats indefinitely.
;
; Used by the routines at #R43610 and #R44815.
@label=GameEntry
c36457 LD SP,65530   ; stack at $FFFA (top of game RAM, below extra data)
 36460 CALL 33600    ; ResetScriptPtr: seed ROM-traversal script pointer
 36463 CALL 42581    ; DrawIntroScreen: animated Alien title screen
 36466 CALL 42821    ; DrawShipMap: ship layout / room-selection screen
 36469 CALL 43610    ; OptionsScreen: difficulty selection (keys 1-4)
 36472 CALL 44561    ; ScreenTransition: wipe to black, set white attributes
 36475 CALL 45401    ; InitCrewPositions: sort crew records by pixel Y
 36478 CALL 31417    ; InitGameView: draw initial corridor view
*36481 CALL 34684    ; HandleInput: read keyboard, dispatch crew movement
 36484 CALL 40319    ; FrameTiming: one-frame delay or play queued sound
 36487 CALL 40826    ; UpdateAlien: move alien, attack reachable crew
 36490 CALL 41264    ; UpdateCrewState: advance per-crew action timers
 36493 CALL 37018    ; UpdateCrewAI: assign new action to idle crew member
 36496 CALL 37363    ; ProcessAnimQueue: step pending corridor animations
 36499 CALL 36859    ; UpdateRoomMode: evaluate current room's game state
 36502 CALL 35973    ; UpdateCorridors: advance all crew along corridor
 36505 CALL 34967    ; AnimateCrewA: XOR-blit crew animation frame set A
 36508 CALL 35016    ; AnimateCrewB: XOR-blit crew animation frame set B
 36511 CALL 44880    ; PlayMusic: output ROM-data beeper tone sequence
 36514 CALL 34967    ; AnimateCrewA: second blit (double-buffer XOR erase)
 36517 CALL 35016    ; AnimateCrewB: second blit (double-buffer XOR erase)
 36520 CALL 37363    ; ProcessAnimQueue: second pass
 36523 CALL 38379    ; UpdateCorridors: second movement pass
 36526 CALL 44313    ; DrawStatusPanel: refresh crew-alive status display
 36529 LD BC,63486   ; BC=$F7FE: keyboard row for keys 1-5
 36532 IN A,(C)      ; read key row (active-low: 0 = key pressed)
 36534 BIT 0,A       ; test key 1
 36536 CALL Z,44815  ; key 1 pressed: open pause/restart menu
 36539 CALL 33589    ; AdvanceScriptPtr: fetch next ROM script command
 36542 CP 0          ; command 0 = no-op
 36544 CALL Z,33589  ; skip second 0
 36547 CP 0          ;
 36549 CALL Z,33600  ; two consecutive 0s: reset script to start
 36552 JR 36481      ; loop forever
*36554 LD A,(IX+3)   ;
 36557 CP 4          ;
 36559 JR NZ,36574   ;
 36561 CALL 36717    ;
 36564 LD (IX+3),1   ;
 36568 LD (IX+0),20  ;
 36572 XOR A         ;
 36573 RET           ;
*36574 CP 3          ;
 36576 RET NC        ;
 36577 JR 36611      ;
