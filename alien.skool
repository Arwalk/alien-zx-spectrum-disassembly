 35466 LD C,E        ;
 35467 LD B,0        ;
 35469 ADD HL,BC     ;
 35470 LD E,(HL)     ; E = bonus[front]
 35471 LD C,D        ;
 35472 POP HL        ;
 35473 ADD HL,BC     ;
 35474 LD D,(HL)     ; D = bonus[back]
 35475 LD A,(IX+5)   ; courage += bonus[back] - bonus[front]
 35478 SUB E         ;
 35479 ADD A,D       ;
 35480 CP 127        ; (clamp underflow to 0)
 35482 JR C,35485    ;
 35484 XOR A         ;
@label=SwapItems_SetCourage
*35485 LD (IX+5),A   ;
 35488 LD A,(IX+6)   ; morale likewise
 35491 SUB E         ;
 35492 ADD A,D       ;
 35493 CP 127        ;
 35495 JR C,35498    ;
 35497 XOR A         ;
@label=SwapItems_SetMorale
