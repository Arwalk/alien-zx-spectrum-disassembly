; KeyboardScanner — the (redefinable) keyboard input device
;
; The keyboard entry of InputScannerTable. Each control is a
; self-modified (port, mask) pair patched by the redefinition flow at
; #R43904. A match sets the AlienFlags bit HandleInput expects:
; UP = bit 2 (cursor up = retreat), DOWN = bit 3 (advance), FIRE =
; bit 4 (action), "Return to QUIT" = bit 1 (row jump).
@nowarn=33682
@ssub=LD HL,AlienFlags
@label=KeyboardScanner
c44041 LD HL,33682   ; AlienFlags = no keys
 44044 LD (HL),0     ;
 44046 LD BC,32766   ; the UP key's port and mask
 44049 IN A,(C)      ; (both operands are patched):
 44051 AND 1         ; pressed?
 44053 JR NZ,44058   ;
 44055 SET 2,(HL)    ; yes: cursor up (retreat)
 44057 RET           ;
@label=KbdScan_Check2
*44058 LD BC,32766   ; the DOWN key
 44061 IN A,(C)      ;
 44063 AND 2         ;
 44065 JR NZ,44070   ;
 44067 SET 3,(HL)    ; cursor down (advance)
 44069 RET           ;
@label=KbdScan_Check3
*44070 LD BC,32766   ; the FIRE key
 44073 IN A,(C)      ;
 44075 AND 4         ;
 44077 JR NZ,44082   ;
 44079 SET 4,(HL)    ; action
 44081 RET           ;
@label=KbdScan_Check4
*44082 LD BC,32766   ; the "Return to QUIT" key
 44085 IN A,(C)      ;
 44087 AND 8         ;
 44089 RET NZ        ;
 44090 SET 1,(HL)    ; row jump
 44092 RET           ;

; WaitKeyPress — wait for any key and identify it
;
; Rotates through the 8 keyboard half-row ports until a key is down.
; Returns BC = that half-row's port and A = the key's bit mask —
; exactly the (port, mask) pair the redefinition flow patches into
; KeyboardScanner.
; .
; Used by the routines at #R43610 and #R44815.
@label=WaitKeyPress
c44093 LD BC,65278   ; start at half-row $FE
@label=WaitPress_Poll
*44096 IN A,(C)      ;
 44098 AND 31        ; any of its 5 keys down?
 44100 XOR 31        ; (A = pressed bits as 1s)
 44102 RET NZ        ; yes: BC/A identify it
 44103 RLC B         ; next half-row
 44105 JR C,44096    ;
 44107 JR 44093      ; wrapped: start over

; WaitKeyRelease — wait until no key is pressed anywhere
;
; Used by the routines at #R42821, #R43610 and #R44815.
@label=WaitKeyRelease
c44109 LD BC,65278   ; all 8 half-rows must
@label=WaitRelease_Poll
*44112 IN A,(C)      ; read clear
 44114 AND 31        ;
 44116 XOR 31        ;
 44118 JR NZ,44109   ; something still down: restart
 44120 RLC B         ;
 44122 JR C,44112    ;
 44124 RET           ;

; EndgameScreen — every way the game can end
;
; Five entry points, one per outcome; each wipes the screen, zeroes
; RatingScore and adds the terms that outcome earns before the shared
; roster/rating/wait-key tail (which restarts at GameEntry):
; .
;   EndgameScreen (#R44125) — the alien was killed in combat or died
;     in space: "The Alien has been killed"; scores crew + rooms +
;     oxygen (the only ending that counts ship condition).
;   Endgame_Escape (#R44159) — the Narcissus got away: with the
;     self-destruct armed, the frozen countdown digits are patched
;     into "The Nostromo will explode in m minutes ss seconds" and
;     crew + oxygen are scored; WITHOUT it the alien survives — "The
;     Alien will be unleashed upon the Earth", Competence Rating 0.
;   Endgame_CrewLost (#R44242) — no human left alive: "Humanoid life
;     levels minimal", then the same destruct-armed split.
;   Endgame_OxygenOut (#R44277) — the air ran out: "Life Support
;     Systems exhausted", every crew member is marked dead, then
;     the same destruct-armed split.
;   Endgame_Summary (#R44138) — from DamageGameOver (the ship broke
;     up or the countdown expired): the alien died with the ship, but
;     only the oxygen term is scored.
; .
; Used by the routines at #R37584 and #R38674.
@label=EndgameScreen
c44125 CALL 44561    ; wipe the screen
 44128 XOR A         ; RatingScore = 0,
@nowarn=40503
@ssub=LD (RatingScore),A
 44129 LD (40503),A  ;
 44132 CALL 44651    ; + crew term
 44135 CALL 44698    ; + room-condition term
; This entry point is used by the routine at #R44524.
@label=Endgame_Summary
*44138 CALL 44722    ; + oxygen term
 44141 CALL 44339    ; "The Alien has been killed"
@label=Endgame_Roster
*44144 CALL 44354    ; the dead-crew roster,
 44147 CALL 44428    ; "<name> was the Android",
 44150 CALL 44452    ; "Competence Rating nnn",
 44153 CALL 44591    ; wait for a key,
 44156 JP 36457      ; and restart the game
; This entry point is used by the routine at #R40281.
@label=Endgame_Escape
*44159 CALL 44561    ; wipe the screen
 44162 XOR A         ; RatingScore = 0
@nowarn=40503
@ssub=LD (RatingScore),A
 44163 LD (40503),A  ;
@nowarn=42068
@ssub=LD DE,StrNarcissusLaunched
 44166 LD DE,42068   ; "The Narcissus is launched"
 44169 LD B,25       ;
 44171 LD HL,16387   ;
 44174 LD (31257),HL ;
 44177 CALL 44509    ;
 44180 LD HL,31253   ; was the self-destruct armed?
 44183 BIT 0,(HL)    ;
 44185 JR NZ,44193   ; yes: the Nostromo (and alien) die
 44187 CALL 44622    ; no: the alien reaches Earth —
 44190 JP 44144      ; rating stays 0
@nowarn=38364
