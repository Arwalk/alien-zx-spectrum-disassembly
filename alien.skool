 39772 LD E,A        ;
 39773 LD D,0        ;
 39775 INC HL        ; HL -> frame pointer table
 39776 ADD HL,DE     ;
 39777 ADD HL,DE     ; HL -> table[frame] (2 bytes/entry)
 39778 LD E,(HL)     ;
 39779 INC HL        ;
 39780 LD D,(HL)     ; DE = sprite frame data ptr
@ignoreua
