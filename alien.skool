; InitJonesAnim
;
; Resets Jones animation and blits the first frame. Sets Y position to 8,
; clears the Y phase freeze flag, then calls #R39832 with B=1 to draw frame 0.
; This entry point is used by the routines at #R31634 and #R36859.
@label=InitJonesAnim
c39655 XOR A         ; A = 0: clear freeze flag
@nowarn=39753
@ssub=LD (JonesPhase),A
 39656 LD (39753),A  ; JonesPhase = 0
 39659 LD A,8        ;
 39661 LD (39750),A  ; JonesPos = 8 (initial Y pixel offset)
 39664 LD B,1        ; B = 1 iteration
 39666 CALL 39832    ; draw first tail frame
 39669 RET           ;

; TriggerJonesAnim
;
; Advances the Jones animation by one frame if not frozen. Sets the freeze
; flag (bit 7 of JonesPhase) after blitting so the animation runs exactly once.
; This entry point is used by the routines at #R35578 and #R36859.
@label=TriggerJonesAnim
c39670 LD B,1        ; B = 1 iteration
@nowarn=39753
@ssub=LD A,(JonesPhase)
 39672 LD A,(39753)  ; A = JonesPhase
 39675 AND 128       ; test freeze flag (bit 7)
 39677 RET NZ        ; already frozen: do nothing
 39678 CALL 39832    ; blit one tail frame
 39681 LD A,128      ;
@nowarn=39753
@ssub=LD (JonesPhase),A
 39683 LD (39753),A  ; freeze: JonesPhase |= 128
 39686 RET           ;

; ResetAlienXAnim
;
; Clears the alien body animation area from the screen, then resets the X phase
; counter so the next trigger starts from frame 0.
; This entry point is used by the routines at #R31634 and #R44880.
@label=ResetAlienXAnim
c39687 CALL 40149    ; clear 19x20-cell screen area (ClearAlienArea)
 39690 XOR A         ; A = 0
@nowarn=39741
@ssub=LD (AlienXPhase),A
 39691 LD (39741),A  ; AlienXPhase = 0 (unfreeze, frame 0)
 39694 RET           ;

; TriggerAlienXAnim
;
; Arms the alien body animation (sets freeze flag so a single blit occurs next frame),
; or ends the encounter sequence. If (RoomModeByte)=1 the crew member was killed: jump to
; #R32719 to handle that. Otherwise clears the screen area and returns.
; This entry point is used by the routines at #R36457 and #R37490.
@nowarn=39741
@label=TriggerAlienXAnim
@ssub=LD A,(AlienXPhase)
c39695 LD A,(39741)  ; A = AlienXPhase
 39698 AND 128       ; test freeze flag
 39700 RET NZ        ; already frozen: do nothing
 39701 LD A,128      ;
@nowarn=39741
@ssub=LD (AlienXPhase),A
 39703 LD (39741),A  ; freeze: AlienXPhase |= 128
 39706 LD A,(31252)  ; A = encounter outcome byte
 39709 CP 1          ; crew member killed?
 39711 JP Z,32719    ; yes: handle death sequence
 39714 CALL 40149    ; no: clear alien screen area
 39717 RET           ;

; UpdateAlienAnim
;
; Per-frame alien encounter update: refreshes the map view, then advances both
; animation layers. Y layer (tail sweep) if not frozen, X layer (body) if not frozen.
@label=UpdateAlienAnim
c39718 CALL 34967    ; redraw room background
 39721 CALL 35016    ; redraw room actors
@nowarn=39753
@ssub=LD A,(JonesPhase)
 39724 LD A,(39753)  ; A = JonesPhase
 39727 AND 128       ; test freeze flag
 39729 CALL Z,39830  ; not frozen: advance Y animation
@nowarn=39741
@ssub=LD A,(AlienXPhase)
 39732 LD A,(39741)  ; A = AlienXPhase
 39735 AND 128       ; test freeze flag
 39737 CALL Z,39764  ; not frozen: blit next alien body frame
 39740 RET           ;

; AlienAnimVars
