; AddAlienRoomDamage
;
; Add A damage points to the ALIEN's current room (then fall into the
; general AddRoomDamage below).
; .
; Used by the routines at #R37018 and #R37584.
@label=AddAlienRoomDamage
c38182 LD HL,29567   ; E = the alien's current room
 38185 LD E,(HL)     ;
; This entry point is used by the routines at #R39159 and #R40941.
; AddRoomDamage: add A damage points to room E's damage meter — a
; 2-digit ASCII pair in RoomDamageDigits (#R30006; tens digit is
; the severity the engine scan at #R39041 compares against). Crossing
; "30" raises the room-specific alarm messages #22-#25.
@label=AddRoomDamage
*38186 BIT 6,E       ; no damage meters in the duct network
 38188 RET NZ        ;
 38189 LD HL,30006   ; per-room ASCII damage digits (tens,units)
 38192 LD D,0        ;
 38194 ADD HL,DE     ;
 38195 ADD HL,DE     ;
 38196 INC HL        ; HL -> units digit
 38197 LD B,A        ; B = damage points to add
@label=Damage_PointLoop
*38198 PUSH BC       ; per damage point: the meter climbs
 38199 PUSH HL       ; in half-steps of the tens digit —
 38200 PUSH DE       ;
 38201 LD A,(HL)     ; units already '5'?
 38202 CP 53         ;
 38204 JR Z,38210    ;
 38206 LD (HL),53    ; no: units 0 -> 5
 38208 JR 38298      ;
@label=Damage_TensCarry
*38210 LD (HL),48    ; yes: units '5' -> '0',
 38212 DEC HL        ; carry into the tens digit
 38213 INC (HL)      ;
 38214 LD A,(HL)     ; tens reached '3'?
 38215 CP 51         ;
 38217 JR NZ,38281   ;
 38219 LD A,E        ; damage tens digit reached '3': room alarms
 38220 CP 6          ; CommdCentr?
 38222 JR NZ,38228   ;
 38224 LD A,22       ; msg #22 "Partial loss of control systems"
 38226 JR 38288      ;
@label=Damage_ChkComputer
*38228 CP 7          ; Computer room?
 38230 JR NZ,38236   ;
 38232 LD A,23       ; msg #23 "Computer Malfunction detected"
 38234 JR 38288      ;
@label=Damage_ChkLifeSupt
*38236 CP 25         ; Life Support?
 38238 JR NZ,38244   ;
 38240 LD A,24       ; msg #24 "Environmental irregularities"
 38242 JR 38288      ;
@label=Damage_ChkNarcissus
*38244 CP 34         ; the Narcissus?
 38246 JR NZ,38252   ;
 38248 LD A,25       ; msg #25 "Narcissus status RED"
 38250 JR 38288      ;
@label=Damage_ChkEngines
*38252 CP 17         ; an engine room (17-19)?
 38254 JR C,38298    ;
 38256 CP 20         ;
 38258 JR NC,38298   ; other rooms: no "30" alarm
 38260 AND 3         ; room 17/18/19 -> flag bit 3/4/5:
 38262 LD B,A        ;
 38263 LD A,4        ;
@label=Damage_EngineBit
*38265 ADD A,A       ; A = 4 << (room & 3)
 38266 DJNZ 38265    ;
 38268 LD HL,31253   ; the engine room catches FIRE —
 38271 OR (HL)       ; set its ShipSystemFlags bit
 38272 LD (HL),A     ;
 38273 LD L,E        ; L = room for the {room} field
 38274 LD A,9        ; msg #9 "WARNING: Fire in {room}"
 38276 CALL 37176    ;
 38279 JR 38298      ;
@label=Damage_ChkStructural
*38281 CP 55         ; tens reached '7' (70 damage)?
 38283 JR NZ,38293   ;
 38285 LD L,E        ; L = room
 38286 LD A,8        ; msg #8 "Structural Damage in {room}"
@label=Damage_SendMsg
*38288 CALL 37176    ;
 38291 JR 38298      ;
@label=Damage_ChkOverflow
*38293 CP 58         ; tens past '9' (100 damage)?
 38295 CALL Z,38317  ; the ship breaks up - game over
@label=Damage_NextPoint
*38298 POP DE        ;
 38299 POP HL        ;
 38300 POP BC        ;
 38301 DJNZ 38198    ; next damage point
 38303 LD A,(31252)  ; is the damaged room the one on
 38306 CP 1          ; screen?
 38308 RET NZ        ;
 38309 LD A,(31242)  ;
 38312 CP E          ;
 38313 CALL Z,32143  ; yes: redraw the title/damage line
 38316 RET           ;

; DamageOverflowFlash — the hull gives way
;
; A room's damage meter has passed 99 (or the destruct countdown ran
; out): ~7 seconds of screen flashing with a rainbow border, then the
; ship is lost (DamageGameOver #R44524).
; .
; Used by the routines at #R38182 and #R38784.
@label=DamageOverflowFlash
c38317 PUSH BC       ;
 38318 PUSH AF       ;
 38319 LD B,100      ; 100 flash cycles:
@label=DamageFlash_Loop
*38321 PUSH BC       ;
 38322 CALL 36448    ; ~36 ms delay,
 38325 LD A,7        ; attributes = white ink on black,
 38327 CALL 42515    ;
 38330 CALL 36448    ; ~36 ms delay,
 38333 LD A,56       ; attributes = black ink on white
 38335 CALL 42515    ;
 38338 POP BC        ;
 38339 LD A,B        ; border cycles through
 38340 AND 7         ; all 8 colours
 38342 OUT (254),A   ;
 38344 DJNZ 38321    ;
 38346 POP AF        ;
 38347 POP BC        ;
 38348 JP 44524      ; game over: the Nostromo is lost
; Ship-status dashboard: counters and ASCII digit cells (previously
; mis-disassembled as code). The digit cells double as the source text
; drawn on the status bar, and the endgame renderer copies them into
; the "The Nostromo will explode in .. minutes .. seconds" screen.
@label=EngineFixCounts
 38351 DEFB 0,0,0    ; per-engine-room (17/18/19) fire-fighting progress,
                     ; +1 per squirt (FightFireSquirt #R38575)
@label=ShipTickCounter
 38354 DEFB 50       ; ship-systems tick countdown (reloaded with 100 by
                     ; the engine-state scan at #R39041)
@label=DestructTickCounter
 38355 DEFB 3        ; destruct-second countdown (reloaded with 20 by the
                     ; ticker at #R38846)
@label=AdjTestRoom
 38356 DEFB 0        ; scratch: room of the actor under adjacency test
@label=OxygenTickInit
 38357 DEFB 10       ; oxygen tick reload value
@label=DestructTimeText
 38358 DEFM "TIME: " ; status-bar label for the destruct countdown
@label=DestructMinutes
 38364 DEFB 0        ; minutes digit, ASCII ('5' when armed at #R38454)
 38365 DEFM ":"
@label=DestructSeconds
 38366 DEFB 0,0      ; seconds digits, ASCII ("00" when armed); the low
                     ; digit also drives the border flicker while armed
@label=OxygenText
 38368 DEFM "TOOH: " ; oxygen label as stored on the tape (sic)
@label=OxygenHi
 38374 DEFM "75"     ; oxygen level, ASCII, counting down; msg #26
@label=OxygenLo
 38376 DEFM "00"     ; "Oxygen status CRITICAL" fires at "05"+"00"
@label=EventPaceCounter
 38378 DEFB 0        ; free-running pace counter gating an event every
                     ; 8 ticks (inside #R38379)

; UpdateRoomActors — per-frame ship-simulation driver
;
; Despite the old name, this is the SHIP-SIMULATION driver: six calls
; covering the destruct countdown, fixture proximity events, the
; oxygen clock, event pacing, engine states and the alien encounter
; animation. The fixture-action handlers the action key dispatches
; into (destruct lever, hypersleep pods, fires, airlocks, launch
; console) follow as their own routines from FixtureAction (#R38398).
; .
; Used by the routine at #R36457.
@label=UpdateRoomActors
c38379 CALL 38846    ; DestructTicker: countdown + border flash
 38382 CALL 38903    ; FindTrackerHolders: motion-tracker scan
 38385 CALL 39531    ; oxygen clock / status line
 38388 CALL 39171    ; ViewedTrackerCheck: beep / uneasy cat
 38391 CALL 39041    ; EngineStateScan: engine fires
 38394 CALL 39718    ; alien encounter animation layers
 38397 RET           ;

; FixtureAction
;
; The action-key (key 0) handler for corridor fixtures,
; dispatched via the RoomDispatchTable tail. Reads the corridor cell
; under the cursor and dispatches on the CELL VALUE:
;   70 -> arm self-destruct     72 -> abort self-destruct
;   74 -> enter hypersleep pod  76 -> fight fire (engine rooms)
;   78 -> Narcissus launch      53/54 -> blow airlock #1/#2
;   55/56 -> seal airlock #1/#2
@label=FixtureAction
c38398 CALL 45846    ; cancel any pending countdown;
 38401 LD HL,29630   ; A = the cursor row —
 38404 LD E,A        ; index CorridorPosTable by it
 38405 LD D,0        ;
 38407 ADD HL,DE     ;
 38408 LD A,(HL)     ; A = cell value under the cursor
 38409 LD (33685),A  ;
 38412 CP 70         ; destruct lever (off)?
 38414 JR Z,38454    ;
 38416 CP 72         ; destruct lever (armed)?
 38418 JR Z,38483    ;
 38420 CP 74         ; hypersleep pod?
 38422 JR Z,38529    ;
 38424 CP 76         ; fire?
 38426 JR Z,38546    ;
 38428 CP 78         ; launch console?
 38430 JP Z,40212    ;
 38433 CP 53         ; airlock #1 door (closed)?
 38435 JP Z,38645    ; blow it
 38438 CP 54         ; airlock #2 door (closed)?
 38440 JP Z,38645    ; blow it
 38443 CP 55         ; airlock #1 door (blown)?
 38445 JP Z,38588    ; seal it
 38448 CP 56         ; airlock #2 door (blown)?
 38450 JP Z,38588    ; seal it
 38453 RET           ; anything else: no action

