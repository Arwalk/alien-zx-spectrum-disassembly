 35411 LD A,(31242)  ;
 35414 AND 63        ;
 35416 LD L,A        ;
 35417 LD H,0        ;
 35419 PUSH HL       ;
 35420 ADD HL,HL     ;
 35421 ADD HL,HL     ;
 35422 POP DE        ;
 35423 ADD HL,DE     ; room * 5
 35424 LD DE,29346   ; + RoomAdjDucts
 35427 ADD HL,DE     ;
 35428 POP AF        ;
 35429 LD D,0        ;
 35431 LD E,A        ;
 35432 ADD HL,DE     ; + direction slot
 35433 LD A,(HL)     ;
 35434 OR 64         ; destination stays inside the ducts
 35436 LD (IX+2),A   ;
 35439 RET           ;

; QuitRoomView
;
; Action on the QUIT row (17): freeze the crew
; animation and return to the ship view.
@label=QuitRoomView
c35440 LD HL,31263   ; freeze animation channel A
 35443 SET 7,(HL)    ;
 35445 JP 31417      ; back to the orders/ship view

